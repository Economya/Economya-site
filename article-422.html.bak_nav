.ah{background:linear-gradient(135deg,#0f0c29,#1e1b5e,#4338ca);color:white;padding:3rem 2rem 2.5rem;position:relative;overflow:hidden}
.ah::before{content:'💤';position:absolute;font-size:16rem;right:-1rem;top:-2rem;opacity:.07;pointer-events:none;line-height:1}
.hi{max-width:760px;margin:0 auto;position:relative;z-index:1;text-align:center}
.cat-pill{display:inline-flex;align-items:center;gap:.4rem;background:rgba(255,255,255,.12);border:1px solid rgba(255,255,255,.2);color:#c7d2fe;font-size:.72rem;font-weight:600;text-transform:uppercase;letter-spacing:.08em;padding:.28rem .9rem;border-radius:50px;margin-bottom:.9rem}
.ah h1{font-family:'Playfair Display',serif;font-size:clamp(1.8rem,4vw,2.8rem);font-weight:900;line-height:1.15;margin-bottom:.9rem}
.ah h1 em{color:#a5b4fc;font-style:normal}
.savings-badge{display:inline-flex;align-items:center;gap:.5rem;background:linear-gradient(135deg,#f59e0b,#4338ca);color:white;font-size:.88rem;font-weight:700;padding:.45rem 1.2rem;border-radius:50px;margin-bottom:1.3rem;box-shadow:0 4px 14px rgba(67,56,202,.35)}
.meta-row{display:flex;flex-wrap:wrap;gap:.6rem;justify-content:center}
.meta-item{display:inline-flex;align-items:center;gap:.3rem;background:rgba(255,255,255,.1);border:1px solid rgba(255,255,255,.15);padding:.22rem .7rem;border-radius:50px;color:rgba(255,255,255,.8);font-size:.74rem}
.theme-tag{background:linear-gradient(135deg,#4338ca,#16a34a);color:white;font-weight:600;padding:.22rem .8rem;border-radius:50px;font-size:.72rem}
.ab{max-width:760px;margin:0 auto;padding:2.5rem 2rem 4rem}
.lead{font-size:1.05rem;color:var(--m);font-weight:300;border-left:4px solid var(--indigo);padding-left:1.2rem;margin-bottom:2rem;line-height:1.8}
h2{font-family:'Playfair Display',serif;font-size:1.35rem;font-weight:700;margin:2.2rem 0 1rem;display:flex;align-items:center;gap:.5rem}
p{margin-bottom:1rem;font-size:.95rem}

/* REVENUS */
.revenus{display:flex;flex-direction:column;gap:1rem;margin:1.5rem 0}
.revenu{background:var(--w);border:1px solid var(--b);border-radius:var(--r);padding:1.2rem 1.5rem;display:grid;grid-template-columns:auto 1fr auto;gap:1rem;align-items:start;transition:box-shadow .2s}
.revenu:hover{box-shadow:0 4px 18px rgba(67,56,202,.1)}
.revenu.top{border:2px solid var(--g)}
.revenu.faux{border:2px solid #dc2626;background:#fef9f9}
.top-badge{display:inline-block;background:var(--g);color:white;font-size:.65rem;font-weight:700;padding:.1rem .5rem;border-radius:50px;margin-bottom:.3rem}
.faux-badge{display:inline-block;background:#dc2626;color:white;font-size:.65rem;font-weight:700;padding:.1rem .5rem;border-radius:50px;margin-bottom:.3rem}
.r-icon{font-size:1.8rem;flex-shrink:0;margin-top:.1rem}
.r-body h3{font-size:.92rem;font-weight:700;margin-bottom:.2rem}
.r-body p{font-size:.82rem;color:var(--m);font-weight:300;margin:0 0 .4rem}
.r-tags{display:flex;flex-wrap:wrap;gap:.3rem}
.rtag{font-size:.68rem;font-weight:600;padding:.1rem .45rem;border-radius:50px;background:var(--indigo-l);color:#1e1b5e}
.rtag.g{background:var(--gl);color:var(--gd)}
.rtag.r{background:#fee2e2;color:#991b1b}
.r-right{text-align:right;flex-shrink:0}
.r-revenu{font-family:'Playfair Display',serif;font-size:1rem;font-weight:700;display:block;white-space:nowrap}
.revenu.top .r-revenu,.revenu:not(.faux) .r-revenu{color:var(--g)}
.revenu.faux .r-revenu{color:#dc2626}
.r-sub{font-size:.7rem;color:var(--m)}

/* ENCADRÉS */
.tip{background:var(--gl);border-left:4px solid var(--g);border-radius:var(--r);padding:1.1rem 1.4rem;margin:1.5rem 0;font-size:.9rem;color:var(--gd)}
.tip strong{display:block;font-weight:600;margin-bottom:.25rem}
.warn{background:var(--indigo-l);border-left:4px solid var(--indigo);border-radius:var(--r);padding:1.1rem 1.4rem;margin:1.5rem 0;font-size:.9rem;color:#1e1b5e}
.warn strong{display:block;font-weight:600;margin-bottom:.25rem}

.cta{background:linear-gradient(135deg,#0f0c29,#1e1b5e);border-radius:var(--r);padding:1.8rem;text-align:center;margin-top:2.5rem;color:white}
.cta h3{font-family:'Playfair Display',serif;font-size:1.2rem;margin-bottom:.4rem}
.cta p{color:rgba(255,255,255,.7);font-size:.86rem;margin-bottom:1rem}
.cta-form{display:flex;gap:.5rem;max-width:360px;margin:0 auto;flex-wrap:wrap;justify-content:center}
.cta-form input{flex:1;min-width:150px;padding:.65rem 1rem;border-radius:50px;border:none;font-size:.86rem;font-family:inherit}
.cta-form button{background:linear-gradient(135deg,#4338ca,#16a34a);color:white;border:none;padding:.65rem 1.3rem;border-radius:50px;font-weight:600;cursor:pointer;font-family:inherit;font-size:.86rem}
footer{background:var(--gd);color:rgba(255,255,255,.6);text-align:center;padding:1.5rem;font-size:.8rem}
footer strong{color:white}
@media(max-width:640px){.ah{padding:2rem 1.2rem}.ab{padding:1.8rem 1.1rem 3rem}.ah::before{font-size:8rem}.revenu{grid-template-columns:1fr;gap:.5rem}.r-right{text-align:left}}

/* Menu hamburger mobile */
.hamburger{display:none;flex-direction:column;gap:5px;cursor:pointer;background:none;border:none;padding:.3rem}
