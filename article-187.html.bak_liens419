<title>Changer de banque et économiser — Economya.fr</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;700;900&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet">
<style>
  *,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
  : root{
    --g:#1D9E75;--gl:#E1F5EE;--gd:#085041;--a:#EF9F27;--al:#FAEEDA;--ad:#633806;
    --t:#2C2C2A;--m:#5F5E5A;--bg:#FAFAF8;--w:#fff;--b:rgba(0,0,0,0.1);
    --emerald:#004F3B;--emerald-mid:#007A5C;--emerald-light:#E0F5EF;
    --gold:#C8960A;--silver:#B0BEC5;--mint:#00E5A0;
  }
  body{font-family:'DM Sans',sans-serif;background:var(--bg);color:var(--t);line-height:1.7}
  nav{display:flex;justify-content:space-between;align-items:center;padding:.9rem 1.8rem;background:var(--w);border-bottom:1px solid var(--b);position:sticky;top:0;z-index:99}
  .logo{font-family:'Playfair Display',serif;font-weight:900;font-size:1.3rem;color:var(--gd);text-decoration:none}
  .logo span{color:var(--a)}
  .back{font-size:.82rem;color:var(--m);text-decoration:none}
  .back:hover{color:var(--g)}

  .hero-art{
    background:linear-gradient(135deg,#001A12 0%,#004F3B 35%,#007A5C 65%,#C8960A 100%);
    padding:3.5rem 2rem 3rem;text-align:center;position:relative;overflow:hidden
  }
  .hero-art::before{
    content:'🏦';position:absolute;font-size:13rem;opacity:.06;
    top:50%;left:50%;transform:translate(jusqu'à -50%,jusqu'à -50%);pointer-events:none
  }
  .acat{font-size:.85rem;font-weight:500;color:rgba(255,255,255,.6);margin-bottom:.6rem;letter-spacing:.04em}
  .acat strong{color:#fff}
  .hero-art h1{
    font-family:'Playfair Display',serif;font-size:clamp(1.7rem,4vw,2.6rem);
    font-weight:900;line-height:1.1;color:#fff;max-width:620px;margin:0 auto .9rem
  }
  .abadge{
    display:inline-block;
    background:linear-gradient(90deg,#FFE082,var(--mint));
    color:#001A12;font-size:.82rem;font-weight:700;padding:.35rem 1rem;
    border-radius:50px;margin-top:.4rem
  }
  .meta{display:flex;justify-content:center;flex-wrap:wrap;gap:.6rem;margin-top:1.2rem}
  .meta span{font-size:.74rem;color:rgba(255,255,255,.55);background:rgba(255,255,255,.1);padding:.2rem .75rem;border-radius:50px}

  article{max-width:680px;margin:0 auto;padding:2.5rem 1.5rem 4rem}
  article p{margin-bottom:1.3rem;font-size:.97rem;font-weight:300}
  article h2{font-family:'Playfair Display',serif;font-size:1.2rem;font-weight:700;color:var(--emerald);margin:2rem 0 .7rem}

  /* Banques comparées */
  .banques{display:flex;flex-direction:column;gap:.7rem;margin:1.5rem 0}
  .banque{background:var(--w);border:1px solid var(--b);border-radius:12px;overflow:hidden}
  .banque-head{display:grid;grid-template-columns:1fr auto auto;align-items:center;padding:.7rem 1.1rem;gap:.6rem;color:#fff}
  .banque-head.neo{background:linear-gradient(90deg,#001A12,#004F3B)}
  .banque-head.online{background:linear-gradient(90deg,#0E2A40,#0077B6)}
  .banque-head.trad{background:linear-gradient(90deg,#2A1A00,#6B4200)}
  .banque-nom{font-weight:600;font-size:.9rem}
  .banque-tarif{color:var(--mint);font-weight:700;font-size:.85rem;white-space:nowrap}
  .banque-type{font-size:.69rem;font-weight:500;background:rgba(255,255,255,.15);padding:.1rem .45rem;border-radius:50px;white-space:nowrap}
  .banque-body{padding:.85rem 1.1rem}
  .banque-desc{font-size:.84rem;font-weight:300;color:var(--m);line-height:1.55;margin-bottom:.5rem}
  .banque-avantages{display:flex;flex-wrap:wrap;gap:.35rem}
  .bav{font-size:.71rem;font-weight:500;padding:.1rem .5rem;border-radius:50px;background:var(--emerald-light);color:var(--emerald)}
  .bav.warn{background:#FEF3C7;color:#92400E}

  /* Tableau frais */
  .frais{width:100%;border-collapse:collapse;margin:1.5rem 0;font-size:.83rem}
  .frais thead tr{background:linear-gradient(90deg,var(--emerald),var(--emerald-mid));color:#fff}
  .frais thead th{padding:.62rem .9rem;text-align:left;font-weight:500}
  .frais tbody tr:nth-child(even){background:var(--emerald-light)}
  .frais tbody tr:nth-child(odd){background:var(--w)}
  .frais tbody td{padding:.55rem .9rem;border-bottom:1px solid var(--b);font-weight:300}
  .frais tbody td:first-child{font-weight:500;color:var(--emerald)}
  .frais td.cher{color:#B91C1C;font-weight:500;white-space:nowrap}
  .frais td.gratuit{color:var(--gd);font-weight:600;white-space:nowrap}
  .frais tr.total td{font-weight:700;background:var(--emerald-light)}

  /* Étapes changement */
  .etapes{display:flex;flex-direction:column;gap:0;border:1px solid var(--b);border-radius:12px;overflow:hidden;margin:1.5rem 0}
  .etape{display:grid;grid-template-columns:44px 1fr;border-bottom:1px solid var(--b)}
  .etape:last-child{border-bottom:none}
  .etape-num{background:linear-gradient(180deg,var(--emerald),var(--emerald-mid));color:var(--mint);font-family:'Playfair Display',serif;font-weight:900;font-size:1.1rem;display:flex;align-items:center;justify-content:center}
  .etape-body{padding:.75rem 1rem;background:var(--w)}
  .etape-title{font-weight:500;font-size:.88rem;color:var(--emerald);margin-bottom:.15rem}
  .etape-desc{font-size:.81rem;font-weight:300;color:var(--m);line-height:1.5}

  .conseil{
    background:linear-gradient(135deg,#001A12,#004F3B);
    border-radius:12px;padding:1.2rem 1.4rem;margin:1.8rem 0;color:#fff;
    border:1px solid rgba(0,229,160,.12)
  }
  .conseil strong{display:block;color:#FFE082;font-weight:500;font-size:.92rem;margin-bottom:.4rem}
  .conseil p{font-size:.88rem;color:rgba(255,255,255,.82);font-weight:300;margin:0;line-height:1.65}

  footer{background:var(--gd);color:rgba(255,255,255,0.6);text-align:center;padding:1.6rem;font-size:.8rem}
  footer strong{color:white}
  footer a{color:var(--a);text-decoration:none}

/* Menu hamburger mobile */
.hamburger{display:none;flex-direction:column;gap:5px;cursor:pointer;background:none;border:none;padding:.3rem}
.hamburger span{display:block;width:24px;height:2px;background:var(--gd,#085041);border-radius:2px;transition:all .3s}
.mobile-menu{display:none;position:fixed;top:0;left:0;right:0;bottom:0;background:rgba(255,255,255,.98);z-index:999;flex-direction:column;align-items:center;justify-content:center;gap:1.5rem}
.mobile-menu.open{display:flex}
.mobile-menu a{font-family:'Playfair Display',serif;font-size:1.3rem;font-weight:700;color:#085041;text-decoration:none}
.mobile-menu .close-btn{position:absolute;top:1.2rem;right:1.5rem;background:none;border:none;font-size:1.8rem;cursor:pointer;color:#085041}
.mobile-menu .nav-cta{background:#1D9E75;color:white!important;padding:.5rem 1.4rem;border-radius:50px}
@media(max-width:768px){
  .hamburger{display:flex}
  nav .nav-links,nav > a:not(.logo),nav > div:not(.mobile-menu){display:none!important}
  nav li{display:none!important}
}
