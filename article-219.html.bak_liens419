  /* HERO — violet profond → indigo → lavande dorée */
  .hero{background:linear-gradient(135deg,#0C0018 0%,#300860 32%,#6020B0 62%,#A060E0 84%,#F0C080 100%);padding:3.8rem 2rem 3.2rem;text-align:center;position:relative;overflow:hidden}
  .hero::before{content:'🤝';position:absolute;font-size:14rem;opacity:.05;top:50%;left:50%;transform:translate(jusqu'à -50%,jusqu'à -50%);pointer-events:none}
