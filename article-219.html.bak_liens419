  .hero-meta span{font-size:.73rem;color:rgba(255,255,255,.5);background:rgba(255,255,255,.09);padding:.2rem .75rem;border-radius:50px}

  article{max-width:700px;margin:0 auto;padding:2.5rem 1.5rem 5rem}
  article p{margin-bottom:1.3rem;font-size:.97rem;font-weight:300;line-height:1.75}
  h2{font-family:'Playfair Display',serif;font-size:1.2rem;font-weight:700;color:#300860;margin:2.2rem 0 .8rem}

  /* TIMELINE PROCÉDURE */
  .timeline{display:flex;flex-direction:column;gap:0;margin:1.5rem 0;position:relative}
  .timeline::before{content:'';position:absolute;left:21px;top:22px;bottom:22px;width:2px;background:linear-gradient(180deg,#6020B0,#A060E0 60%,rgba(160,96,224,.1))}
  .tl{display:grid;grid-template-columns:44px 1fr;gap:.9rem;padding:.75rem 0;align-items:flex-start}
  .tl-dot{width:44px;height:44px;border-radius:50%;background:linear-gradient(135deg,#300860,#6020B0);color:#F0C080;font-family:'Playfair Display',serif;font-weight:900;font-size:.9rem;display:flex;align-items:center;justify-content:center;flex-shrink:0;position:relative;z-index:1;box-shadow:0 2px 10px rgba(96,32,176,.3);text-align:center;line-height:1.2}
  .tl-body{padding-top:.3rem}
  .tl-titre{font-weight:500;font-size:.9rem;color:#300860;margin-bottom:.2rem}
  .tl-desc{font-size:.83rem;font-weight:300;color:#5F5E5A;line-height:1.55}
  .tl-badge{display:inline-block;margin-top:.35rem;font-size:.72rem;font-weight:600;padding:.1rem .55rem;border-radius:50px}
  .tl-badge.delai{background:#F0EEFF;color:#300860}
  .tl-badge.important{background:#FEF3C7;color:#713F12}
  .tl-badge.alerte{background:#FEE2E2;color:#7F1D1D}

  /* CALCUL INDEMNITÉ */
  .indemnite{background:#fff;border:1px solid rgba(0,0,0,.08);border-radius:13px;overflow:hidden;margin:1.5rem 0}
  .indem-head{background:linear-gradient(90deg,#300860,#6020B0);padding:.8rem 1.2rem;color:#fff;font-family:'Playfair Display',serif;font-weight:700;font-size:.95rem}
  .indem-row{display:grid;grid-template-columns:1.5fr 1fr;border-bottom:1px solid rgba(0,0,0,.06);font-size:.84rem;align-items:center}
  .indem-row.header{background:#F5F0FF;font-weight:600;font-size:.75rem;color:#300860;text-transform:uppercase;letter-spacing:.04em}
  .indem-row:last-child{border-bottom:none}
  .indem-row:nth-child(even):not(.header){background:#FAFAFA}
  .indem-cell{padding:.58rem .9rem;font-weight:300;color:#2C2C2A}
  .indem-cell.label{font-weight:500;color:#300860}
  .indem-cell.montant{font-weight:600;color:#6020B0}

  /* COMPARATIF RC VS LICENCIEMENT VS DÉMISSION */
  .compare{display:grid;grid-template-columns:repeat(3,1fr);gap:.65rem;margin:1.5rem 0}
  .comp-col{border-radius:12px;overflow:hidden;border:1px solid rgba(0,0,0,.08)}
  .comp-head{padding:.65rem .7rem;color:#fff;font-weight:700;font-size:.83rem;text-align:center}
  .comp-head.rc{background:linear-gradient(135deg,#300860,#6020B0)}
  .comp-head.licenc{background:linear-gradient(135deg,#7F1D1D,#B91C1C)}
  .comp-head.demis{background:linear-gradient(135deg,#3A1A00,#8B4500)}
  .comp-body{background:#fff;padding:.75rem .8rem}
  .comp-item{font-size:.78rem;font-weight:300;padding:.22rem 0;border-bottom:1px dotted rgba(0,0,0,.07);line-height:1.4;color:#2C2C2A}
  .comp-item:last-child{border-bottom:none}
  .comp-item.oui::before{content:'✅ ';font-size:.72rem}
  .comp-item.non::before{content:'❌ ';font-size:.72rem}
  .comp-item.warn::before{content:'⚠️ ';font-size:.72rem}

  /* NÉGOCIATION */
  .nego{display:flex;flex-direction:column;gap:.55rem;margin:1.4rem 0}
  .nego-item{display:flex;gap:.75rem;align-items:flex-start;padding:.7rem 1rem;border-radius:10px;background:#fff;border:1px solid rgba(0,0,0,.07)}
  .nego-ico{font-size:1rem;flex-shrink:0;margin-top:.1rem}
  .nego-text{font-size:.83rem;font-weight:300;color:#2C2C2A;line-height:1.5}
  .nego-text strong{font-weight:500;color:#300860;display:block;margin-bottom:.1rem}

  /* SIMULATION */
  .simul{background:linear-gradient(135deg,#0C0018,#300860);border-radius:13px;padding:1.3rem 1.5rem;margin:1.5rem 0;color:#fff}
  .simul h3{font-family:'Playfair Display',serif;font-size:1rem;font-weight:700;color:#F0C080;margin-bottom:.9rem}
  .simul-row{display:flex;justify-content:space-between;padding:.38rem 0;border-bottom:1px solid rgba(255,255,255,.07);font-size:.84rem}
  .simul-row:last-child{border-bottom:none;padding-top:.5rem;margin-top:.2rem}
  .simul-lab{font-weight:300;color:rgba(255,255,255,.8)}
  .simul-val{font-weight:600;color:#F0C080;white-space:nowrap}
  .simul-lab.total{font-weight:600;color:#fff}
  .simul-val.total{font-size:1rem}

  .encadre{border-left:4px solid #6020B0;background:#F5F0FF;border-radius:0 10px 10px 0;padding:1rem 1.2rem;margin:1.5rem 0}
  .encadre strong{display:block;color:#300860;font-size:.9rem;margin-bottom:.3rem}
  .encadre p{font-size:.84rem;font-weight:300;color:#4A1090;margin:0;line-height:1.6}

  .conseil{background:linear-gradient(135deg,#0C0018,#300860);border-radius:13px;padding:1.3rem 1.5rem;margin:2rem 0;color:#fff;border:1px solid rgba(240,192,128,.12)}
  .conseil strong{display:block;color:#F0C080;font-weight:500;font-size:.93rem;margin-bottom:.4rem}
  .conseil p{font-size:.88rem;color:rgba(255,255,255,.8);font-weight:300;margin:0;line-height:1.65}

  footer{background:#085041;color:rgba(255,255,255,.6);text-align:center;padding:1.6rem;font-size:.8rem}
  footer strong{color:#fff}
  footer a{color:#EF9F27;text-decoration:none}
  @media(max-width:500px){.compare{grid-template-columns:1fr}.timeline::before{left:18px}.indem-row{grid-template-columns:1fr}}

