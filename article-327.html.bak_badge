.ah{background:linear-gradient(135deg,#022c22,#065f46,#0d9488);color:white;padding:3rem 2rem 2.5rem;position:relative;overflow:hidden}
.ah::before{content:'🌿';position:absolute;font-size:16rem;right:-1rem;top:-2rem;opacity:.07;pointer-events:none;line-height:1}
.hi{max-width:760px;margin:0 auto;position:relative;z-index:1}
.cat-pill{display:inline-flex;align-items:center;gap:.4rem;background:rgba(255,255,255,.12);border:1px solid rgba(255,255,255,.2);color:#99f6e4;font-size:.72rem;font-weight:600;text-transform:uppercase;letter-spacing:.08em;padding:.28rem .9rem;border-radius:50px;margin-bottom:.9rem}
.ah h1{font-family:'Playfair Display',serif;font-size:clamp(1.8rem,4vw,2.8rem);font-weight:900;line-height:1.15;margin-bottom:.9rem}
.ah h1 em{color:#5eead4;font-style:normal}
.savings-badge{display:inline-flex;align-items:center;gap:.5rem;background:linear-gradient(135deg,#f59e0b,#0d9488);color:white;font-size:.88rem;font-weight:700;padding:.45rem 1.2rem;border-radius:50px;margin-bottom:1.3rem;box-shadow:0 4px 14px rgba(13,148,136,.35)}
.meta-row{display:flex;flex-wrap:wrap;gap:.6rem}
.meta-item{display:inline-flex;align-items:center;gap:.3rem;background:rgba(255,255,255,.1);border:1px solid rgba(255,255,255,.15);padding:.22rem .7rem;border-radius:50px;color:rgba(255,255,255,.8);font-size:.74rem}
.theme-tag{background:linear-gradient(135deg,#0d9488,#65a30d);color:white;font-weight:600;padding:.22rem .8rem;border-radius:50px;font-size:.72rem}
.ab{max-width:760px;margin:0 auto;padding:2.5rem 2rem 4rem}
.lead{font-size:1.05rem;color:var(--m);font-weight:300;border-left:4px solid var(--teal);padding-left:1.2rem;margin-bottom:2rem;line-height:1.8}
h2{font-family:'Playfair Display',serif;font-size:1.35rem;font-weight:700;margin:2.2rem 0 1rem;display:flex;align-items:center;gap:.5rem}
p{margin-bottom:1rem;font-size:.95rem}

/* MYTHES vs RÉALITÉ */
.mythes{display:flex;flex-direction:column;gap:.9rem;margin:1.5rem 0}
.mythe{background:var(--w);border:1px solid var(--b);border-radius:var(--r);overflow:hidden}
.mythe-q{background:#fef2f2;padding:.75rem 1.2rem;font-weight:600;font-size:.9rem;color:#dc2626;display:flex;align-items:center;gap:.5rem}
.mythe-r{background:var(--teal-l);padding:.75rem 1.2rem;font-size:.87rem;color:#134e4a;font-weight:300;line-height:1.55}
.mythe-r strong{color:var(--teal);font-weight:700}

/* PRINCIPES */
.principes{display:grid;grid-template-columns:repeat(auto-fit,minmax(190px,1fr));gap:1rem;margin:1.5rem 0}
.principe{background:var(--w);border:1px solid var(--b);border-radius:var(--r);padding:1.2rem;text-align:center;transition:transform .2s}
.principe:hover{transform:translateY(-2px)}
.principe-icon{font-size:2rem;margin-bottom:.5rem}
.principe-name{font-weight:700;font-size:.9rem;margin-bottom:.3rem}
.principe-desc{font-size:.78rem;color:var(--m);font-weight:300;line-height:1.4}
.principe-eco{display:inline-block;margin-top:.4rem;background:var(--gl);color:var(--gd);font-size:.7rem;font-weight:600;padding:.1rem .5rem;border-radius:50px}

/* ENCADRÉS */
.tip{background:var(--gl);border-left:4px solid var(--g);border-radius:var(--r);padding:1.1rem 1.4rem;margin:1.5rem 0;font-size:.9rem;color:var(--gd)}
.tip strong{display:block;font-weight:600;margin-bottom:.25rem}
.warn{background:var(--teal-l);border-left:4px solid var(--teal);border-radius:var(--r);padding:1.1rem 1.4rem;margin:1.5rem 0;font-size:.9rem;color:#134e4a}
.warn strong{display:block;font-weight:600;margin-bottom:.25rem}

.cta{background:linear-gradient(135deg,#022c22,#065f46);border-radius:var(--r);padding:1.8rem;text-align:center;margin-top:2.5rem;color:white}
.cta h3{font-family:'Playfair Display',serif;font-size:1.2rem;margin-bottom:.4rem}
.cta p{color:rgba(255,255,255,.7);font-size:.86rem;margin-bottom:1rem}
.cta-form{display:flex;gap:.5rem;max-width:360px;margin:0 auto;flex-wrap:wrap;justify-content:center}
.cta-form input{flex:1;min-width:150px;padding:.65rem 1rem;border-radius:50px;border:none;font-size:.86rem;font-family:inherit}
.cta-form button{background:linear-gradient(135deg,#0d9488,#65a30d);color:white;border:none;padding:.65rem 1.3rem;border-radius:50px;font-weight:600;cursor:pointer;font-family:inherit;font-size:.86rem}
footer{background:var(--gd);color:rgba(255,255,255,.6);text-align:center;padding:1.5rem;font-size:.8rem}
footer strong{color:white}
@media(max-width:640px){.ah{padding:2rem 1.2rem}.ab{padding:1.8rem 1.1rem 3rem}.ah::before{font-size:8rem}}

/* Menu hamburger mobile */
.hamburger{display:none;flex-direction:column;gap:5px;cursor:pointer;background:none;border:none;padding:.3rem}
.hamburger span{display:block;width:24px;height:2px;background:var(--gd,#085041);border-radius:2px;transition:all .3s}
