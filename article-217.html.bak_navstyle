  .hero-cat strong{color:#fff}
  .hero h1{font-family:'Playfair Display',serif;font-size:clamp(1.8rem,4.5vw,2.7rem);font-weight:900;color:#fff;line-height:1.1;max-width:640px;margin:.3rem auto .9rem}
  .hero-badge{display:inline-block;background:linear-gradient(90deg,#F5C060,#E85030);color:#1A0008;font-size:.82rem;font-weight:700;padding:.35rem 1.1rem;border-radius:50px}
  .hero-meta{display:flex;justify-content:center;flex-wrap:wrap;gap:.55rem;margin-top:1.2rem}
  .hero-meta span{font-size:.73rem;color:rgba(255,255,255,.5);background:rgba(255,255,255,.09);padding:.2rem .75rem;border-radius:50px}

  article{max-width:700px;margin:0 auto;padding:2.5rem 1.5rem 5rem}
  article p{margin-bottom:1.3rem;font-size:.97rem;font-weight:300;line-height:1.75}
  h2{font-family:'Playfair Display',serif;font-size:1.2rem;font-weight:700;color:#6B001A;margin:2.2rem 0 .8rem}

  /* IMPACT CHIFFRÉ */
  .impact{display:grid;grid-template-columns:repeat(3,1fr);gap:.75rem;margin:1.5rem 0}
  .impact-card{background:#fff;border:1px solid rgba(0,0,0,.08);border-radius:12px;padding:1.1rem .9rem;text-align:center}
  .impact-val{font-family:'Playfair Display',serif;font-size:1.8rem;font-weight:900;color:#C01840;line-height:1}
  .impact-label{font-size:.73rem;font-weight:300;color:#5F5E5A;margin-top:.3rem;line-height:1.35}

  /* SCRIPTS DE NÉGOCIATION */
  .scripts{display:flex;flex-direction:column;gap:.9rem;margin:1.5rem 0}
  .script{border-radius:13px;overflow:hidden;border:1px solid rgba(0,0,0,.08)}
  .script-head{display:flex;align-items:center;gap:.7rem;padding:.75rem 1.1rem}
  .script-head.embauche{background:linear-gradient(90deg,#1A0008,#6B001A)}
  .script-head.augmentation{background:linear-gradient(90deg,#0A2A0A,#1A6B1A)}
  .script-head.objection{background:linear-gradient(90deg,#1A1A00,#6B6B00)}
  .script-ico{font-size:1.3rem}
  .script-titre{font-weight:600;font-size:.9rem;color:#fff;flex:1}
  .script-context{font-size:.72rem;color:rgba(255,255,255,.6);white-space:nowrap}
  .script-body{background:#fff;padding:.9rem 1.1rem}
  .script-situation{font-size:.75rem;font-weight:600;text-transform:uppercase;letter-spacing:.06em;color:#5F5E5A;margin-bottom:.5rem}
  .script-dialogue{display:flex;flex-direction:column;gap:.5rem}
  .dialogue-rh{display:flex;gap:.7rem;align-items:flex-start}
  .dialogue-vous{display:flex;gap:.7rem;align-items:flex-start;flex-direction:row-reverse}
  .bulle{border-radius:12px;padding:.55rem .9rem;font-size:.83rem;font-weight:300;line-height:1.5;max-width:85%}
  .bulle-rh{background:#F3F4F6;color:#2C2C2A}
  .bulle-vous{background:linear-gradient(135deg,#6B001A,#C01840);color:#fff;font-weight:400}
  .dialogue-ico{font-size:1rem;flex-shrink:0;margin-top:.2rem}
  .script-tip{margin-top:.6rem;font-size:.76rem;background:#FFF5F5;border-left:3px solid #C01840;padding:.4rem .8rem;border-radius:0 6px 6px 0;color:#6B001A;font-style:italic}

  /* TIMING PARFAIT */
  .timing{display:grid;grid-template-columns:1fr 1fr;gap:.7rem;margin:1.5rem 0}
  .timing-card{background:#fff;border:1px solid rgba(0,0,0,.08);border-radius:11px;padding:.85rem .9rem}
  .timing-ico{font-size:1.3rem;margin-bottom:.3rem}
  .timing-titre{font-weight:500;font-size:.86rem;margin-bottom:.2rem}
  .timing-titre.bon{color:#065F46}
  .timing-titre.mauvais{color:#9B1D1D}
  .timing-desc{font-size:.79rem;font-weight:300;color:#5F5E5A;line-height:1.45}

  /* ALTERNATIVES AU SALAIRE */
  .alternatives{display:flex;flex-direction:column;gap:.5rem;margin:1.4rem 0}
  .alt{display:flex;gap:.75rem;align-items:flex-start;padding:.65rem 1rem;border-radius:10px;background:#fff;border:1px solid rgba(0,0,0,.07)}
  .alt-ico{font-size:1rem;flex-shrink:0;margin-top:.1rem}
  .alt-text{font-size:.83rem;font-weight:300;color:#2C2C2A;line-height:1.5}
  .alt-text strong{font-weight:500;color:#6B001A;display:block;margin-bottom:.1rem}
  .alt-gain{font-size:.72rem;font-weight:600;color:#065F46;margin-top:.1rem}

  .conseil{background:linear-gradient(135deg,#1A0008,#6B001A);border-radius:13px;padding:1.3rem 1.5rem;margin:2rem 0;color:#fff;border:1px solid rgba(245,192,96,.12)}
  .conseil strong{display:block;color:#F5C060;font-weight:500;font-size:.93rem;margin-bottom:.4rem}
  .conseil p{font-size:.88rem;color:rgba(255,255,255,.8);font-weight:300;margin:0;line-height:1.65}

  footer{background:#085041;color:rgba(255,255,255,.6);text-align:center;padding:1.6rem;font-size:.8rem}
  footer strong{color:#fff}
  footer a{color:#EF9F27;text-decoration:none}
  @media(max-width:500px){.impact{grid-template-columns:1fr 1fr}.timing{grid-template-columns:1fr}}

