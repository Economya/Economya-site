  /* HERO — sable chaud → terracotta → rose pêche */
  .hero{background:linear-gradient(135deg,#1A0A00 0%,#5C2800 30%,#C05010 62%,#E8803A 84%,#F5C9A8 100%);padding:3.8rem 2rem 3.2rem;text-align:center;position:relative;overflow:hidden}
  .hero::before{content:'🖼️';position:absolute;font-size:14rem;opacity:.05;top:50%;left:50%;transform:translate(jusqu'à -50%,jusqu'à -50%);pointer-events:none}
  .hero-cat{font-size:.82rem;font-weight:500;color:rgba(255,255,255,.6);margin-bottom:.6rem;letter-spacing:.05em}
  .hero-cat strong{color:#fff}
  .hero h1{font-family:'Playfair Display',serif;font-size:clamp(1.8rem,4.5vw,2.7rem);font-weight:900;color:#fff;line-height:1.1;max-width:640px;margin:.3rem auto .9rem}
  .hero-badge{display:inline-block;background:linear-gradient(90deg,#F5C9A8,#E8803A);color:#1A0A00;font-size:.82rem;font-weight:700;padding:.35rem 1.1rem;border-radius:50px}
  .hero-meta{display:flex;justify-content:center;flex-wrap:wrap;gap:.55rem;margin-top:1.2rem}
  .hero-meta span{font-size:.73rem;color:rgba(255,255,255,.5);background:rgba(255,255,255,.09);padding:.2rem .75rem;border-radius:50px}

  article{max-width:700px;margin:0 auto;padding:2.5rem 1.5rem 5rem}
  article p{margin-bottom:1.3rem;font-size:.97rem;font-weight:300;line-height:1.75}
  h2{font-family:'Playfair Display',serif;font-size:1.2rem;font-weight:700;color:#5C2800;margin:2.2rem 0 .8rem}

  /* STAT IMPACT VISUEL */
  .stats{display:grid;grid-template-columns:repeat(3,1fr);gap:.8rem;margin:1.5rem 0}
  .stat{background:#fff;border:1px solid rgba(0,0,0,.08);border-radius:12px;padding:1.1rem .9rem;text-align:center}
  .stat-val{font-family:'Playfair Display',serif;font-size:1.9rem;font-weight:900;color:#C05010;line-height:1}
  .stat-label{font-size:.74rem;font-weight:300;color:#5F5E5A;margin-top:.3rem;line-height:1.35}

  /* AVANT / APRÈS PAR PIÈCE */
  .pieces{display:flex;flex-direction:column;gap:.8rem;margin:1.5rem 0}
  .piece{border-radius:12px;overflow:hidden;border:1px solid rgba(0,0,0,.08)}
  .piece-head{display:flex;align-items:center;gap:.7rem;padding:.75rem 1.1rem;background:linear-gradient(90deg,#5C2800,#C05010);color:#fff}
  .piece-ico{font-size:1.3rem}
