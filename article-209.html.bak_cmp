  .encadre{border-left:4px solid #E8803A;background:#FFF5EE;border-radius:0 10px 10px 0;padding:1rem 1.2rem;margin:1.5rem 0}
  .encadre strong{display:block;color:#5C2800;font-size:.9rem;margin-bottom:.3rem}
  .encadre p{font-size:.84rem;font-weight:300;color:#7C3A10;margin:0;line-height:1.6}

  .conseil{background:linear-gradient(135deg,#1A0A00,#5C2800);border-radius:13px;padding:1.3rem 1.5rem;margin:2rem 0;color:#fff;border:1px solid rgba(245,201,168,.12)}
  .conseil strong{display:block;color:#F5C9A8;font-weight:500;font-size:.93rem;margin-bottom:.4rem}
  .conseil p{font-size:.88rem;color:rgba(255,255,255,.8);font-weight:300;margin:0;line-height:1.65}

  footer{background:#085041;color:rgba(255,255,255,.6);text-align:center;padding:1.6rem;font-size:.8rem}
  footer strong{color:#fff}
  footer a{color:#EF9F27;text-decoration:none}
  @media(max-width:500px){.stats{grid-template-columns:1fr 1fr}.piece-body{grid-template-columns:1fr}.piece-col:first-child{border-right:none;border-bottom:1px solid rgba(0,0,0,.06)}.photos{grid-template-columns:1fr}}

