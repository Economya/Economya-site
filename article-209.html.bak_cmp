  .piece-col:first-child{border-right:1px solid rgba(0,0,0,.06);background:#FFF8F5}
  .piece-label{font-size:.68rem;font-weight:600;text-transform:uppercase;letter-spacing:.07em;margin-bottom:.5rem}
  .piece-col:first-child .piece-label{color:#9B1D1D}
  .piece-col:last-child .piece-label{color:#085041}
  .piece-item{font-size:.81rem;font-weight:300;color:#2C2C2A;padding:.2rem 0;line-height:1.4;border-bottom:1px dotted rgba(0,0,0,.07)}
  .piece-item:last-child{border-bottom:none}
  .piece-item.avant::before{content:'✗ ';color:#C05010;font-weight:700}
  .piece-item.apres::before{content:'✓ ';color:#085041;font-weight:700}

  /* BUDGET GLOBAL */
  .budget{background:linear-gradient(135deg,#1A0A00,#5C2800);border-radius:13px;padding:1.3rem 1.5rem;margin:1.5rem 0;color:#fff}
  .budget h3{font-family:'Playfair Display',serif;font-size:1rem;font-weight:700;color:#F5C9A8;margin-bottom:.9rem}
  .budget-row{display:flex;justify-content:space-between;padding:.38rem 0;border-bottom:1px solid rgba(255,255,255,.08);font-size:.84rem}
  .budget-row:last-child{border-bottom:none;padding-top:.55rem;margin-top:.2rem}
  .budget-label{font-weight:300;color:rgba(255,255,255,.8)}
  .budget-val{font-weight:600;color:#F5C9A8;white-space:nowrap}
  .budget-label.total{font-weight:600;color:#fff}
