  /* CHECKLIST PHOTOS */
  .photos{display:grid;grid-template-columns:1fr 1fr;gap:.6rem;margin:1.5rem 0}
  .photo-item{background:#fff;border:1px solid rgba(0,0,0,.08);border-radius:10px;padding:.75rem .9rem;display:flex;gap:.6rem;align-items:flex-start}
  .photo-ico{font-size:1.1rem;flex-shrink:0}
  .photo-text{font-size:.81rem;font-weight:300;color:#2C2C2A;line-height:1.45}
