        <tr><td>Analyser ses contrats</td><td>ChatGPT</td><td class="g">Variable</td></tr>
        <tr><td>Changer de fournisseur énergie</td><td>Hello Watt</td><td class="g">150–400 €/an</td></tr>
        <tr><td>Trouver des aides</td><td>Perplexity AI</td><td class="g">Centaines d'€</td></tr>
