  .hero-badge{display:inline-block;background:linear-gradient(90deg,#90C8F8,#4888E8);color:#080C1C;font-size:.82rem;font-weight:700;padding:.35rem 1.1rem;border-radius:50px}
  .hero-meta{display:flex;justify-content:center;flex-wrap:wrap;gap:.55rem;margin-top:1.2rem}
  .hero-meta span{font-size:.73rem;color:rgba(255,255,255,.5);background:rgba(255,255,255,.09);padding:.2rem .75rem;border-radius:50px}

  article{max-width:700px;margin:0 auto;padding:2.5rem 1.5rem 5rem}
  article p{margin-bottom:1.3rem;font-size:.97rem;font-weight:300;line-height:1.75}
  h2{font-family:'Playfair Display',serif;font-size:1.2rem;font-weight:700;color:#182060;margin:2.2rem 0 .8rem}

  /* COMPARATIF PEE VS PERCO */
  .compare{display:grid;grid-template-columns:1fr 1fr;gap:.9rem;margin:1.5rem 0}
  .comp{border-radius:13px;overflow:hidden;border:1px solid rgba(0,0,0,.08)}
  .comp-head{padding:.75rem 1rem;color:#fff;font-weight:700;font-size:.9rem}
  .comp-head.pee{background:linear-gradient(135deg,#182060,#2840C8)}
  .comp-head.perco{background:linear-gradient(135deg,#3A0860,#8820C8)}
  .comp-body{background:#fff;padding:.85rem 1rem}
  .comp-row{display:flex;justify-content:space-between;gap:.5rem;padding:.3rem 0;border-bottom:1px dotted rgba(0,0,0,.07);font-size:.82rem}
  .comp-row:last-child{border-bottom:none}
  .comp-label{font-weight:300;color:#5F5E5A}
  .comp-val{font-weight:500;color:#2C2C2A;text-align:right;font-size:.8rem}

  /* SUPPORTS D'INVESTISSEMENT */
  .supports{display:grid;grid-template-columns:repeat(3,1fr);gap:.65rem;margin:1.5rem 0}
  .support{background:#fff;border:1px solid rgba(0,0,0,.08);border-radius:11px;padding:.85rem .8rem;text-align:center}
  .support-ico{font-size:1.5rem;margin-bottom:.35rem}
  .support-nom{font-weight:500;font-size:.83rem;color:#182060;margin-bottom:.2rem}
  .support-risque{display:inline-block;font-size:.68rem;font-weight:600;padding:.1rem .45rem;border-radius:50px;margin-bottom:.3rem}
  .support-risque.faible{background:#ECFDF5;color:#065F46}
  .support-risque.moyen{background:#FEF3C7;color:#713F12}
  .support-risque.eleve{background:#FEE2E2;color:#7F1D1D}
  .support-desc{font-size:.74rem;font-weight:300;color:#5F5E5A;line-height:1.4}

  /* STRATÉGIE PAR ÂGE */
  .strategies{display:flex;flex-direction:column;gap:.6rem;margin:1.5rem 0}
  .strat{background:#fff;border:1px solid rgba(0,0,0,.08);border-radius:11px;display:grid;grid-template-columns:90px 1fr;overflow:hidden}
  .strat-age{background:linear-gradient(135deg,#182060,#2840C8);color:#90C8F8;display:flex;align-items:center;justify-content:center;font-family:'Playfair Display',serif;font-weight:900;font-size:1.1rem;padding:.8rem;text-align:center;line-height:1.2}
  .strat-body{padding:.75rem 1rem}
  .strat-titre{font-weight:500;font-size:.87rem;color:#182060;margin-bottom:.2rem}
  .strat-desc{font-size:.8rem;font-weight:300;color:#5F5E5A;line-height:1.5}

  /* SIMULATION */
  .simul{background:linear-gradient(135deg,#080C1C,#182060);border-radius:13px;padding:1.3rem 1.5rem;margin:1.5rem 0;color:#fff}
  .simul h3{font-family:'Playfair Display',serif;font-size:1rem;font-weight:700;color:#90C8F8;margin-bottom:.9rem}
  .simul-row{display:flex;justify-content:space-between;padding:.4rem 0;border-bottom:1px solid rgba(255,255,255,.07);font-size:.84rem}
  .simul-row:last-child{border-bottom:none;padding-top:.55rem;margin-top:.2rem}
  .simul-lab{font-weight:300;color:rgba(255,255,255,.8)}
  .simul-val{font-weight:600;color:#90C8F8;white-space:nowrap}
  .simul-lab.total{font-weight:600;color:#fff}
  .simul-val.total{font-size:1rem}
  .simul-val.green{color:#6EE7B7}

  /* ERREURS À ÉVITER */
  .erreurs{display:flex;flex-direction:column;gap:.5rem;margin:1.4rem 0}
  .erreur{display:flex;gap:.75rem;align-items:flex-start;padding:.7rem 1rem;border-radius:10px;background:#fff;border:1px solid rgba(0,0,0,.07)}
  .erreur-ico{font-size:1rem;flex-shrink:0;margin-top:.1rem}
  .erreur-text{font-size:.83rem;font-weight:300;color:#2C2C2A;line-height:1.5}
  .erreur-text strong{font-weight:500;color:#7B1D1D;display:block;margin-bottom:.1rem}

  .encadre{border-left:4px solid #2840C8;background:#EEF4FF;border-radius:0 10px 10px 0;padding:1rem 1.2rem;margin:1.5rem 0}
  .encadre strong{display:block;color:#182060;font-size:.9rem;margin-bottom:.3rem}
  .encadre p{font-size:.84rem;font-weight:300;color:#2840C8;margin:0;line-height:1.6}

  .conseil{background:linear-gradient(135deg,#080C1C,#182060);border-radius:13px;padding:1.3rem 1.5rem;margin:2rem 0;color:#fff;border:1px solid rgba(144,200,248,.1)}
  .conseil strong{display:block;color:#90C8F8;font-weight:500;font-size:.93rem;margin-bottom:.4rem}
  .conseil p{font-size:.88rem;color:rgba(255,255,255,.8);font-weight:300;margin:0;line-height:1.65}

  footer{background:#085041;color:rgba(255,255,255,.6);text-align:center;padding:1.6rem;font-size:.8rem}
  footer strong{color:#fff}
  footer a{color:#EF9F27;text-decoration:none}
