<title>Loisirs créatifs pas chers — Economya.fr</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;700;900&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet">
<style>
  *,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
  : root{
    --g:#1D9E75;--gl:#E1F5EE;--gd:#085041;--a:#EF9F27;--al:#FAEEDA;--ad:#633806;
    --t:#2C2C2A;--m:#5F5E5A;--bg:#FAFAF8;--w:#fff;--b:rgba(0,0,0,0.1);
    --magenta:#9B1D6A;--magenta-mid:#C2185B;--magenta-light:#FCE4EC;
    --violet:#5C2D91;--sun:#FFD600;--cyan:#00E5FF;
  }
  body{font-family:'DM Sans',sans-serif;background:var(--bg);color:var(--t);line-height:1.7}
  nav{display:flex;justify-content:space-between;align-items:center;padding:.9rem 1.8rem;background:var(--w);border-bottom:1px solid var(--b);position:sticky;top:0;z-index:99}
  .logo{font-family:'Playfair Display',serif;font-weight:900;font-size:1.3rem;color:var(--gd);text-decoration:none}
  .logo span{color:var(--a)}
  .back{font-size:.82rem;color:var(--m);text-decoration:none}
  .back:hover{color:var(--g)}

  .hero-art{
    background:linear-gradient(135deg,#1A0010 0%,#5C2D91 35%,#9B1D6A 65%,#FFD600 100%);
    padding:3.5rem 2rem 3rem;text-align:center;position:relative;overflow:hidden
  }
  .hero-art::before{
    content:'🎨';position:absolute;font-size:13rem;opacity:.06;
    top:50%;left:50%;transform:translate(jusqu'à -50%,jusqu'à -50%);pointer-events:none
  }
  .acat{font-size:.85rem;font-weight:500;color:rgba(255,255,255,.6);margin-bottom:.6rem;letter-spacing:.04em}
  .acat strong{color:#fff}
  .hero-art h1{
    font-family:'Playfair Display',serif;font-size:clamp(1.7rem,4vw,2.6rem);
    font-weight:900;line-height:1.1;color:#fff;max-width:620px;margin:0 auto .9rem
  }
  .abadge{
    display:inline-block;
    background:linear-gradient(90deg,var(--sun),var(--cyan));
    color:#1A0010;font-size:.82rem;font-weight:700;padding:.35rem 1rem;
    border-radius:50px;margin-top:.4rem
  }
  .meta{display:flex;justify-content:center;flex-wrap:wrap;gap:.6rem;margin-top:1.2rem}
  .meta span{font-size:.74rem;color:rgba(255,255,255,.55);background:rgba(255,255,255,.1);padding:.2rem .75rem;border-radius:50px}

  article{max-width:680px;margin:0 auto;padding:2.5rem 1.5rem 4rem}
  article p{margin-bottom:1.3rem;font-size:.97rem;font-weight:300}
  article h2{font-family:'Playfair Display',serif;font-size:1.2rem;font-weight:700;color:var(--violet);margin:2rem 0 .7rem}

  /* Activités créatives */
  .activites{display:grid;grid-template-columns:1fr 1fr;gap:.8rem;margin:1.5rem 0}
  .activite{border-radius:12px;overflow:hidden;border:1px solid rgba(155,29,106,.15)}
  .activite-head{padding:.65rem .9rem;display:flex;justify-content:space-between;align-items:center;color:#fff}
  .activite-head.a1{background:linear-gradient(90deg,#5C2D91,#9B1D6A)}
  .activite-head.a2{background:linear-gradient(90deg,#1A3D18,#2D6A4F)}
  .activite-head.a3{background:linear-gradient(90deg,#1A2E3B,#1565C0)}
  .activite-head.a4{background:linear-gradient(90deg,#5D3000,#C67C3A)}
  .activite-head.a5{background:linear-gradient(90deg,#1B0035,#6A1E9E)}
  .activite-head.a6{background:linear-gradient(90deg,#1A0A00,#8B4513)}
  .activite-emoji{font-size:1.2rem}
  .activite-nom{font-weight:600;font-size:.85rem;flex:1;padding:0 .5rem}
  .activite-budget{font-size:.73rem;font-weight:700;background:rgba(255,255,255,.2);padding:.1rem .45rem;border-radius:50px;white-space:nowrap}
  .activite-body{background:var(--w);padding:.75rem .9rem;font-size:.81rem;font-weight:300;color:var(--m);line-height:1.5}
  .activite-tip{margin-top:.4rem;font-size:.77rem;color:var(--magenta);font-weight:500}

  /* Où s'approvisionner */
  .sources{display:flex;flex-direction:column;gap:.6rem;margin:1.5rem 0}
  .source{background:var(--w);border:1px solid var(--b);border-radius:10px;display:grid;grid-template-columns:40px 1fr;align-items:center;gap:.7rem;padding:.65rem .9rem}
  .source-icon{font-size:1.3rem;text-align:center}
  .source-body{}
  .source-nom{font-weight:500;font-size:.87rem;color:var(--violet);margin-bottom:.1rem}
  .source-desc{font-size:.79rem;font-weight:300;color:var(--m);line-height:1.4}

  /* Cours gratuits */
  .cours{display:grid;grid-template-columns:repeat(3,1fr);gap:.6rem;margin:1.5rem 0}
  .cours-item{background:linear-gradient(135deg,#F3E5F5,#FCE4EC);border:1px solid rgba(155,29,106,.12);border-radius:10px;padding:.8rem .9rem;text-align:center}
  .cours-icon{font-size:1.3rem;margin-bottom:.3rem}
  .cours-nom{font-weight:500;font-size:.82rem;color:var(--magenta);margin-bottom:.2rem}
  .cours-desc{font-size:.74rem;font-weight:300;color:var(--m);line-height:1.35}

  .conseil{
    background:linear-gradient(135deg,#1A0010,#5C2D91);
    border-radius:12px;padding:1.2rem 1.4rem;margin:1.8rem 0;color:#fff
  }
  .conseil strong{display:block;color:var(--sun);font-weight:500;font-size:.92rem;margin-bottom:.4rem}
  .conseil p{font-size:.88rem;color:rgba(255,255,255,.82);font-weight:300;margin:0;line-height:1.65}

  footer{background:var(--gd);color:rgba(255,255,255,0.6);text-align:center;padding:1.6rem;font-size:.8rem}
  footer strong{color:white}
  footer a{color:var(--a);text-decoration:none}
  @media(max-width:500px){.activites{grid-template-columns:1fr}.cours{grid-template-columns:1fr 1fr}}

/* Menu hamburger mobile */
.hamburger{display:none;flex-direction:column;gap:5px;cursor:pointer;background:none;border:none;padding:.3rem}
.hamburger span{display:block;width:24px;height:2px;background:var(--gd,#085041);border-radius:2px;transition:all .3s}
.mobile-menu{display:none;position:fixed;top:0;left:0;right:0;bottom:0;background:rgba(255,255,255,.98);z-index:999;flex-direction:column;align-items:center;justify-content:center;gap:1.5rem}
.mobile-menu.open{display:flex}
.mobile-menu a{font-family:'Playfair Display',serif;font-size:1.3rem;font-weight:700;color:#085041;text-decoration:none}
.mobile-menu .close-btn{position:absolute;top:1.2rem;right:1.5rem;background:none;border:none;font-size:1.8rem;cursor:pointer;color:#085041}
.mobile-menu .nav-cta{background:#1D9E75;color:white!important;padding:.5rem 1.4rem;border-radius:50px}
@media(max-width:768px){
  .hamburger{display:flex}
  nav .nav-links,nav > a:not(.logo),nav > div:not(.mobile-menu){display:none!important}
  nav li{display:none!important}
}
