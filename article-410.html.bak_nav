(function(){
  var url = encodeURIComponent(window.location.href);
  var titre = encodeURIComponent(document.title);
  document.querySelectorAll('a[href*="https://economya.fr/article-410.html"]').forEach(function(a){
    a.href = a.href.replace(/https://economya.fr/article-410.html/g, url).replace(/N%C3%A9obanques%202026%20%3A%20le%20comparatif%20complet/g, titre);
  });
})();
</script>

