.btn-next{background:linear-gradient(135deg,var(--gd),var(--g));color:white;border:none;padding:.8rem 2rem;border-radius:50px;font-weight:600;cursor:pointer;font-family:inherit;font-size:.95rem;margin-top:1rem;width:100%}

/* Carte ADN */
.adn-card{background:linear-gradient(135deg,#0a0a0a,#1a1a2e);border-radius:var(--r);padding:2rem;color:white;margin-bottom:1.5rem;position:relative;overflow:hidden}
.adn-card::before{content:'';position:absolute;top:0;left:0;right:0;height:4px;background:linear-gradient(90deg,var(--g),var(--a))}
.adn-header{display:flex;align-items:center;gap:1rem;margin-bottom:1.5rem}
.adn-emoji{font-size:3rem}
.adn-nom{font-family:'Playfair Display',serif;font-size:1.5rem;font-weight:900}
.adn-sous{font-size:.8rem;color:rgba(255,255,255,.6)}
.adn-code{font-family:monospace;font-size:.75rem;color:var(--g);margin-top:.2rem;letter-spacing:.1em}
.adn-genes{display:grid;grid-template-columns:repeat(auto-fit,minmax(140px,1fr));gap:.8rem;margin-bottom:1.5rem}
.gene{background:rgba(255,255,255,.07);border-radius:12px;padding:.8rem;text-align:center}
.gene-label{font-size:.65rem;color:rgba(255,255,255,.5);text-transform:uppercase;letter-spacing:.06em;margin-bottom:.3rem}
.gene-value{font-family:'Playfair Display',serif;font-size:1.1rem;font-weight:700;color:var(--a)}
.gene-bar{height:4px;background:rgba(255,255,255,.1);border-radius:50px;margin-top:.4rem;overflow:hidden}
.gene-bar-fill{height:100%;border-radius:50px;background:linear-gradient(90deg,var(--g),var(--a))}
.adn-desc{font-size:.88rem;color:rgba(255,255,255,.75);line-height:1.7;margin-bottom:1.5rem}
.adn-forces{display:grid;grid-template-columns:1fr 1fr;gap:1rem;margin-bottom:1.5rem}
.force-block{background:rgba(255,255,255,.05);border-radius:12px;padding:1rem}
.force-titre{font-size:.72rem;font-weight:700;text-transform:uppercase;letter-spacing:.06em;margin-bottom:.5rem}
.force-titre.vert{color:var(--g)}
.force-titre.rouge{color:#f87171}
.force-item{font-size:.8rem;color:rgba(255,255,255,.7);padding:.2rem 0;padding-left:1rem;position:relative}
.force-item::before{position:absolute;left:0}
.vert .force-item::before{content:'✅'}
.rouge .force-item::before{content:'⚠️'}
.adn-conseil{background:rgba(239,159,39,.1);border:1px solid rgba(239,159,39,.3);border-radius:12px;padding:1rem;font-size:.85rem;color:rgba(255,255,255,.8);line-height:1.6}
.share-box{background:var(--w);border-radius:var(--r);border:1px solid var(--b);padding:1.5rem;text-align:center;margin-bottom:1.5rem}
.share-box h3{font-family:'Playfair Display',serif;font-size:1rem;font-weight:700;color:var(--gd);margin-bottom:.8rem}
.share-text-box{background:var(--bg);border-radius:8px;padding:.8rem;font-size:.82rem;color:var(--m);font-style:italic;margin-bottom:.8rem;line-height:1.5}
.btn-retry{background:transparent;border:2px solid var(--g);color:var(--gd);padding:.7rem 1.8rem;border-radius:50px;font-weight:600;cursor:pointer;font-family:inherit;font-size:.9rem;width:100%;margin-bottom:1rem}
.cta{background:linear-gradient(135deg,var(--al),#FFF8EE);border-radius:var(--r);padding:1.8rem;text-align:center}
.cta h3{font-family:'Playfair Display',serif;font-size:1.1rem;color:#633806;margin-bottom:.4rem}
.cta p{font-size:.86rem;color:var(--m);margin-bottom:1rem}
.cta-form{display:flex;gap:.5rem;max-width:360px;margin:0 auto;flex-wrap:wrap;justify-content:center}
.cta-form input[type=email]{flex:1;min-width:150px;padding:.65rem 1rem;border-radius:50px;border:1px solid var(--b);font-size:.86rem;font-family:inherit}
.cta-form button{background:var(--a);color:white;border:none;padding:.65rem 1.3rem;border-radius:50px;font-weight:600;cursor:pointer;font-family:inherit;font-size:.86rem}
footer{background:var(--gd);color:rgba(255,255,255,.6);text-align:center;padding:1.5rem;font-size:.8rem;margin-top:2rem}
footer strong{color:white}
@media(max-width:640px){.hero{padding:2rem 1.2rem}.container{padding:1.5rem 1rem}.adn-forces{grid-template-columns:1fr}}

/* Menu hamburger mobile */
.hamburger{display:none;flex-direction:column;gap:5px;cursor:pointer;background:none;border:none;padding:.3rem}
.hamburger span{display:block;width:24px;height:2px;background:var(--gd,#085041);border-radius:2px;transition:all .3s}
.mobile-menu{display:none;position:fixed;top:0;left:0;right:0;bottom:0;background:rgba(255,255,255,.98);z-index:999;flex-direction:column;align-items:center;justify-content:center;gap:1.5rem}
.mobile-menu.open{display:flex}
.mobile-menu a{font-family:'Playfair Display',serif;font-size:1.3rem;font-weight:700;color:#085041;text-decoration:none}
.mobile-menu .close-btn{position:absolute;top:1.2rem;right:1.5rem;background:none;border:none;font-size:1.8rem;cursor:pointer;color:#085041}
.mobile-menu .nav-cta{background:#1D9E75;color:white!important;padding:.5rem 1.4rem;border-radius:50px}
@media(max-width:768px){
  .hamburger{display:flex}
  nav .nav-links, nav > a:not(.logo), nav > div{display:none!important}
  nav li{display:none!important}
}
