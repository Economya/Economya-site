<script>
const QUESTIONS = [
  {
    text: "Quand vous recevez de l'argent inattendu (prime, cadeau...) que faites-vous ?",
    left: "Je le dépense immédiatement 🛍️",
    right: "Je l'épargne tout de suite 🏦",
    gene: "Épargne",
    low: "Dépensier spontané",
    high: "Épargnant discipliné"
  },
  {
    text: "Comment vous sentez-vous face aux investissements risqués ?",
    left: "J'évite tout risque 😰",
    right: "J'aime prendre des risques 🚀",
    gene: "Risque",
    low: "Ultra-prudent",
    high: "Aventurier financier"
  },
  {
    text: "À quelle fréquence regardez-vous vos comptes bancaires ?",
    left: "Jamais, j'évite 🙈",
    right: "Chaque jour ✅",
    gene: "Contrôle",
    low: "Tête dans le sable",
    high: "Pilote expert"
  },
  {
    text: "Quelle est votre vision de l'argent ?",
    left: "L'argent c'est pour vivre maintenant 🎉",
    right: "L'argent c'est pour la liberté future 🔮",
    gene: "Vision",
    low: "Carpe diem",
    high: "Stratège long terme"
  },
  {
    text: "Face à une grosse dépense imprévue de 1 000 € ?",
    left: "Je suis complètement déstabilisé 😱",
    right: "J'ai prévu pour ça 🛡️",
    gene: "Résilience",
    low: "Fragile",
    high: "Blindé"
  }
];

const PROFILS = [
  {
    min: 0, max: 25,
    emoji: '🌊', nom: 'Le Surfeur de Vague',
    code: 'ADN-SURF-001',
    desc: 'Vous vivez dans le présent, au gré des opportunités. L\'argent entre et sort naturellement. Vous êtes généreux, spontané et profitez de la vie. Votre défi : construire une base solide sans perdre votre joie de vivre.',
    forces: ['Généreux et spontané', 'Profite de la vie', 'Sans stress au quotidien'],
    faiblesses: ['Peu d\'épargne constituée', 'Vulnérable aux imprévus', 'Pas de vision long terme'],
    conseil: '💡 Conseil ADN : Mettez en place un virement automatique de 50€/mois dès le 1er. Vous ne le remarquerez pas mais dans 10 ans vous aurez 6 000€ + intérêts.'
  },
  {
    min: 26, max: 45,
    emoji: '⚖️', nom: 'L\'Équilibriste',
    code: 'ADN-EQUI-002',
    desc: 'Vous naviguez entre plaisir et prudence. Vous épargnez un peu, dépensez un peu, vivez bien. Vous êtes pragmatique et réaliste. Votre force : vous n\'êtes ni dans l\'excès ni dans la privation.',
    forces: ['Équilibré et pragmatique', 'Ni trop rigide ni trop laxiste', 'Gestion saine au quotidien'],
    faiblesses: ['Pourrait épargner davantage', 'Manque parfois de vision', 'Objectifs flous'],
    conseil: '💡 Conseil ADN : Vous êtes bien positionné. Donnez-vous 1 objectif financier précis pour cette année et construisez autour de lui.'
  },
  {
    min: 46, max: 65,
    emoji: '🦅', nom: 'L\'Architecte Financier',
    code: 'ADN-ARCH-003',
    desc: 'Vous construisez méthodiquement votre avenir financier. Vous avez une vision, un plan et vous le suivez. Vous prenez des risques calculés et savez où vous allez. Votre défi : ne pas oublier de profiter du chemin.',
    forces: ['Vision long terme claire', 'Discipliné et méthodique', 'Bon gestionnaire du risque'],
    faiblesses: ['Peut être trop rigide', 'Risque de passer à côté du présent', 'Perfectionisme parfois bloquant'],
    conseil: '💡 Conseil ADN : Votre architecture est solide. Accordez-vous une enveloppe "plaisirs" mensuelle sans culpabilité — c\'est aussi un investissement dans votre bien-être.'
  },
  {
    min: 66, max: 85,
    emoji: '🏆', nom: 'Le Stratège Élite',
    code: 'ADN-STRA-004',
    desc: 'Vous avez une maîtrise avancée de vos finances. Vous optimisez, planifiez et construisez un patrimoine solide. Vous êtes dans le top 15% des Français pour la gestion financière.',
    forces: ['Maîtrise financière avancée', 'Patrimoine en construction', 'Résilient face aux imprévus'],
    faiblesses: ['Peut négliger les petits plaisirs', 'Risque d\'over-optimisation', 'Stress si objectifs non atteints'],
    conseil: '💡 Conseil ADN : Votre niveau est excellent. La prochaine étape : diversifiez vos investissements (ETF, immobilier, PER) pour créer plusieurs sources de revenus.'
  },
  {
    min: 86, max: 100,
    emoji: '🌟', nom: 'Le Maître de l\'Argent',
    code: 'ADN-MAST-005',
    desc: 'Vous êtes dans le top 5% des Français pour la gestion financière. Vous avez une discipline de fer, une vision claire et une résilience exceptionnelle. L\'argent est votre outil, pas votre maître.',
    forces: ['Discipline financière exceptionnelle', 'Vision et stratégie claires', 'Patrimoine optimisé'],
    faiblesses: ['Peut être perçu comme trop rigide', 'Difficulté à déléguer', 'Exigence parfois excessive'],
    conseil: '💡 Conseil ADN : Vous avez atteint un niveau rare. Pensez maintenant à transmettre — à vos proches, vos enfants, ou via du mentorat financier.'
  }
];

let currentQ = 0;
let reponses = [];

function updateSlider() {
  const val = +document.getElementById('slider').value;
  const q = QUESTIONS[currentQ];
  let label;
  if(val < 20) label = q.low;
  else if(val > 80) label = q.high;
  else if(val < 40) label = 'Plutôt ' + q.low.toLowerCase();
  else if(val > 60) label = 'Plutôt ' + q.high.toLowerCase();
  else label = 'Équilibré';
  document.getElementById('slider-val').textContent = label;
}

function showQuestion() {
  const q = QUESTIONS[currentQ];
  const pct = (currentQ / QUESTIONS.length) * 100;
  document.getElementById('progress').style.width = pct + '%';
  document.getElementById('progress-text').textContent = `Question ${currentQ + 1} sur ${QUESTIONS.length}`;
  document.getElementById('q-num').textContent = `Question ${currentQ + 1} sur ${QUESTIONS.length}`;
  document.getElementById('q-text').textContent = q.text;
  document.getElementById('label-left').textContent = q.left;
  document.getElementById('label-right').textContent = q.right;
  document.getElementById('slider').value = 50;
  updateSlider();
}

function nextQuestion() {
  reponses.push(+document.getElementById('slider').value);
  currentQ++;
  if(currentQ < QUESTIONS.length) {
    showQuestion();
  } else {
    showResult();
  }
}

function showResult() {
  document.getElementById('progress').style.width = '100%';
  document.getElementById('progress-text').textContent = 'Votre ADN révélé !';

  const score = Math.round(reponses.reduce((a,b) => a+b, 0) / reponses.length);
  const profil = PROFILS.find(p => score >= p.min && score <= p.max);

  document.getElementById('adn-emoji').textContent = profil.emoji;
  document.getElementById('adn-nom').textContent = profil.nom;
  document.getElementById('adn-code').textContent = profil.code;
  document.getElementById('adn-desc').textContent = profil.desc;
  document.getElementById('adn-conseil').textContent = profil.conseil;

  // Gènes
  const genesEl = document.getElementById('adn-genes');
  genesEl.innerHTML = '';
  QUESTIONS.forEach((q, i) => {
    const val = reponses[i];
    genesEl.innerHTML += `
      <div class="gene">
        <div class="gene-label">${q.gene}</div>
        <div class="gene-value">${val}%</div>
        <div class="gene-bar"><div class="gene-bar-fill" style="width:${val}%"></div></div>
      </div>
    `;
  });

  // Forces
  const forcesList = document.getElementById('forces-list');
  forcesList.innerHTML = '';
  profil.forces.forEach(f => {
    forcesList.innerHTML += `<div class="force-item">${f}</div>`;
  });

  const faiblessesList = document.getElementById('faiblesses-list');
  faiblessesList.innerHTML = '';
  profil.faiblesses.forEach(f => {
    faiblessesList.innerHTML += `<div class="force-item">${f}</div>`;
  });

  // Share
  document.getElementById('share-text').textContent = `Mon ADN Financier vient d'être révélé 🧬 Je suis "${profil.nom}" (${profil.code}) — Score global : ${score}/100. Et vous ? Testez sur economya.fr`;

  document.getElementById('screen-questions').classList.remove('active');
  document.getElementById('screen-result').classList.add('active');
  window.scrollTo({top:0, behavior:'smooth'});
}

function retry() {
  currentQ = 0;
  reponses = [];
  document.getElementById('screen-result').classList.remove('active');
  document.getElementById('screen-questions').classList.add('active');
  showQuestion();
  window.scrollTo({top:0, behavior:'smooth'});
}

showQuestion();
</script>
