  var titre = encodeURIComponent(document.title);
  document.querySelectorAll('a[href*="https://economya.fr/article-312.html"]').forEach(function(a){
    a.href = a.href.replace(/https://economya.fr/article-312.html/g, url).replace(/V%C3%AAtements%20enfants%20pas%20chers%20%3A%20meilleures%20sources/g, titre);
  });
})();
</script>

