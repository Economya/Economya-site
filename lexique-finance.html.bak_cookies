<!DOCTYPE html>
<html lang="fr">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Lexique Finance — Tous les termes expliqués simplement — Economya.fr</title>
<meta name="description" content="Plus de 100 termes financiers expliqués simplement. APL, PEA, ETF, SCPI, TMI... Comprenez enfin le vocabulaire de la finance. Gratuit sur Economya.fr">
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;700;900&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet">
<style>
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
:root{--g:#1D9E75;--gl:#E1F5EE;--gd:#085041;--a:#EF9F27;--al:#FAEEDA;--r:16px;--t:#2C2C2A;--m:#5F5E5A;--bg:#FAFAF8;--w:#fff;--b:rgba(0,0,0,0.08)}
body{font-family:'DM Sans',sans-serif;background:var(--bg);color:var(--t);min-height:100vh}
nav{display:flex;justify-content:space-between;align-items:center;padding:.9rem 1.8rem;background:var(--w);border-bottom:1px solid var(--b);position:sticky;top:0;z-index:99}
.logo{font-family:'Playfair Display',serif;font-weight:900;font-size:1.3rem;color:var(--gd);text-decoration:none}
.logo span{color:var(--a)}
.nav-back{text-decoration:none;color:var(--m);font-size:.82rem;font-weight:500}
.hero{background:linear-gradient(135deg,#1e293b,#334155,#475569);color:white;padding:3rem 2rem 2.5rem;text-align:center;position:relative;overflow:hidden}
.hero::before{content:'📖';position:absolute;font-size:16rem;right:-1rem;top:-2rem;opacity:.07;pointer-events:none}
.hero h1{font-family:'Playfair Display',serif;font-size:clamp(1.8rem,4vw,2.8rem);font-weight:900;margin-bottom:.6rem}
.hero h1 em{color:#EF9F27;font-style:normal}
.hero p{font-size:.95rem;color:rgba(255,255,255,.75);max-width:500px;margin:0 auto}
.container{max-width:900px;margin:0 auto;padding:2.5rem 1.5rem}
.search-wrap{background:var(--w);border-radius:50px;border:2px solid var(--g);padding:.6rem 1.2rem;display:flex;align-items:center;gap:.8rem;margin-bottom:2rem;box-shadow:0 4px 20px rgba(29,158,117,.1)}
.search-wrap input{border:none;background:transparent;font-size:1rem;font-family:inherit;width:100%;outline:none;color:var(--t)}
.search-wrap span{font-size:1.2rem;flex-shrink:0}
.alpha-nav{display:flex;flex-wrap:wrap;gap:.4rem;margin-bottom:2rem}
.alpha-btn{background:var(--w);border:1px solid var(--b);border-radius:8px;padding:.3rem .6rem;font-size:.82rem;font-weight:600;cursor:pointer;color:var(--m);font-family:inherit;transition:all .2s}
.alpha-btn:hover,.alpha-btn.active{background:var(--gd);color:white;border-color:var(--gd)}
.letter-section{margin-bottom:2.5rem}
.letter-title{font-family:'Playfair Display',serif;font-size:2rem;font-weight:900;color:var(--gd);margin-bottom:1rem;padding-bottom:.5rem;border-bottom:3px solid var(--g)}
.terms-grid{display:flex;flex-direction:column;gap:.8rem}
.term-card{background:var(--w);border-radius:var(--r);border:1px solid var(--b);padding:1.2rem 1.5rem;box-shadow:0 2px 8px rgba(0,0,0,.03);transition:box-shadow .2s}
.term-card:hover{box-shadow:0 4px 16px rgba(29,158,117,.1)}
.term-card.hidden{display:none}
.term-header{display:flex;align-items:center;gap:.8rem;margin-bottom:.4rem}
.term-name{font-family:'Playfair Display',serif;font-size:1.05rem;font-weight:700;color:var(--gd)}
.term-badge{background:var(--gl);color:var(--gd);font-size:.65rem;font-weight:700;padding:.15rem .6rem;border-radius:50px;text-transform:uppercase}
.term-def{font-size:.88rem;color:var(--t);line-height:1.7}
.term-exemple{font-size:.82rem;color:var(--m);font-style:italic;margin-top:.3rem;padding-left:.8rem;border-left:3px solid var(--gl)}
.no-results{text-align:center;padding:3rem;color:var(--m);display:none}
.cta{background:linear-gradient(135deg,var(--al),#FFF8EE);border-radius:var(--r);padding:1.8rem;text-align:center;margin-top:2rem}
.cta h3{font-family:'Playfair Display',serif;font-size:1.1rem;color:#633806;margin-bottom:.4rem}
.cta p{font-size:.86rem;color:var(--m);margin-bottom:1rem}
.cta-form{display:flex;gap:.5rem;max-width:360px;margin:0 auto;flex-wrap:wrap;justify-content:center}
.cta-form input[type=email]{flex:1;min-width:150px;padding:.65rem 1rem;border-radius:50px;border:1px solid var(--b);font-size:.86rem;font-family:inherit}
.cta-form button{background:var(--a);color:white;border:none;padding:.65rem 1.3rem;border-radius:50px;font-weight:600;cursor:pointer;font-family:inherit;font-size:.86rem}
footer{background:var(--gd);color:rgba(255,255,255,.6);text-align:center;padding:1.5rem;font-size:.8rem;margin-top:2rem}
footer strong{color:white}
@media(max-width:640px){.hero{padding:2rem 1.2rem}.container{padding:1.5rem 1rem}}

/* Menu hamburger mobile */
.hamburger{display:none;flex-direction:column;gap:5px;cursor:pointer;background:none;border:none;padding:.3rem}
.hamburger span{display:block;width:24px;height:2px;background:var(--gd,#085041);border-radius:2px;transition:all .3s}
.mobile-menu{display:none;position:fixed;top:0;left:0;right:0;bottom:0;background:rgba(255,255,255,.98);z-index:999;flex-direction:column;align-items:center;justify-content:center;gap:1.5rem}
.mobile-menu.open{display:flex}
.mobile-menu a{font-family:'Playfair Display',serif;font-size:1.3rem;font-weight:700;color:#085041;text-decoration:none}
.mobile-menu .close-btn{position:absolute;top:1.2rem;right:1.5rem;background:none;border:none;font-size:1.8rem;cursor:pointer;color:#085041}
.mobile-menu .nav-cta{background:#1D9E75;color:white!important;padding:.5rem 1.4rem;border-radius:50px}
@media(max-width:768px){
  .hamburger{display:flex}
  nav .nav-links, nav > a:not(.logo), nav > div{display:none!important}
  nav li{display:none!important}
}
</style>

