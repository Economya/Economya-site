<script>
const TERMES = [
  // A
  { lettre:'A', nom:'APL', badge:'Logement', def:'Aide Personnalisée au Logement. Aide versée par la CAF pour réduire le montant de votre loyer. Son montant dépend de vos revenus, de votre loyer et de votre situation familiale.', exemple:'Ex : avec 700 €/mois de loyer et 18 000 €/an de revenus, vous pouvez toucher 150-250 €/mois d\'APL.' },
  { lettre:'A', nom:'Abattement fiscal', badge:'Fiscalité', def:'Réduction appliquée sur votre revenu imposable avant de calculer votre impôt. Le plus connu est l\'abattement forfaitaire de 10% sur les salaires.', exemple:'Ex : si vous gagnez 30 000 €, l\'abattement de 10% ramène votre revenu imposable à 27 000 €.' },
  { lettre:'A', nom:'Assurance-vie', badge:'Épargne', def:'Placement financier très populaire en France. Malgré son nom, c\'est avant tout un outil d\'épargne avec une fiscalité avantageuse après 8 ans. Vous pouvez investir en fonds euros (sécurisé) ou en unités de compte (plus risqué, plus rentable).', exemple:'Ex : un contrat en fonds euros rapporte 2,5-3,5%/an avec capital garanti.' },
  { lettre:'A', nom:'AGIRC-ARRCO', badge:'Retraite', def:'Régime de retraite complémentaire obligatoire pour les salariés du secteur privé. Les cotisations prélevées sur votre salaire alimentent des "points" qui seront convertis en pension à la retraite.', exemple:'' },
  // B
  { lettre:'B', nom:'Barème progressif', badge:'Fiscalité', def:'Système de calcul de l\'impôt où le taux augmente par tranches de revenus. En France : 0%, 11%, 30%, 41%, 45%. Seule la partie du revenu dans chaque tranche est taxée au taux correspondant.', exemple:'Ex : sur 35 000 € de revenu imposable, vous payez 0% jusqu\'à 11 497 €, puis 11% sur la tranche suivante, etc.' },
  { lettre:'B', nom:'Bitcoin / Cryptomonnaie', badge:'Investissement', def:'Monnaie numérique décentralisée non contrôlée par une banque centrale. Très volatile et spéculatif. À n\'investir qu\'une part très limitée de son épargne (5% maximum selon les experts).', exemple:'' },
  { lettre:'B', nom:'Budget', badge:'Gestion', def:'Plan prévisionnel de vos revenus et dépenses sur une période donnée (mois, année). Outil fondamental pour maîtriser ses finances et atteindre ses objectifs.', exemple:'Ex : la règle 50/30/20 répartit le budget en 50% besoins, 30% envies, 20% épargne.' },
  // C
  { lettre:'C', nom:'CAF', badge:'Aides', def:'Caisse d\'Allocations Familiales. Organisme qui verse les aides sociales : APL, allocations familiales, RSA, prime d\'activité. Gérez vos droits sur caf.fr.', exemple:'' },
  { lettre:'C', nom:'Capital', badge:'Finance', def:'Somme d\'argent initiale placée ou investie. Par opposition aux intérêts ou revenus générés par ce capital.', exemple:'Ex : si vous placez 10 000 € (capital) à 3%, vous recevez 300 € d\'intérêts par an.' },
  { lettre:'C', nom:'CEL', badge:'Épargne', def:'Compte Épargne Logement. Livret réglementé à 1% permettant d\'obtenir un prêt immobilier à taux préférentiel. Plafond : 15 300 €. Souvent associé au PEL.', exemple:'' },
  { lettre:'C', nom:'Cotisations sociales', badge:'Emploi', def:'Prélèvements obligatoires sur le salaire brut qui financent la protection sociale (retraite, santé, chômage). Représentent environ 22% du salaire brut pour le salarié.', exemple:'Ex : sur un salaire brut de 2 500 €, les cotisations salariales représentent ~550 €.' },
  { lettre:'C', nom:'CPF', badge:'Formation', def:'Compte Personnel de Formation. Chaque salarié accumule des droits en euros chaque année pour financer des formations. Consultez votre solde sur moncompteformation.gouv.fr.', exemple:'Ex : un salarié à temps plein accumule 500 €/an de droits CPF (plafond 5 000 €).' },
  { lettre:'C', nom:'Crédit à la consommation', badge:'Crédit', def:'Prêt bancaire pour financer des achats non immobiliers (voiture, électroménager, vacances). Taux généralement plus élevés que le crédit immobilier. À utiliser avec prudence.', exemple:'Ex : un crédit conso à 5 000 € sur 36 mois à 6% TAEG coûte ~465 € d\'intérêts.' },
  // D
  { lettre:'D', nom:'Décote fiscale', badge:'Fiscalité', def:'Réduction d\'impôt accordée aux foyers dont l\'impôt est faible. Elle diminue progressivement à mesure que l\'impôt calculé augmente. Elle permet à de nombreux foyers modestes de ne payer aucun impôt.', exemple:'' },
  { lettre:'D', nom:'Défiscalisation', badge:'Fiscalité', def:'Ensemble des moyens légaux pour réduire son impôt sur le revenu : PER, investissement immobilier (Pinel), dons aux associations, emploi à domicile, etc.', exemple:'Ex : un versement de 3 000 € sur un PER réduit directement votre revenu imposable de 3 000 €.' },
  { lettre:'D', nom:'Dividende', badge:'Investissement', def:'Part des bénéfices d\'une entreprise distribuée à ses actionnaires. Revenu passif pour l\'investisseur. Fiscalisé en France à 30% (flat tax).', exemple:'Ex : si vous possédez 100 actions à 2 €/an de dividende, vous recevez 200 €/an.' },
  // E
  { lettre:'E', nom:'Épargne de précaution', badge:'Épargne', def:'Réserve d\'argent liquide disponible immédiatement pour faire face aux imprévus (panne, chômage, urgence). Recommandation : 3 à 6 mois de dépenses fixes, placée sur un Livret A.', exemple:'Ex : si vos dépenses fixes sont de 1 500 €/mois, visez 4 500-9 000 € de précaution.' },
  { lettre:'E', nom:'ETF', badge:'Investissement', def:'Exchange Traded Fund (fonds indiciel coté). Produit financier qui réplique la performance d\'un indice boursier (ex: CAC 40, S&P 500). Frais très bas (~0,2%/an), diversification automatique. Idéal pour les particuliers.', exemple:'Ex : un ETF World investi dans 1 600 entreprises mondiales pour 0,2%/an de frais.' },
  { lettre:'E', nom:'Euribor', badge:'Crédit', def:'Taux de référence interbancaire européen. Sert de base pour calculer les taux des crédits immobiliers à taux variable. Fluctue selon la politique de la BCE.', exemple:'' },
  // F
  { lettre:'F', nom:'Flat Tax', badge:'Fiscalité', def:'Prélèvement Forfaitaire Unique (PFU) de 30% sur les revenus du capital (dividendes, intérêts, plus-values). Simplifie la fiscalité des placements financiers en France depuis 2018.', exemple:'Ex : 1 000 € de plus-value sur actions = 300 € d\'impôt avec la flat tax.' },
  { lettre:'F', nom:'Fonds euros', badge:'Épargne', def:'Support d\'investissement sécurisé dans une assurance-vie. Capital garanti, rendement faible (2-3%/an). Composé majoritairement d\'obligations d\'État. Idéal pour l\'épargne prudente.', exemple:'' },
  { lettre:'F', nom:'Frais de notaire', badge:'Immobilier', def:'Frais payés lors d\'un achat immobilier. Comprennent les droits de mutation (taxes), les émoluments du notaire et les débours. Représentent 7-8% du prix dans l\'ancien, 2-3% dans le neuf.', exemple:'Ex : pour un bien à 200 000 € dans l\'ancien : environ 15 000 € de frais de notaire.' },
  // G
  { lettre:'G', nom:'Garantie décès-invalidité', badge:'Crédit', def:'Assurance obligatoire lors d\'un crédit immobilier. Rembourse le capital restant dû en cas de décès ou d\'invalidité de l\'emprunteur. Son coût peut représenter 0,2-0,5% du capital emprunté par an.', exemple:'' },
  // I
  { lettre:'I', nom:'Impôt sur le revenu', badge:'Fiscalité', def:'Impôt calculé sur les revenus annuels du foyer fiscal selon un barème progressif. Prélevé à la source depuis 2019 directement sur le salaire.', exemple:'Ex : un célibataire gagnant 30 000 €/an paie environ 2 400 € d\'impôt.' },
  { lettre:'I', nom:'Inflation', badge:'Économie', def:'Hausse générale et durable des prix. L\'inflation érode le pouvoir d\'achat : 1 000 € aujourd\'hui achèteront moins dans 10 ans. Pour protéger son épargne, il faut placer à un taux supérieur à l\'inflation.', exemple:'Ex : avec 3% d\'inflation, 1 000 € perdent ~26% de leur valeur en 10 ans.' },
  { lettre:'I', nom:'Intérêts composés', badge:'Épargne', def:'Mécanisme où les intérêts générés produisent eux-mêmes des intérêts. L\'effet boule de neige le plus puissant en finance. Einstein l\'aurait appelé "la 8ème merveille du monde".', exemple:'Ex : 10 000 € à 5%/an = 16 289 € après 10 ans, 43 219 € après 30 ans.' },
  // L
  { lettre:'L', nom:'LDDS', badge:'Épargne', def:'Livret de Développement Durable et Solidaire. Taux 1,5% (2026), plafond 12 000 €, exonéré d\'impôts. Fonctionne comme le Livret A. Financement de projets écologiques et solidaires.', exemple:'' },
  { lettre:'L', nom:'LEP', badge:'Épargne', def:'Livret d\'Épargne Populaire. Meilleur taux des livrets réglementés : 2,5% (2026). Réservé aux foyers modestes (sous conditions de revenus). Plafond 10 000 €. À ouvrir en priorité si vous êtes éligible.', exemple:'Ex : 10 000 € sur LEP = 250 €/an d\'intérêts nets d\'impôts.' },
  { lettre:'L', nom:'Livret A', badge:'Épargne', def:'Le livret d\'épargne le plus connu en France. Taux 1,5% (2026), plafond 22 950 €, disponible à tout moment, exonéré d\'impôts. Idéal pour l\'épargne de précaution.', exemple:'Ex : 10 000 € sur Livret A = 150 €/an d\'intérêts sans impôt.' },
  { lettre:'L', nom:'Loyer', badge:'Immobilier', def:'Somme versée mensuellement par le locataire au propriétaire en échange de la jouissance d\'un logement. Ne doit pas dépasser 33% des revenus nets selon les recommandations.', exemple:'' },
  // M
  { lettre:'M', nom:'Mensualité', badge:'Crédit', def:'Somme fixe payée chaque mois pour rembourser un crédit. Comprend une part de capital et une part d\'intérêts. En début de prêt, les intérêts sont prépondérants.', exemple:'Ex : pour 200 000 € empruntés sur 20 ans à 3,5% : mensualité de ~1 160 €.' },
  { lettre:'M', nom:'Mutuelle', badge:'Santé', def:'Assurance complémentaire santé qui rembourse les frais non pris en charge par la Sécurité sociale (ticket modérateur, dépassements d\'honoraires). Obligatoire en entreprise depuis 2016.', exemple:'' },
  // O
  { lettre:'O', nom:'Obligation', badge:'Investissement', def:'Titre de dette émis par une entreprise ou un État. En achetant une obligation, vous prêtez de l\'argent en échange d\'intérêts. Moins risqué que les actions, moins rentable aussi.', exemple:'' },
  // P
  { lettre:'P', nom:'PEA', badge:'Investissement', def:'Plan d\'Épargne en Actions. Enveloppe fiscale pour investir en Bourse. Après 5 ans, les gains sont exonérés d\'impôt (seuls les prélèvements sociaux restent dus). Plafond 150 000 €. L\'outil préféré des investisseurs particuliers.', exemple:'Ex : 10 000 € investis en ETF sur PEA pendant 20 ans à 7%/an = ~38 000 € sans impôt.' },
  { lettre:'P', nom:'PEL', badge:'Épargne', def:'Plan d\'Épargne Logement. Taux 2% (ouverture 2026), plafond 61 200 €. Bloqué 4 ans minimum. Permet d\'obtenir un prêt immobilier à taux préférentiel. Fiscalisé.', exemple:'' },
  { lettre:'P', nom:'PER', badge:'Retraite', def:'Plan d\'Épargne Retraite. Placement long terme permettant de déduire les versements de votre revenu imposable. Bloqué jusqu\'à la retraite (sauf cas exceptionnels). Idéal si vous êtes fortement imposé.', exemple:'Ex : 5 000 € versés sur PER avec TMI à 30% = 1 500 € d\'économie d\'impôt immédiate.' },
  { lettre:'P', nom:'Plus-value', badge:'Investissement', def:'Gain réalisé lors de la vente d\'un bien (immobilier, action) à un prix supérieur à son prix d\'achat. Imposable en France (flat tax 30% pour les valeurs mobilières).', exemple:'Ex : achat d\'une action à 50 €, revendue à 80 € = plus-value de 30 €.' },
  { lettre:'P', nom:'Pouvoir d\'achat', badge:'Économie', def:'Quantité de biens et services que vous pouvez acheter avec vos revenus. Diminue avec l\'inflation. Augmente avec une hausse de salaire supérieure à l\'inflation.', exemple:'' },
  { lettre:'P', nom:'Prélèvement à la source', badge:'Fiscalité', def:'Système de collecte de l\'impôt sur le revenu directement sur le salaire chaque mois, sans attendre la déclaration annuelle. En vigueur en France depuis 2019.', exemple:'Ex : un taux de 8% signifie que 8% de votre salaire net est prélevé chaque mois.' },
  { lettre:'P', nom:'Prime d\'activité', badge:'Aides', def:'Aide versée par la CAF aux travailleurs à revenus modestes (salariés, indépendants). Montant moyen : 176 €/mois. Des millions de Français y ont droit sans le savoir. Demande sur caf.fr.', exemple:'Ex : un salarié célibataire gagnant 1 400 €/mois peut toucher ~150 €/mois.' },
  // R
  { lettre:'R', nom:'Rendement', badge:'Investissement', def:'Rapport entre les gains générés par un placement et le capital investi, exprimé en pourcentage annuel. Plus le rendement est élevé, plus le risque est généralement important.', exemple:'Ex : 200 € de gains sur 4 000 € investis = rendement de 5%.' },
  { lettre:'R', nom:'RSA', badge:'Aides', def:'Revenu de Solidarité Active. Aide versée aux personnes sans ressources ou à très faibles revenus. Montant de base : ~635 €/mois pour une personne seule. Demande sur caf.fr.', exemple:'' },
  // S
  { lettre:'S', nom:'SCPI', badge:'Investissement', def:'Société Civile de Placement Immobilier. Permet d\'investir dans l\'immobilier locatif à partir de quelques centaines d\'euros. Vous recevez des loyers proportionnels à votre investissement sans gérer de biens directement.', exemple:'Ex : 10 000 € en SCPI = ~450-550 €/an de revenus locatifs en moyenne.' },
  // T
  { lettre:'T', nom:'TAEG', badge:'Crédit', def:'Taux Annuel Effectif Global. Le vrai coût d\'un crédit incluant tout : taux d\'intérêt, frais de dossier, assurance. C\'est cet indicateur qu\'il faut comparer entre plusieurs offres.', exemple:'Ex : un taux nominal de 3,5% peut devenir un TAEG de 4,2% avec les assurances.' },
  { lettre:'T', nom:'TMI', badge:'Fiscalité', def:'Taux Marginal d\'Imposition. Le taux d\'imposition de votre dernière tranche de revenus. Votre TMI détermine l\'intérêt des placements défiscalisants (PER, dons...).', exemple:'Ex : avec un TMI de 30%, chaque euro versé sur un PER vous économise 0,30 € d\'impôt.' },
  { lettre:'T', nom:'Taux d\'endettement', badge:'Crédit', def:'Rapport entre vos charges de crédit et vos revenus. Les banques acceptent généralement un taux d\'endettement maximum de 35%. Au-delà, votre demande de crédit risque d\'être refusée.', exemple:'Ex : 700 €/mois de crédit pour 2 800 €/mois de revenus = 25% d\'endettement.' },
];

function renderLexique(termes) {
  const content = document.getElementById('lexique-content');
  const alphaNav = document.getElementById('alpha-nav');
  content.innerHTML = '';

  const lettres = [...new Set(termes.map(t => t.lettre))].sort();

  // Alpha nav
  alphaNav.innerHTML = '';
  'ABCDEFGHIJKLMNOPQRSTUVWXYZ'.split('').forEach(l => {
    const hasTerms = lettres.includes(l);
    const btn = document.createElement('button');
    btn.className = 'alpha-btn' + (hasTerms ? '' : '');
    btn.textContent = l;
    btn.style.opacity = hasTerms ? '1' : '0.3';
    btn.style.cursor = hasTerms ? 'pointer' : 'default';
    if(hasTerms) btn.onclick = () => {
      document.getElementById('section-' + l)?.scrollIntoView({behavior:'smooth', block:'start'});
    };
    alphaNav.appendChild(btn);
  });

  lettres.forEach(l => {
    const section = document.createElement('div');
    section.className = 'letter-section';
    section.id = 'section-' + l;
    section.innerHTML = `<div class="letter-title">${l}</div><div class="terms-grid" id="grid-${l}"></div>`;
    content.appendChild(section);

    const grid = section.querySelector('.terms-grid');
    termes.filter(t => t.lettre === l).forEach(t => {
      grid.innerHTML += `
        <div class="term-card">
          <div class="term-header">
            <span class="term-name">${t.nom}</span>
            ${t.badge ? `<span class="term-badge">${t.badge}</span>` : ''}
          </div>
          <div class="term-def">${t.def}</div>
          ${t.exemple ? `<div class="term-exemple">${t.exemple}</div>` : ''}
        </div>
      `;
    });
  });
}

function filterTerms() {
  const q = document.getElementById('search').value.toLowerCase().trim();
  const noResults = document.getElementById('no-results');

  if(!q) {
    renderLexique(TERMES);
    noResults.style.display = 'none';
    return;
  }

  const filtered = TERMES.filter(t =>
    t.nom.toLowerCase().includes(q) ||
    t.def.toLowerCase().includes(q) ||
    t.badge.toLowerCase().includes(q)
  );

  if(filtered.length === 0) {
    document.getElementById('lexique-content').innerHTML = '';
    noResults.style.display = 'block';
  } else {
    noResults.style.display = 'none';
    renderLexique(filtered);
  }
}

renderLexique(TERMES);
</script>
<script>function toggleMenu(){var m=document.getElementById("mobileMenu");m.classList.toggle("open");document.body.style.overflow=m.classList.contains("open")?"hidden":"";}</script></body>
</html>
