<style>
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
:root{--g:#1D9E75;--gl:#E1F5EE;--gd:#085041;--a:#EF9F27;--al:#FAEEDA;--ad:#633806;--violet:#7c3aed;--violet-l:#f5f3ff;--t:#2C2C2A;--m:#5F5E5A;--bg:#FAFAF8;--w:#fff;--b:rgba(0,0,0,0.08);--r:14px}
body{font-family:'DM Sans',sans-serif;background:var(--bg);color:var(--t);line-height:1.7}
nav{display:flex;justify-content:space-between;align-items:center;padding:.9rem 1.8rem;background:var(--w);border-bottom:1px solid var(--b);position:sticky;top:0;z-index:99}
.logo{font-family:'Playfair Display',serif;font-weight:900;font-size:1.3rem;color:var(--gd);text-decoration:none}
.logo span{color:var(--a)}
.nav-back{text-decoration:none;color:var(--m);font-size:.82rem;font-weight:500}
.nav-back:hover{color:var(--g)}
.ah{background:linear-gradient(135deg,#1e0533,#4c1d95,#7c3aed);color:white;padding:3rem 2rem 2.5rem;position:relative;overflow:hidden}
.ah::before{content:'🔗';position:absolute;font-size:16rem;right:-1rem;top:-2rem;opacity:.07;pointer-events:none;line-height:1}
.hi{max-width:760px;margin:0 auto;position:relative;z-index:1;text-align:center}
.cat-pill{display:inline-flex;align-items:center;gap:.4rem;background:rgba(255,255,255,.12);border:1px solid rgba(255,255,255,.2);color:#ddd6fe;font-size:.72rem;font-weight:600;text-transform:uppercase;letter-spacing:.08em;padding:.28rem .9rem;border-radius:50px;margin-bottom:.9rem}
.ah h1{font-family:'Playfair Display',serif;font-size:clamp(1.8rem,4vw,2.8rem);font-weight:900;line-height:1.15;margin-bottom:.9rem}
.ah h1 em{color:#c4b5fd;font-style:normal}
.savings-badge{display:inline-flex;align-items:center;gap:.5rem;background:linear-gradient(135deg,#16a34a,#7c3aed);color:white;font-size:.88rem;font-weight:700;padding:.45rem 1.2rem;border-radius:50px;margin-bottom:1.3rem;box-shadow:0 4px 14px rgba(124,58,237,.35)}
.meta-row{display:flex;flex-wrap:wrap;gap:.6rem;justify-content:center}
.meta-item{display:inline-flex;align-items:center;gap:.3rem;background:rgba(255,255,255,.1);border:1px solid rgba(255,255,255,.15);padding:.22rem .7rem;border-radius:50px;color:rgba(255,255,255,.8);font-size:.74rem}
.theme-tag{background:linear-gradient(135deg,#7c3aed,#16a34a);color:white;font-weight:600;padding:.22rem .8rem;border-radius:50px;font-size:.72rem}
.ab{max-width:760px;margin:0 auto;padding:2.5rem 2rem 4rem}
.lead{font-size:1.05rem;color:var(--m);font-weight:300;border-left:4px solid var(--violet);padding-left:1.2rem;margin-bottom:2rem;line-height:1.8}
h2{font-family:'Playfair Display',serif;font-size:1.35rem;font-weight:700;margin:2.2rem 0 1rem;display:flex;align-items:center;gap:.5rem}
p{margin-bottom:1rem;font-size:.95rem}

/* PROGRAMMES */
.programmes{display:flex;flex-direction:column;gap:1rem;margin:1.5rem 0}
.prog{background:var(--w);border:1px solid var(--b);border-radius:var(--r);padding:1.2rem 1.5rem;display:grid;grid-template-columns:auto 1fr auto;gap:1rem;align-items:start;transition:box-shadow .2s}
.prog:hover{box-shadow:0 4px 18px rgba(124,58,237,.1)}
.prog.top{border:2px solid var(--g)}
.top-badge{display:inline-block;background:var(--g);color:white;font-size:.65rem;font-weight:700;padding:.1rem .5rem;border-radius:50px;margin-bottom:.3rem}
.p-icon{font-size:1.8rem;flex-shrink:0;margin-top:.1rem}
.p-body h3{font-size:.92rem;font-weight:700;margin-bottom:.2rem}
.p-body p{font-size:.82rem;color:var(--m);font-weight:300;margin:0 0 .4rem}
.p-tags{display:flex;flex-wrap:wrap;gap:.3rem}
.ptag{font-size:.68rem;font-weight:600;padding:.1rem .45rem;border-radius:50px;background:var(--violet-l);color:#4c1d95}
.ptag.g{background:var(--gl);color:var(--gd)}
.p-right{text-align:right;flex-shrink:0}
.p-comm{font-family:'Playfair Display',serif;font-size:1rem;font-weight:700;color:var(--violet);display:block;white-space:nowrap}
.p-sub{font-size:.7rem;color:var(--m)}

/* ÉTAPES */
.steps{display:flex;flex-direction:column;gap:.85rem;margin:1.2rem 0}
.step{display:grid;grid-template-columns:38px 1fr;gap:.9rem;align-items:start;background:var(--w);border:1px solid var(--b);border-radius:var(--r);padding:1rem 1.2rem}
.sn{width:38px;height:38px;border-radius:50%;background:linear-gradient(135deg,#4c1d95,#7c3aed);color:white;font-family:'Playfair Display',serif;font-weight:700;font-size:1rem;display:flex;align-items:center;justify-content:center;flex-shrink:0}
.sc h3{font-size:.92rem;font-weight:600;margin-bottom:.2rem}
.sc p{font-size:.84rem;color:var(--m);font-weight:300;margin:0}
.sc .stag{display:inline-block;margin-top:.35rem;background:var(--violet-l);color:#4c1d95;font-size:.7rem;font-weight:600;padding:.12rem .55rem;border-radius:50px}

/* ENCADRÉS */
.tip{background:var(--gl);border-left:4px solid var(--g);border-radius:var(--r);padding:1.1rem 1.4rem;margin:1.5rem 0;font-size:.9rem;color:var(--gd)}
.tip strong{display:block;font-weight:600;margin-bottom:.25rem}
.warn{background:var(--violet-l);border-left:4px solid var(--violet);border-radius:var(--r);padding:1.1rem 1.4rem;margin:1.5rem 0;font-size:.9rem;color:#1e0533}
.warn strong{display:block;font-weight:600;margin-bottom:.25rem}

.cta{background:linear-gradient(135deg,#1e0533,#4c1d95);border-radius:var(--r);padding:1.8rem;text-align:center;margin-top:2.5rem;color:white}
.cta h3{font-family:'Playfair Display',serif;font-size:1.2rem;margin-bottom:.4rem}
.cta p{color:rgba(255,255,255,.7);font-size:.86rem;margin-bottom:1rem}
.cta-form{display:flex;gap:.5rem;max-width:360px;margin:0 auto;flex-wrap:wrap;justify-content:center}
.cta-form input{flex:1;min-width:150px;padding:.65rem 1rem;border-radius:50px;border:none;font-size:.86rem;font-family:inherit}
.cta-form button{background:linear-gradient(135deg,#7c3aed,#16a34a);color:white;border:none;padding:.65rem 1.3rem;border-radius:50px;font-weight:600;cursor:pointer;font-family:inherit;font-size:.86rem}
footer{background:var(--gd);color:rgba(255,255,255,.6);text-align:center;padding:1.5rem;font-size:.8rem}
footer strong{color:white}
@media(max-width:640px){.ah{padding:2rem 1.2rem}.ab{padding:1.8rem 1.1rem 3rem}.ah::before{font-size:8rem}.prog{grid-template-columns:1fr;gap:.5rem}.p-right{text-align:left}}

/* Menu hamburger mobile */
.hamburger{display:none;flex-direction:column;gap:5px;cursor:pointer;background:none;border:none;padding:.3rem}
.hamburger span{display:block;width:24px;height:2px;background:var(--gd,#085041);border-radius:2px;transition:all .3s}
.mobile-menu{display:none;position:fixed;top:0;left:0;right:0;bottom:0;background:rgba(255,255,255,.98);z-index:999;flex-direction:column;align-items:center;justify-content:center;gap:1.5rem}
.mobile-menu.open{display:flex}
.mobile-menu a{font-family:'Playfair Display',serif;font-size:1.3rem;font-weight:700;color:#085041;text-decoration:none}
.mobile-menu .close-btn{position:absolute;top:1.2rem;right:1.5rem;background:none;border:none;font-size:1.8rem;cursor:pointer;color:#085041}
.mobile-menu .nav-cta{background:#1D9E75;color:white!important;padding:.5rem 1.4rem;border-radius:50px}
@media(max-width:768px){
  .hamburger{display:flex}
  nav .nav-links,nav > a:not(.logo),nav > div:not(.mobile-menu){display:none!important}
  nav li{display:none!important}
}
