<!DOCTYPE html>
<html lang="fr">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Camping et plein air : vacances pas chères en France — Economya.fr</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;700;900&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet">
<style>
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
:root{--g:#1D9E75;--gl:#E1F5EE;--gd:#085041;--a:#EF9F27;--al:#FAEEDA;--ad:#633806;--t:#2C2C2A;--m:#5F5E5A;--bg:#FAFAF8;--w:#fff;--b:rgba(0,0,0,0.1)}
body{font-family:'DM Sans',sans-serif;background:var(--bg);color:var(--t);line-height:1.7;font-size:1rem}

nav{display:flex;justify-content:space-between;align-items:center;padding:.9rem 1.8rem;background:var(--w);border-bottom:1px solid var(--b);position:sticky;top:0;z-index:99}
.logo{font-family:'Playfair Display',serif;font-weight:900;font-size:1.4rem;color:var(--gd);text-decoration:none}
.logo span{color:var(--a)}
.back{font-size:.8rem;color:var(--m);text-decoration:none;display:flex;align-items:center;gap:.4rem}
.back:hover{color:var(--g)}

.article-hero{background:linear-gradient(135deg,#052e16,#166534 55%,#16a34a);color:white;padding:4rem 2rem 3rem;text-align:center}
.article-cat{display:inline-block;background:rgba(239,159,39,0.2);color:var(--a);border:1px solid rgba(239,159,39,0.4);padding:.3rem .9rem;border-radius:50px;font-size:.75rem;font-weight:500;text-transform:uppercase;margin-bottom:1.2rem}
.article-hero h1{font-family:'Playfair Display',serif;font-size:clamp(1.8rem,4vw,2.8rem);font-weight:900;line-height:1.2;max-width:680px;margin:0 auto 1rem}
.article-hero h1 em{color:var(--a);font-style:normal}
.article-meta{display:flex;justify-content:center;gap:1.5rem;flex-wrap:wrap;margin-top:1.5rem;font-size:.8rem;color:rgba(255,255,255,0.6)}
.savings-badge{display:inline-block;background:var(--a);color:white;padding:.5rem 1.2rem;border-radius:50px;font-weight:500;font-size:.9rem;margin-top:1.2rem}

.article-wrap{max-width:720px;margin:0 auto;padding:3rem 1.5rem 5rem}

.intro-box{background:var(--gl);border-left:4px solid var(--g);padding:1.2rem 1.5rem;border-radius:0 8px 8px 0;margin-bottom:2.5rem;font-size:.95rem;color:var(--gd);font-weight:500}

h2{font-family:'Playfair Display',serif;font-size:1.4rem;font-weight:700;margin:2.5rem 0 .8rem;color:var(--gd)}
p{margin-bottom:1rem;color:var(--m);font-weight:300}
p strong{color:var(--t);font-weight:500}

/* FORMULE CARDS */
.formule-grid{display:grid;gap:1.2rem;margin:1.5rem 0}
.formule-card{background:var(--w);border:1px solid var(--b);border-radius:14px;overflow:hidden;transition:box-shadow .2s}
.formule-card:hover{box-shadow:0 5px 22px rgba(0,0,0,0.08)}
.formule-header{padding:1rem 1.5rem;display:flex;justify-content:space-between;align-items:center;gap:1rem;border-bottom:1px solid var(--b);background:var(--bg)}
.formule-left{display:flex;align-items:center;gap:.9rem}
.formule-icon{font-size:1.7rem}
.formule-name{font-family:'Playfair Display',serif;font-size:1rem;font-weight:700;color:var(--gd)}
.formule-type{font-size:.73rem;color:var(--m);margin-top:.1rem}
.formule-prix{text-align:right;flex-shrink:0}
.prix-val{font-family:'Playfair Display',serif;font-size:1.2rem;font-weight:900;color:var(--g);line-height:1}
.prix-label{font-size:.63rem;color:var(--m)}
.formule-body{padding:.9rem 1.5rem 1.1rem}
.formule-body p{margin:0 0 .5rem;font-size:.84rem;color:var(--m);font-weight:300;line-height:1.55}
.formule-body p:last-child{margin:0}
.formule-tags{display:flex;gap:.5rem;flex-wrap:wrap;margin-top:.6rem}
.ftag{font-size:.68rem;font-weight:500;padding:.15rem .5rem;border-radius:50px}
.ftag-g{background:var(--gl);color:var(--gd)}
.ftag-a{background:var(--al);color:var(--ad)}
.ftag-b{background:#EFF6FF;color:#1e40af}

/* EQUIP TABLE */
.equip{background:var(--w);border:1px solid var(--b);border-radius:12px;overflow:hidden;margin:1.5rem 0}
.equip-head{display:grid;grid-template-columns:1.5fr 1fr 1fr;background:var(--gd);color:white;font-size:.74rem;font-weight:500;padding:.7rem 1rem;gap:.5rem}
.equip-row{display:grid;grid-template-columns:1.5fr 1fr 1fr;padding:.65rem 1rem;border-bottom:1px solid var(--b);font-size:.81rem;gap:.5rem;align-items:center}
.equip-row:last-child{border-bottom:none;font-weight:500;background:var(--gl)}
.equip-row:nth-child(even){background:var(--bg)}
.e-good{color:var(--g);font-weight:500}
.e-mid{color:var(--a)}

/* DESTINATION GRID */
.dest-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(200px,1fr));gap:.9rem;margin:1.5rem 0}
.dest-card{background:var(--w);border:1px solid var(--b);border-radius:10px;padding:1rem;transition:box-shadow .2s}
.dest-card:hover{box-shadow:0 3px 14px rgba(0,0,0,0.06)}
.dest-flag{font-size:1.5rem;margin-bottom:.4rem}
.dest-name{font-size:.9rem;font-weight:500;color:var(--gd);margin-bottom:.2rem}
.dest-desc{font-size:.76rem;color:var(--m);font-weight:300;line-height:1.4;margin-bottom:.4rem}
.dest-prix{display:inline-block;background:var(--al);color:var(--ad);font-size:.7rem;font-weight:500;padding:.15rem .5rem;border-radius:50px}

.tip-box{background:var(--al);border:1px solid rgba(239,159,39,0.3);border-radius:12px;padding:1.2rem 1.5rem;margin:2rem 0}
.tip-box .tip-label{font-size:.7rem;font-weight:500;text-transform:uppercase;letter-spacing:.06em;color:var(--ad);margin-bottom:.5rem}
.tip-box p{margin:0;font-size:.9rem;color:var(--ad)}

.warn-box{background:#FEF2F2;border:1px solid #FECACA;border-radius:12px;padding:1.2rem 1.5rem;margin:2rem 0}
.warn-box .warn-label{font-size:.7rem;font-weight:500;text-transform:uppercase;letter-spacing:.06em;color:#991B1B;margin-bottom:.5rem}
.warn-box p{margin:0;font-size:.88rem;color:#7F1D1D}

.recap{background:var(--w);border:1px solid var(--b);border-radius:12px;overflow:hidden;margin:2rem 0}
.recap-title{background:var(--gd);color:white;padding:.8rem 1.2rem;font-family:'Playfair Display',serif;font-size:1rem;font-weight:700}
.recap-row{display:flex;justify-content:space-between;align-items:center;padding:.7rem 1.2rem;border-bottom:1px solid var(--b);font-size:.85rem;gap:1rem}
.recap-row:last-child{border-bottom:none;font-weight:500;background:var(--gl)}
.recap-row span:last-child{color:var(--g);font-weight:500;text-align:right}

.article-nav{display:flex;justify-content:space-between;align-items:center;padding:1.5rem 0;border-top:1px solid var(--b);margin-top:3rem;gap:1rem;flex-wrap:wrap}
.art-nav-btn{display:flex;flex-direction:column;gap:.2rem;text-decoration:none;max-width:45%}
.art-nav-btn .nav-label{font-size:.7rem;text-transform:uppercase;letter-spacing:.06em;color:var(--m)}
.art-nav-btn .nav-title{font-size:.85rem;font-weight:500;color:var(--gd)}
.art-nav-btn:hover .nav-title{color:var(--g)}
.art-nav-btn.next{text-align:right;margin-left:auto}

footer{background:var(--gd);color:rgba(255,255,255,0.6);text-align:center;padding:1.8rem;font-size:.8rem}
footer strong{color:white}
footer a{color:rgba(255,255,255,0.5);text-decoration:none}

@media(max-width:640px){
  .article-wrap{padding:2rem 1rem 4rem}
  nav{padding:.8rem 1rem}
  .formule-header{flex-wrap:wrap}
  .equip-head,.equip-row{font-size:.74rem;padding:.6rem .7rem}
  .dest-grid{grid-template-columns:1fr 1fr}
}

/* Menu hamburger mobile */
.hamburger{display:none;flex-direction:column;gap:5px;cursor:pointer;background:none;border:none;padding:.3rem}
.hamburger span{display:block;width:24px;height:2px;background:var(--gd,#085041);border-radius:2px;transition:all .3s}
.mobile-menu{display:none;position:fixed;top:0;left:0;right:0;bottom:0;background:rgba(255,255,255,.98);z-index:999;flex-direction:column;align-items:center;justify-content:center;gap:1.5rem}
.mobile-menu.open{display:flex}
.mobile-menu a{font-family:'Playfair Display',serif;font-size:1.3rem;font-weight:700;color:#085041;text-decoration:none}
.mobile-menu .close-btn{position:absolute;top:1.2rem;right:1.5rem;background:none;border:none;font-size:1.8rem;cursor:pointer;color:#085041}
.mobile-menu .nav-cta{background:#1D9E75;color:white!important;padding:.5rem 1.4rem;border-radius:50px}
@media(max-width:768px){
  .hamburger{display:flex}
  nav .nav-links,nav > a:not(.logo),nav > div:not(.mobile-menu){display:none!important}
  nav li{display:none!important}
}
