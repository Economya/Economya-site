p{margin-bottom:1rem;font-size:.95rem}

/* PAYS CARDS */
.pays{display:flex;flex-direction:column;gap:1rem;margin:1.5rem 0}
.pays-card{background:var(--w);border:1px solid var(--b);border-radius:var(--r);padding:1.3rem 1.5rem;display:grid;grid-template-columns:auto 1fr auto;gap:1rem;align-items:start;transition:box-shadow .2s}
.pays-card:hover{box-shadow:0 4px 18px rgba(234,88,12,.1)}
.pays-card.top{border:2px solid var(--g)}
.top-badge{display:inline-block;background:var(--g);color:white;font-size:.65rem;font-weight:700;padding:.1rem .5rem;border-radius:50px;margin-bottom:.3rem}
.pays-flag{font-size:2rem;flex-shrink:0;margin-top:.1rem}
.pays-body h3{font-size:.95rem;font-weight:700;margin-bottom:.2rem}
.pays-body p{font-size:.83rem;color:var(--m);font-weight:300;margin:0 0 .45rem}
.pays-tags{display:flex;flex-wrap:wrap;gap:.3rem}
.ptag{font-size:.68rem;font-weight:600;padding:.1rem .45rem;border-radius:50px;background:#fff7ed;color:#9a3412}
.ptag.g{background:var(--gl);color:var(--gd)}
.pays-right{text-align:right;flex-shrink:0}
.pays-salaire{font-family:'Playfair Display',serif;font-size:1.2rem;font-weight:700;color:var(--orange);display:block;white-space:nowrap}
.pays-sub{font-size:.7rem;color:var(--m)}

/* ÉTAPES */
.steps{display:flex;flex-direction:column;gap:.85rem;margin:1.2rem 0}
.step{display:grid;grid-template-columns:38px 1fr;gap:.9rem;align-items:start;background:var(--w);border:1px solid var(--b);border-radius:var(--r);padding:1rem 1.2rem;transition:box-shadow .2s}
.step:hover{box-shadow:0 4px 16px rgba(234,88,12,.1)}
.sn{width:38px;height:38px;border-radius:50%;background:linear-gradient(135deg,#9a3412,#ea580c);color:white;font-family:'Playfair Display',serif;font-weight:700;font-size:1rem;display:flex;align-items:center;justify-content:center;flex-shrink:0}
.sc h3{font-size:.92rem;font-weight:600;margin-bottom:.2rem}
.sc p{font-size:.84rem;color:var(--m);font-weight:300;margin:0}

/* ENCADRÉS */
.tip{background:var(--gl);border-left:4px solid var(--g);border-radius:var(--r);padding:1.1rem 1.4rem;margin:1.5rem 0;font-size:.9rem;color:var(--gd)}
.tip strong{display:block;font-weight:600;margin-bottom:.25rem}
.warn{background:var(--orange-l);border-left:4px solid var(--orange);border-radius:var(--r);padding:1.1rem 1.4rem;margin:1.5rem 0;font-size:.9rem;color:#7c2d12}
.warn strong{display:block;font-weight:600;margin-bottom:.25rem}

.cta{background:linear-gradient(135deg,#1c0900,#9a3412);border-radius:var(--r);padding:1.8rem;text-align:center;margin-top:2.5rem;color:white}
.cta h3{font-family:'Playfair Display',serif;font-size:1.2rem;margin-bottom:.4rem}
.cta p{color:rgba(255,255,255,.7);font-size:.86rem;margin-bottom:1rem}
.cta-form{display:flex;gap:.5rem;max-width:360px;margin:0 auto;flex-wrap:wrap;justify-content:center}
.cta-form input{flex:1;min-width:150px;padding:.65rem 1rem;border-radius:50px;border:none;font-size:.86rem;font-family:inherit}
.cta-form button{background:linear-gradient(135deg,#ea580c,#7c3aed);color:white;border:none;padding:.65rem 1.3rem;border-radius:50px;font-weight:600;cursor:pointer;font-family:inherit;font-size:.86rem}
footer{background:var(--gd);color:rgba(255,255,255,.6);text-align:center;padding:1.5rem;font-size:.8rem}
footer strong{color:white}
@media(max-width:640px){.ah{padding:2rem 1.2rem}.ab{padding:1.8rem 1.1rem 3rem}.ah::before{font-size:8rem}.pays-card{grid-template-columns:1fr;gap:.5rem}.pays-right{text-align:left}}

/* Menu hamburger mobile */
.hamburger{display:none;flex-direction:column;gap:5px;cursor:pointer;background:none;border:none;padding:.3rem}
.hamburger span{display:block;width:24px;height:2px;background:var(--gd,#085041);border-radius:2px;transition:all .3s}
