p{margin-bottom:1rem;font-size:.95rem}

/* OPTIONS CONGÉ */
.options{display:flex;flex-direction:column;gap:1rem;margin:1.5rem 0}
.opt{background:var(--w);border:1px solid var(--b);border-radius:var(--r);padding:1.3rem 1.5rem;display:grid;grid-template-columns:auto 1fr auto;gap:1rem;align-items:start;transition:box-shadow .2s}
