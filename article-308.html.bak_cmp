.opt-icon{font-size:2rem;flex-shrink:0;margin-top:.1rem}
.opt-body h3{font-size:.95rem;font-weight:700;margin-bottom:.2rem}
.opt-body p{font-size:.83rem;color:var(--m);font-weight:300;margin:0 0 .45rem}
.opt-tags{display:flex;flex-wrap:wrap;gap:.3rem}
.otag{font-size:.68rem;font-weight:600;padding:.1rem .45rem;border-radius:50px;background:var(--gl);color:var(--gd)}
.otag.warn{background:#fffbeb;color:#78350f}
.opt-right{text-align:right;flex-shrink:0}
.opt-amt{font-family:'Playfair Display',serif;font-size:1.2rem;font-weight:700;color:var(--g);display:block;white-space:nowrap}
.opt-sub{font-size:.7rem;color:var(--m)}

/* TABLEAU */
.tw{overflow-x:auto;margin:1.3rem 0;border-radius:var(--r);border:1px solid var(--b)}
table{width:100%;border-collapse:collapse;font-size:.86rem}
thead tr{background:linear-gradient(135deg,#065f46,#1D9E75);color:white}
