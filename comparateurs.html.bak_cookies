<!DOCTYPE html>
<html lang="fr">
<head>
  <link rel="icon" type="image/svg+xml" href="favicon.svg">
  <meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Comparateurs Finance — Economya.fr</title>
<meta name="description" content="Comparateurs gratuits pour banques, assurances, livrets d'épargne et forfaits mobile. Trouvez la meilleure offre sur Economya.fr">
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;700;900&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet">
<style>
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
:root{--g:#1D9E75;--gl:#E1F5EE;--gd:#085041;--a:#EF9F27;--al:#FAEEDA;--r:16px;--t:#2C2C2A;--m:#5F5E5A;--bg:#FAFAF8;--w:#fff;--b:rgba(0,0,0,0.08)}
body{font-family:'DM Sans',sans-serif;background:var(--bg);color:var(--t);min-height:100vh}
nav{display:flex;justify-content:space-between;align-items:center;padding:.9rem 1.8rem;background:var(--w);border-bottom:1px solid var(--b);position:sticky;top:0;z-index:99}
.logo{font-family:'Playfair Display',serif;font-weight:900;font-size:1.3rem;color:var(--gd);text-decoration:none}
.logo span{color:var(--a)}
.nav-back{text-decoration:none;color:var(--m);font-size:.82rem;font-weight:500}
.hero{background:linear-gradient(135deg,#1a0533,#7c2d92,#a855f7);color:white;padding:3.5rem 2rem 3rem;text-align:center;position:relative;overflow:hidden}
.hero::before{content:'🔍';position:absolute;font-size:18rem;right:-2rem;top:-3rem;opacity:.05;pointer-events:none}
.hero h1{font-family:'Playfair Display',serif;font-size:clamp(2rem,5vw,3.2rem);font-weight:900;margin-bottom:.8rem}
.hero h1 em{color:var(--a);font-style:normal}
.hero p{font-size:1rem;color:rgba(255,255,255,.8);max-width:520px;margin:0 auto}
.container{max-width:1000px;margin:0 auto;padding:3rem 1.5rem}
.section-title{font-family:'Playfair Display',serif;font-size:1.5rem;font-weight:700;color:var(--gd);margin-bottom:1.5rem}
.comp-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(300px,1fr));gap:1.2rem;margin-bottom:3rem}
.comp-card{background:var(--w);border:1px solid var(--b);border-radius:var(--r);padding:1.5rem;text-decoration:none;color:inherit;transition:transform .2s,box-shadow .2s;display:block;position:relative}
.comp-card:hover{transform:translateY(-3px);box-shadow:0 8px 24px rgba(124,45,146,.1)}
.comp-card.top{border:2px solid var(--g)}
.top-badge{position:absolute;top:1rem;right:1rem;background:var(--g);color:white;font-size:.65rem;font-weight:700;padding:.2rem .6rem;border-radius:50px}
.comp-icon{font-size:2.2rem;margin-bottom:.8rem;display:block}
.comp-cat{font-size:.68rem;font-weight:700;text-transform:uppercase;letter-spacing:.08em;color:var(--g);margin-bottom:.3rem}
.comp-name{font-family:'Playfair Display',serif;font-size:1.05rem;font-weight:700;margin-bottom:.4rem}
.comp-desc{font-size:.82rem;color:var(--m);line-height:1.5;margin-bottom:.8rem}
.comp-items{display:flex;flex-wrap:wrap;gap:.4rem;margin-bottom:1rem}
.comp-item{background:var(--gl);color:var(--gd);font-size:.7rem;font-weight:600;padding:.2rem .6rem;border-radius:50px}
.comp-btn{display:inline-flex;align-items:center;gap:.4rem;background:var(--gl);color:var(--gd);font-size:.8rem;font-weight:600;padding:.4rem .9rem;border-radius:50px}
.comp-card:hover .comp-btn{background:var(--g);color:white}
.newsletter{background:linear-gradient(135deg,#1a0533,#7c2d92);border-radius:var(--r);padding:2.5rem;text-align:center;color:white;margin-top:1rem}
.newsletter h2{font-family:'Playfair Display',serif;font-size:1.4rem;margin-bottom:.5rem}
.newsletter p{color:rgba(255,255,255,.75);font-size:.9rem;margin-bottom:1.2rem}
.nl-form{display:flex;gap:.5rem;max-width:400px;margin:0 auto;flex-wrap:wrap;justify-content:center}
.nl-form input{flex:1;min-width:180px;padding:.7rem 1.1rem;border-radius:50px;border:none;font-size:.88rem;font-family:inherit}
.nl-form button{background:var(--a);color:white;border:none;padding:.7rem 1.4rem;border-radius:50px;font-weight:600;cursor:pointer;font-family:inherit}
footer{background:var(--gd);color:rgba(255,255,255,.6);text-align:center;padding:1.5rem;font-size:.8rem;margin-top:2rem}
footer strong{color:white}
@media(max-width:640px){.hero{padding:2.5rem 1.2rem}.container{padding:2rem 1rem}}

/* Menu hamburger mobile */
.hamburger{display:none;flex-direction:column;gap:5px;cursor:pointer;background:none;border:none;padding:.3rem}
.hamburger span{display:block;width:24px;height:2px;background:var(--gd,#085041);border-radius:2px;transition:all .3s}
.mobile-menu{display:none;position:fixed;top:0;left:0;right:0;bottom:0;background:rgba(255,255,255,.98);z-index:999;flex-direction:column;align-items:center;justify-content:center;gap:1.5rem}
.mobile-menu.open{display:flex}
.mobile-menu a{font-family:'Playfair Display',serif;font-size:1.3rem;font-weight:700;color:#085041;text-decoration:none}
.mobile-menu .close-btn{position:absolute;top:1.2rem;right:1.5rem;background:none;border:none;font-size:1.8rem;cursor:pointer;color:#085041}
.mobile-menu .nav-cta{background:#1D9E75;color:white!important;padding:.5rem 1.4rem;border-radius:50px}
@media(max-width:768px){
  .hamburger{display:flex}
  nav .nav-links, nav > a:not(.logo), nav > div{display:none!important}
  nav li{display:none!important}
}
</style>

  <script type="application/ld+json">
  {
  "@context": "https://schema.org",
  "@type": "WebApplication",
  "name": "Comparateurs Finance",
  "description": "Comparateurs gratuits pour banques, assurances, livrets d'épargne et forfaits mobile. Trouvez la meilleure offre sur Economya.fr",
  "url": "https://economya.fr/comparateurs.html",
  "applicationCategory": "FinanceApplication",
  "operatingSystem": "Web",
  "offers": {
    "@type": "Offer",
    "price": "0",
    "priceCurrency": "EUR"
  },
  "publisher": {
    "@type": "Organization",
    "name": "Economya.fr",
    "url": "https://economya.fr"
  },
  "inLanguage": "fr-FR"
}
  </script>

