<style>
  *,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
  : root{
    --g:#1D9E75;--gl:#E1F5EE;--gd:#085041;--a:#EF9F27;--al:#FAEEDA;--ad:#633806;
    --t:#2C2C2A;--m:#5F5E5A;--bg:#FAFAF8;--w:#fff;--b:rgba(0,0,0,0.1);
    --amber:#A85C00;--amber-mid:#D4831A;--amber-light:#FFF6E5;
    --yellow:#FFD700;--warm:#FF8C00;--cream:#FFFDF5;
  }
  body{font-family:'DM Sans',sans-serif;background:var(--bg);color:var(--t);line-height:1.7}
  nav{display:flex;justify-content:space-between;align-items:center;padding:.9rem 1.8rem;background:var(--w);border-bottom:1px solid var(--b);position:sticky;top:0;z-index:99}
  .logo{font-family:'Playfair Display',serif;font-weight:900;font-size:1.3rem;color:var(--gd);text-decoration:none}
  .logo span{color:var(--a)}
  .back{font-size:.82rem;color:var(--m);text-decoration:none}
  .back:hover{color:var(--g)}

  .hero-art{
    background:linear-gradient(135deg,#1A0E00 0%,#A85C00 35%,#D4831A 65%,#FFD700 88%,#FFFCCC 100%);
    padding:3.5rem 2rem 3rem;text-align:center;position:relative;overflow:hidden
  }
  .hero-art::before{
    content:'💡';position:absolute;font-size:13rem;opacity:.07;
    top:50%;left:50%;transform:translate(jusqu'à -50%,jusqu'à -50%);pointer-events:none
  }
  .acat{font-size:.85rem;font-weight:500;color:rgba(255,255,255,.65);margin-bottom:.6rem;letter-spacing:.04em}
  .acat strong{color:#fff}
  .hero-art h1{
    font-family:'Playfair Display',serif;font-size:clamp(1.7rem,4vw,2.6rem);
    font-weight:900;line-height:1.1;color:#fff;max-width:620px;margin:0 auto .9rem
  }
  .abadge{
    display:inline-block;
    background:linear-gradient(90deg,#FFFCCC,var(--yellow));
    color:#1A0E00;font-size:.82rem;font-weight:700;padding:.35rem 1rem;
    border-radius:50px;margin-top:.4rem
  }
  .meta{display:flex;justify-content:center;flex-wrap:wrap;gap:.6rem;margin-top:1.2rem}
  .meta span{font-size:.74rem;color:rgba(255,255,255,.55);background:rgba(255,255,255,.12);padding:.2rem .75rem;border-radius:50px}

  article{max-width:680px;margin:0 auto;padding:2.5rem 1.5rem 4rem}
  article p{margin-bottom:1.3rem;font-size:.97rem;font-weight:300}
  article h2{font-family:'Playfair Display',serif;font-size:1.2rem;font-weight:700;color:var(--amber);margin:2rem 0 .7rem}

  /* Comparatif ampoules */
  .ampoules{width:100%;border-collapse:collapse;margin:1.5rem 0;font-size:.84rem}
  .ampoules thead tr{background:linear-gradient(90deg,var(--amber),var(--amber-mid));color:#fff}
  .ampoules thead th{padding:.62rem .9rem;text-align:left;font-weight:500}
  .ampoules tbody tr:nth-child(even){background:var(--amber-light)}
  .ampoules tbody tr:nth-child(odd){background:var(--w)}
  .ampoules tbody td{padding:.55rem .9rem;border-bottom:1px solid var(--b);font-weight:300;vertical-align:middle}
  .ampoules tbody td:first-child{font-weight:500;color:var(--amber)}
  .ampoules td.mauvais{color:#B91C1C;font-weight:500}
  .ampoules td.bien{color:var(--gd);font-weight:600}
  .ampoules tr.led td{background:#ECFDF5;font-weight:500}
  .ampoules tr.led td:first-child{color:var(--gd)}

  /* Guide choix LED */
  .guide{display:grid;grid-template-columns:1fr 1fr;gap:.7rem;margin:1.5rem 0}
  .guide-item{background:var(--w);border:1px solid var(--b);border-radius:11px;padding:.85rem 1rem}
  .guide-emoji{font-size:1.3rem;margin-bottom:.3rem}
  .guide-titre{font-weight:500;font-size:.88rem;color:var(--amber);margin-bottom:.2rem}
  .guide-desc{font-size:.8rem;font-weight:300;color:var(--m);line-height:1.45}

  /* Calcul économies foyer */
  .simul{background:linear-gradient(135deg,#1A0E00,#A85C00);border-radius:13px;padding:1.2rem 1.4rem;margin:1.5rem 0;color:#fff}
  .simul h3{font-family:'Playfair Display',serif;font-weight:700;font-size:1rem;color:var(--yellow);margin-bottom:.9rem}
  .simul-row{display:flex;justify-content:space-between;padding:.4rem 0;border-bottom:1px solid rgba(255,255,255,.08);font-size:.84rem}
  .simul-row:last-child{border-bottom:none;padding-top:.5rem;margin-top:.3rem}
  .simul-label{font-weight:300;color:rgba(255,255,255,.85)}
  .simul-val{font-weight:600;color:var(--yellow);white-space:nowrap}
  .simul-label.total{font-weight:600;color:#fff}
  .simul-val.total{font-size:.95rem}

  /* Gestes complémentaires */
  .gestes{display:flex;flex-direction:column;gap:0;border:1px solid var(--b);border-radius:12px;overflow:hidden;margin:1.5rem 0}
  .geste{display:grid;grid-template-columns:44px 1fr;border-bottom:1px solid var(--b)}
  .geste:last-child{border-bottom:none}
  .geste-num{background:linear-gradient(180deg,var(--amber),var(--amber-mid));color:#FFFCCC;font-family:'Playfair Display',serif;font-weight:900;font-size:1rem;display:flex;align-items:center;justify-content:center}
  .geste-body{padding:.7rem 1rem;background:var(--w)}
  .geste-title{font-weight:500;font-size:.87rem;color:var(--amber);margin-bottom:.12rem}
  .geste-desc{font-size:.8rem;font-weight:300;color:var(--m);line-height:1.45}

  .conseil{
    background:linear-gradient(135deg,#1A0E00,#A85C00);
    border-radius:12px;padding:1.2rem 1.4rem;margin:1.8rem 0;color:#fff;
    border:1px solid rgba(255,215,0,.15)
  }
  .conseil strong{display:block;color:var(--yellow);font-weight:500;font-size:.92rem;margin-bottom:.4rem}
  .conseil p{font-size:.88rem;color:rgba(255,255,255,.82);font-weight:300;margin:0;line-height:1.65}

  footer{background:var(--gd);color:rgba(255,255,255,0.6);text-align:center;padding:1.6rem;font-size:.8rem}
  footer strong{color:white}
  footer a{color:var(--a);text-decoration:none}
  @media(max-width:500px){.guide{grid-template-columns:1fr}}

/* Menu hamburger mobile */
.hamburger{display:none;flex-direction:column;gap:5px;cursor:pointer;background:none;border:none;padding:.3rem}
