<script>
const fmt = n => Math.round(n).toLocaleString('fr-FR') + ' €';

// Montants forfaitaires 2026 (approximatifs)
const FORFAITS = {
  seul:   { base: 638.28, logement: 67.84, enfants: 0 },
  couple: { base: 957.42, logement: 67.84, enfants: 0 },
  seul1:  { base: 1392.19, logement: 101.77, enfants: 0 },
  seul2:  { base: 1392.19, logement: 101.77, enfants: 0 }, // ⚠️ A VERIFIER sur caf.fr - montant 1 enfant utilise par defaut, sources divergentes pour 2 enfants
  couple1:{ base: 957.42, logement: 101.77, enfants: 127.66 },
  couple2:{ base: 957.42, logement: 101.77, enfants: 255.31 },
  couple3:{ base: 957.42, logement: 101.77, enfants: 382.97 },
};

function calculate() {
  const revenus = +document.getElementById('revenus').value;
  const autres = +document.getElementById('autres').value;
  const situation = document.getElementById('situation').value;
  const logement = document.getElementById('logement').value;

  document.getElementById('v-revenus').innerHTML = revenus.toLocaleString('fr-FR') + ' <span>€/mois</span>';
  document.getElementById('v-autres').innerHTML = autres.toLocaleString('fr-FR') + ' <span>€/mois</span>';

  const f = FORFAITS[situation];
  const forfaitLogement = logement === 'heberge' ? 0 : f.logement;
  const montantForaitaire = f.base + forfaitLogement + f.enfants;

  // Formule prime d'activité (barème officiel CAF au 1er avril 2026)
  // PA = MF + 59,85% × RP + Bonification individuelle - RG
  // MF = montant forfaitaire
  // RP = revenus professionnels
  // RG = ressources globales du foyer
  // Bonification individuelle : 0€ sous 709,18€, croît linéairement jusqu'à
  // 240,63€ max atteint à 1 658,76€ de revenus professionnels
  function bonificationIndividuelle(rp) {
    const SEUIL_BAS = 709.18;
    const SEUIL_HAUT = 1658.76;
    const MAX_BONIF = 240.63;
    if (rp <= SEUIL_BAS) return 0;
    if (rp >= SEUIL_HAUT) return MAX_BONIF;
    return MAX_BONIF * (rp - SEUIL_BAS) / (SEUIL_HAUT - SEUIL_BAS);
  }
  const rg = revenus + autres;
  const bonification = bonificationIndividuelle(revenus);
  const pa = montantForaitaire + 0.5985 * revenus + bonification - rg;
  const prime = Math.max(0, Math.round(pa));

  const banner = document.getElementById('result-banner');
  const montantEl = document.getElementById('r-prime');
  const sousEl = document.getElementById('r-sous');

  if(prime < 10) {
    banner.className = 'result-big ineligible';
    montantEl.className = 'montant bleu';
    montantEl.textContent = '0 €';
    sousEl.textContent = 'Vous ne semblez pas éligible à la prime d\'activité';
  } else {
    banner.className = 'result-big eligible';
    montantEl.className = 'montant vert';
    montantEl.textContent = fmt(prime);
    sousEl.textContent = 'par mois — vérifiez sur caf.fr pour le montant exact';
  }

  document.getElementById('r-annuel').textContent = fmt(prime * 12);
  document.getElementById('r-forfait').textContent = fmt(forfaitLogement);
  document.getElementById('r-plafond').textContent = fmt(montantForaitaire);

  // Commentaires
  const comments = [];
  if(prime >= 10) {
    comments.push({ type: 'bon', icon: '🎉', txt: `Vous êtes potentiellement éligible à ${fmt(prime)}/mois. Faites votre demande sur caf.fr dès maintenant !` });
    comments.push({ type: 'bon', icon: '💰', txt: `Sur un an, cela représente ${fmt(prime * 12)} — une somme non négligeable à ne pas laisser passer.` });
  } else {
    comments.push({ type: 'info', icon: 'ℹ️', txt: 'Avec vos revenus actuels, vous ne semblez pas éligible. Mais vérifiez sur caf.fr — le calcul officiel est plus précis.' });
  }

  if(revenus < 1500) {
    comments.push({ type: 'info', icon: '💡', txt: 'La prime d\'activité est conçue pour les travailleurs à revenus modestes. Si vous êtes en dessous de 1 500 €/mois, vous avez de bonnes chances d\'y avoir droit.' });
  }

  if(logement === 'heberge') {
    comments.push({ type: 'alerte', icon: '⚠️', txt: 'Hébergé gratuitement : le forfait logement n\'est pas appliqué, ce qui réduit le montant de votre prime.' });
  }

  const commentList = document.getElementById('comment-list');
  commentList.innerHTML = '';
  comments.forEach(c => {
    commentList.innerHTML += `<div class="comment-item ${c.type}"><span style="font-size:1.2rem;flex-shrink:0">${c.icon}</span><span>${c.txt}</span></div>`;
  });
}

document.querySelectorAll('input[type=range]').forEach(el => el.addEventListener('input', calculate));
calculate();
</script>
