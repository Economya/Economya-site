<html lang="fr">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Livres : lire beaucoup pour moins cher — Economya.fr</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;700;900&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet">
<style>
  *,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
  :root{
    --g:#1D9E75;--gl:#E1F5EE;--gd:#085041;--a:#EF9F27;--al:#FAEEDA;--ad:#633806;
    --t:#2C2C2A;--m:#5F5E5A;--bg:#FAFAF8;--w:#fff;--b:rgba(0,0,0,0.1);
    --ink:#1C1226;--ink-mid:#3D2B6B;--ink-light:#EEE8FF;
    --amber:#D4831A;--paper:#FDF8EF;--sage:#4A7C4E;
  }
  body{font-family:'DM Sans',sans-serif;background:var(--bg);color:var(--t);line-height:1.7}
  nav{display:flex;justify-content:space-between;align-items:center;padding:.9rem 1.8rem;background:var(--w);border-bottom:1px solid var(--b);position:sticky;top:0;z-index:99}
  .logo{font-family:'Playfair Display',serif;font-weight:900;font-size:1.3rem;color:var(--gd);text-decoration:none}
  .logo span{color:var(--a)}
  .back{font-size:.82rem;color:var(--m);text-decoration:none}
  .back:hover{color:var(--g)}

  .hero-art{
    background:linear-gradient(135deg,#08040F 0%,#1C1226 35%,#3D2B6B 65%,#D4831A 100%);
    padding:3.5rem 2rem 3rem;text-align:center;position:relative;overflow:hidden
  }
  .hero-art::before{
    content:'📚';position:absolute;font-size:13rem;opacity:.06;
    top:50%;left:50%;transform:translate(jusqu'à -50%,jusqu'à -50%);pointer-events:none
  }
  .acat{font-size:.85rem;font-weight:500;color:rgba(255,255,255,.6);margin-bottom:.6rem;letter-spacing:.04em}
  .acat strong{color:#fff}
  .hero-art h1{
    font-family:'Playfair Display',serif;font-size:clamp(1.7rem,4vw,2.6rem);
    font-weight:900;line-height:1.1;color:#fff;max-width:620px;margin:0 auto .9rem
  }
  .abadge{
    display:inline-block;
    background:linear-gradient(90deg,var(--paper),var(--amber));
    color:#08040F;font-size:.82rem;font-weight:700;padding:.35rem 1rem;
    border-radius:50px;margin-top:.4rem
  }
  .meta{display:flex;justify-content:center;flex-wrap:wrap;gap:.6rem;margin-top:1.2rem}
  .meta span{font-size:.74rem;color:rgba(255,255,255,.55);background:rgba(255,255,255,.1);padding:.2rem .75rem;border-radius:50px}

  article{max-width:680px;margin:0 auto;padding:2.5rem 1.5rem 4rem}
  article p{margin-bottom:1.3rem;font-size:.97rem;font-weight:300}
  article h2{font-family:'Playfair Display',serif;font-size:1.2rem;font-weight:700;color:var(--ink);margin:2rem 0 .7rem}

  /* Options lecture */
  .options{display:flex;flex-direction:column;gap:.7rem;margin:1.5rem 0}
  .opt{background:var(--w);border:1px solid var(--b);border-radius:12px;overflow:hidden;display:grid;grid-template-columns:auto 1fr}
  .opt-prix{background:linear-gradient(180deg,var(--ink),var(--ink-mid));color:#fff;display:flex;flex-direction:column;align-items:center;justify-content:center;padding:.8rem .7rem;min-width:75px;text-align:center}
  .opt-val{font-family:'Playfair Display',serif;font-size:1.1rem;font-weight:900;color:var(--amber);line-height:1.1}
  .opt-unit{font-size:.6rem;font-weight:500;text-transform:uppercase;letter-spacing:.05em;color:rgba(255,255,255,.55);margin-top:.2rem}
  .opt-body{padding:.8rem 1rem}
  .opt-title{font-weight:500;font-size:.9rem;color:var(--ink);margin-bottom:.2rem}
  .opt-desc{font-size:.83rem;font-weight:300;color:var(--m);line-height:1.55;margin-bottom:.35rem}
  .opt-tags{display:flex;flex-wrap:wrap;gap:.35rem}
  .otag{font-size:.69rem;font-weight:500;padding:.1rem .5rem;border-radius:50px;background:var(--ink-light);color:var(--ink-mid)}

  /* Sites occasion */
  .sites{display:grid;grid-template-columns:repeat(3,1fr);gap:.6rem;margin:1.5rem 0}
  .site{background:var(--w);border:1px solid var(--b);border-radius:10px;padding:.8rem .9rem;text-align:center}
  .site-nom{font-weight:600;font-size:.87rem;color:var(--ink);margin-bottom:.2rem}
  .site-desc{font-size:.75rem;font-weight:300;color:var(--m);line-height:1.4;margin-bottom:.3rem}
  .site-tag{font-size:.68rem;font-weight:500;padding:.1rem .45rem;border-radius:50px;background:var(--al);color:var(--ad)}

  /* Calcul économie annuelle */
  .calcul{display:grid;grid-template-columns:1fr auto 1fr;gap:.6rem;align-items:center;margin:1.5rem 0;background:var(--w);border:1px solid var(--b);border-radius:12px;padding:1.1rem 1.2rem}
  .calc-block{text-align:center}
  .calc-label{font-size:.7rem;font-weight:500;text-transform:uppercase;letter-spacing:.06em;color:var(--m);margin-bottom:.3rem}
  .calc-val{font-family:'Playfair Display',serif;font-size:1.6rem;font-weight:900}
  .calc-val.rouge{color:#B91C1C}
  .calc-val.vert{color:var(--sage)}
  .calc-sub{font-size:.72rem;color:var(--m);margin-top:.15rem;font-weight:300}
  .calc-arrow{font-size:1.3rem;color:var(--ink-mid);text-align:center}

  .conseil{
    background:linear-gradient(135deg,#08040F,#1C1226);
    border-radius:12px;padding:1.2rem 1.4rem;margin:1.8rem 0;color:#fff;
    border:1px solid rgba(212,131,26,.2)
  }
  .conseil strong{display:block;color:var(--amber);font-weight:500;font-size:.92rem;margin-bottom:.4rem}
  .conseil p{font-size:.88rem;color:rgba(255,255,255,.82);font-weight:300;margin:0;line-height:1.65}

  footer{background:var(--gd);color:rgba(255,255,255,0.6);text-align:center;padding:1.6rem;font-size:.8rem}
  footer strong{color:white}
  footer a{color:var(--a);text-decoration:none}
  @media(max-width:500px){.sites{grid-template-columns:1fr 1fr}.calcul{grid-template-columns:1fr}}

/* Menu hamburger mobile */
.hamburger{display:none;flex-direction:column;gap:5px;cursor:pointer;background:none;border:none;padding:.3rem}
.hamburger span{display:block;width:24px;height:2px;background:var(--gd,#085041);border-radius:2px;transition:all .3s}
.mobile-menu{display:none;position:fixed;top:0;left:0;right:0;bottom:0;background:rgba(255,255,255,.98);z-index:999;flex-direction:column;align-items:center;justify-content:center;gap:1.5rem}
.mobile-menu.open{display:flex}
.mobile-menu a{font-family:'Playfair Display',serif;font-size:1.3rem;font-weight:700;color:#085041;text-decoration:none}
.mobile-menu .close-btn{position:absolute;top:1.2rem;right:1.5rem;background:none;border:none;font-size:1.8rem;cursor:pointer;color:#085041}
.mobile-menu .nav-cta{background:#1D9E75;color:white!important;padding:.5rem 1.4rem;border-radius:50px}
@media(max-width:768px){
  .hamburger{display:flex}
  nav .nav-links,nav > a:not(.logo),nav > div:not(.mobile-menu){display:none!important}
  nav li{display:none!important}
}
</style>
