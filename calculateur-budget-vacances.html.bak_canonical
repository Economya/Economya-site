<div class="container">

  <div class="card">
    <h2>🧳 Votre style de voyage</h2>
    <div class="style-grid">
      <div class="style-opt active" data-style="backpacker" onclick="choisirStyle('backpacker')">
        <span class="emoji">🎒</span>
        <span class="name">Backpacker</span>
      </div>
      <div class="style-opt" data-style="malin" onclick="choisirStyle('malin')">
        <span class="emoji">🧭</span>
        <span class="name">Voyageur malin</span>
      </div>
      <div class="style-opt" data-style="confort" onclick="choisirStyle('confort')">
        <span class="emoji">🌴</span>
        <span class="name">Confort</span>
      </div>
    </div>

    <div class="field">
      <label for="zone">Destination</label>
      <select id="zone">
        <option value="europe">Europe / proche (train, vol court)</option>
        <option value="lointain">Destination lointaine (vol long-courrier)</option>
      </select>
    </div>
    <div class="field">
      <label for="jours">Durée du séjour (jours)</label>
      <input type="number" id="jours" placeholder="Ex : 10" min="1" step="1" value="10">
    </div>
    <div class="field">
      <label for="voyageurs">Nombre de voyageurs</label>
      <input type="number" id="voyageurs" placeholder="Ex : 2" min="1" step="1" value="1">
    </div>
    <div class="field">
      <label for="moisAvant">Départ dans combien de mois ?</label>
      <input type="number" id="moisAvant" placeholder="Ex : 6" min="1" step="1" value="6">
      <div class="hint">Pour calculer combien épargner chaque mois.</div>
    </div>
    <button class="btn-calc" onclick="calculer()">Calculer mon budget vacances</button>
  </div>

  <div class="result" id="result">
    <div class="total-banner">
      <div class="total-label">Budget total estimé</div>
      <span class="total-val" id="totalVal">—</span>
