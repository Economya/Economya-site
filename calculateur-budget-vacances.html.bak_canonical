<script>
function toggleMenu(){var m=document.getElementById("mobileMenu");m.classList.toggle("open");document.body.style.overflow=m.classList.contains("open")?"hidden":"";}

// Budgets indicatifs par jour et par personne (€), et billet A/R moyen par personne
const BUDGETS = {
  backpacker: {
    europe:   { heberg: 20, nourriture: 15, transportLocal: 5,  activites: 10, billet: 100 },
    lointain: { heberg: 15, nourriture: 12, transportLocal: 6,  activites: 12, billet: 650 }
  },
  malin: {
    europe:   { heberg: 55, nourriture: 30, transportLocal: 10, activites: 20, billet: 180 },
    lointain: { heberg: 45, nourriture: 25, transportLocal: 12, activites: 25, billet: 800 }
  },
  confort: {
    europe:   { heberg: 140, nourriture: 60, transportLocal: 20, activites: 45, billet: 300 },
    lointain: { heberg: 160, nourriture: 55, transportLocal: 25, activites: 55, billet: 1300 }
  }
};

let styleActuel = 'backpacker';

function choisirStyle(style){
  styleActuel = style;
  document.querySelectorAll('.style-opt').forEach(function(el){
    el.classList.toggle('active', el.dataset.style === style);
  });
}

function fmtM(v){
  return v.toLocaleString('fr-FR', {maximumFractionDigits: 0}) + ' €';
}

function calculer(){
  const jours = parseInt(document.getElementById('jours').value) || 0;
  const voyageurs = parseInt(document.getElementById('voyageurs').value) || 0;
  const moisAvant = parseInt(document.getElementById('moisAvant').value) || 0;
  const zone = document.getElementById('zone').value;

  if(jours <= 0 || voyageurs <= 0){
    alert('Merci de renseigner la durée du séjour et le nombre de voyageurs.');
    return;
  }

  const b = BUDGETS[styleActuel][zone];

  const coutTransport = b.billet * voyageurs;
  const coutHeberg = b.heberg * jours * voyageurs;
  const coutNourriture = b.nourriture * jours * voyageurs;
  const coutTransportLocal = b.transportLocal * jours * voyageurs;
  const coutActivites = b.activites * jours * voyageurs;

  const total = coutTransport + coutHeberg + coutNourriture + coutTransportLocal + coutActivites;

  document.getElementById('r-transport').textContent = fmtM(coutTransport);
  document.getElementById('r-heberg').textContent = fmtM(coutHeberg);
  document.getElementById('r-nourriture').textContent = fmtM(coutNourriture);
  document.getElementById('r-transportlocal').textContent = fmtM(coutTransportLocal);
  document.getElementById('r-activites').textContent = fmtM(coutActivites);

  document.getElementById('totalVal').textContent = fmtM(total);
  document.getElementById('totalSub').textContent = jours + ' jours · ' + voyageurs + ' voyageur' + (voyageurs > 1 ? 's' : '');

  const epargneMensuelle = moisAvant > 0 ? total / moisAvant : total;
  document.getElementById('r-epargne').textContent = fmtM(epargneMensuelle) + '/mois';
  document.getElementById('r-epargne-lbl').textContent = 'pendant ' + moisAvant + ' mois pour atteindre ' + fmtM(total);

  const explain = document.getElementById('r-explain');
  explain.innerHTML = `<strong>💡 Objectif :</strong> en mettant de côté ${fmtM(epargneMensuelle)} chaque mois pendant ${moisAvant} mois, vous financez entièrement ce voyage sans toucher à votre épargne de précaution.`;

  document.getElementById('result').style.display = 'block';
  document.getElementById('result').scrollIntoView({behavior: 'smooth', block: 'start'});
}
</script>

