<!-- Menu hamburger mobile -->

<button class="hamburger" onclick="toggleMenu()" aria-label="Menu"><span></span><span></span><span></span></button></nav><div class="mobile-menu" id="mobileMenu"><button class="close-btn" onclick="toggleMenu()">X</button><a href="index.html">Accueil</a><a href="jeux.html">Jeux</a><a href="outils-gratuits.html">Outils gratuits</a><a href="comparateurs.html">Comparateurs</a><a href="a-propos.html">A propos</a><a href="recherche.html">Rechercher</a></div>
<div class="hero">
  <h1>Audit de vos <em>abonnements</em></h1>
  <p>Cochez ce que vous gardez, coupez le reste. Découvrez en 5 minutes combien vous pouvez économiser.</p>
</div>
<div class="container">

  <div class="bilan">
    <div class="bilan-item"><span class="bilan-num rouge" id="b-total">0 €</span><div class="bilan-lbl">Total abonnements/mois</div></div>
    <div class="bilan-item"><span class="bilan-num orange" id="b-garde">0 €</span><div class="bilan-lbl">Abonnements conservés</div></div>
    <div class="bilan-item"><span class="bilan-num vert" id="b-eco">0 €</span><div class="bilan-lbl">Économies potentielles</div></div>
  </div>

  <!-- Streaming -->
  <div class="section">
    <h2>🎬 Streaming & Divertissement</h2>
    <div id="list-streaming"></div>
  </div>

  <!-- Musique -->
  <div class="section">
    <h2>🎵 Musique & Podcasts</h2>
    <div id="list-musique"></div>
  </div>

  <!-- Sport & Bien-être -->
  <div class="section">
    <h2>💪 Sport & Bien-être</h2>
    <div id="list-sport"></div>
  </div>

  <!-- Tech & Logiciels -->
  <div class="section">
    <h2>💻 Tech & Logiciels</h2>
    <div id="list-tech"></div>
  </div>

  <!-- Presse & Formation -->
  <div class="section">
    <h2>📚 Presse & Formation</h2>
    <div id="list-presse"></div>
  </div>

  <!-- Autres -->
  <div class="section">
    <h2>📦 Autres abonnements</h2>
    <div id="list-autres"></div>
    <button class="btn-add" onclick="ajouterCustom()">+ Ajouter un abonnement personnalisé</button>
  </div>

  <!-- Résultat -->
  <div class="eco-banner" id="eco-banner" style="display:none">
    <h2>💰 Vous pourriez économiser</h2>
    <span class="montant" id="eco-montant">0 €</span>
    <div class="sous" id="eco-sous">par mois en coupant les abonnements sélectionnés</div>
  </div>

  <div class="result-section" id="result-section" style="display:none">
    <h2>✂️ Abonnements à couper</h2>
    <div class="liste-couper" id="liste-couper"></div>
  </div>

  <div class="cta">
    <h3>📬 Économisez sur tous vos postes chaque semaine</h3>
    <p>Nos meilleures alternatives gratuites aux abonnements payants dans votre boîte mail.</p>
    <div class="cta-form">
      <input type="email" placeholder="votre@email.fr">
      <button>Je m'abonne</button>
    </div>
  </div>
</div>


<!-- Boutons partage -->
<div style="background:#fff;border-radius:16px;border:1px solid rgba(0,0,0,0.08);padding:1.2rem 1.5rem;margin:2rem auto;max-width:680px;text-align:center">
  <p style="font-size:.82rem;font-weight:600;color:#5F5E5A;margin-bottom:.8rem;text-transform:uppercase;letter-spacing:.05em">Partager cet article</p>
