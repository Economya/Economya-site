<!DOCTYPE html>
<html lang="fr">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Checklist Audit de vos Abonnements — Economya.fr</title>
<meta name="description" content="Auditez tous vos abonnements en 5 minutes et découvrez combien vous pouvez économiser chaque mois. Gratuit sur Economya.fr">
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;700;900&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet">
<style>
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
:root{--g:#1D9E75;--gl:#E1F5EE;--gd:#085041;--a:#EF9F27;--al:#FAEEDA;--r:16px;--t:#2C2C2A;--m:#5F5E5A;--bg:#FAFAF8;--w:#fff;--b:rgba(0,0,0,0.08)}
body{font-family:'DM Sans',sans-serif;background:var(--bg);color:var(--t);min-height:100vh}
nav{display:flex;justify-content:space-between;align-items:center;padding:.9rem 1.8rem;background:var(--w);border-bottom:1px solid var(--b);position:sticky;top:0;z-index:99}
.logo{font-family:'Playfair Display',serif;font-weight:900;font-size:1.3rem;color:var(--gd);text-decoration:none}
.logo span{color:var(--a)}
.nav-back{text-decoration:none;color:var(--m);font-size:.82rem;font-weight:500}
.hero{background:linear-gradient(135deg,#1e3a5f,#1d4ed8,#3b82f6);color:white;padding:3rem 2rem 2.5rem;text-align:center;position:relative;overflow:hidden}
.hero::before{content:'✂️';position:absolute;font-size:16rem;right:-1rem;top:-2rem;opacity:.07;pointer-events:none}
.hero h1{font-family:'Playfair Display',serif;font-size:clamp(1.8rem,4vw,2.6rem);font-weight:900;margin-bottom:.6rem}
.hero h1 em{color:#EF9F27;font-style:normal}
.hero p{font-size:.95rem;color:rgba(255,255,255,.75);max-width:500px;margin:0 auto}
.container{max-width:900px;margin:0 auto;padding:2.5rem 1.5rem}
.bilan{background:linear-gradient(135deg,#1e3a5f,#1d4ed8);border-radius:var(--r);padding:1.5rem 2rem;color:white;margin-bottom:1.5rem;display:flex;justify-content:space-between;align-items:center;flex-wrap:wrap;gap:1rem;position:sticky;top:70px;z-index:98}
.bilan-item{text-align:center}
.bilan-num{font-family:'Playfair Display',serif;font-size:1.8rem;font-weight:900;display:block}
.bilan-num.rouge{color:#fca5a5}
.bilan-num.vert{color:#86efac}
.bilan-num.orange{color:#fed7aa}
.bilan-lbl{font-size:.72rem;color:rgba(255,255,255,.7)}
.section{background:var(--w);border-radius:var(--r);border:1px solid var(--b);padding:1.5rem 2rem;margin-bottom:1.2rem;box-shadow:0 4px 20px rgba(0,0,0,.04)}
.section h2{font-family:'Playfair Display',serif;font-size:1.1rem;font-weight:700;margin-bottom:1.2rem;color:var(--gd);display:flex;align-items:center;gap:.5rem}
.abo-item{display:grid;grid-template-columns:1fr auto auto auto;gap:.8rem;align-items:center;padding:.8rem 0;border-bottom:1px solid var(--b)}
.abo-item:last-child{border-bottom:none}
.abo-info h3{font-size:.9rem;font-weight:600;margin-bottom:.15rem}
.abo-info p{font-size:.75rem;color:var(--m)}
.abo-prix{font-family:'Playfair Display',serif;font-size:1rem;font-weight:700;color:var(--gd);white-space:nowrap;text-align:right}
.abo-input{width:70px;border:1px solid var(--b);border-radius:8px;padding:.35rem .5rem;font-family:inherit;font-size:.85rem;text-align:center}
.abo-btns{display:flex;gap:.4rem}
.btn-garde{background:var(--gl);color:var(--gd);border:none;border-radius:50px;padding:.3rem .8rem;font-size:.72rem;font-weight:600;cursor:pointer;font-family:inherit;transition:all .2s}
.btn-garde.active{background:var(--g);color:white}
.btn-coupe{background:#fef2f2;color:#dc2626;border:none;border-radius:50px;padding:.3rem .8rem;font-size:.72rem;font-weight:600;cursor:pointer;font-family:inherit;transition:all .2s}
.btn-coupe.active{background:#dc2626;color:white}
.abo-custom{display:grid;grid-template-columns:1fr auto auto auto;gap:.8rem;align-items:center;padding:.8rem 0;border-bottom:1px solid var(--b)}
.abo-custom input[type=text]{border:1px solid var(--b);border-radius:8px;padding:.35rem .7rem;font-family:inherit;font-size:.85rem;width:100%}
.btn-add{background:var(--gl);color:var(--gd);border:2px dashed var(--g);border-radius:8px;padding:.6rem;font-family:inherit;font-size:.82rem;font-weight:600;cursor:pointer;width:100%;margin-top:.8rem;transition:all .2s}
.btn-add:hover{background:var(--g);color:white}
.result-section{background:var(--w);border-radius:var(--r);border:1px solid var(--b);padding:2rem;margin-bottom:1.5rem;box-shadow:0 4px 20px rgba(0,0,0,.04)}
.result-section h2{font-family:'Playfair Display',serif;font-size:1.2rem;font-weight:700;margin-bottom:1.2rem;color:var(--gd)}
.eco-banner{background:linear-gradient(135deg,#14532d,#16a34a);border-radius:var(--r);padding:2rem;text-align:center;color:white;margin-bottom:1.5rem}
.eco-banner h2{font-family:'Playfair Display',serif;font-size:1rem;color:rgba(255,255,255,.8);margin-bottom:.4rem}
.eco-banner .montant{font-family:'Playfair Display',serif;font-size:3.5rem;font-weight:900;color:#86efac;display:block}
.eco-banner .sous{font-size:.85rem;color:rgba(255,255,255,.7);margin-top:.3rem}
.liste-couper{display:flex;flex-direction:column;gap:.6rem}
.couper-item{display:flex;justify-content:space-between;align-items:center;background:#fef2f2;border-radius:10px;padding:.8rem 1rem;font-size:.85rem}
.couper-item .nom{font-weight:600;color:#dc2626}
.couper-item .prix{font-weight:700;color:#991b1b}
.cta{background:linear-gradient(135deg,var(--al),#FFF8EE);border-radius:var(--r);padding:1.8rem;text-align:center;margin-bottom:1.5rem}
.cta h3{font-family:'Playfair Display',serif;font-size:1.1rem;color:#633806;margin-bottom:.4rem}
.cta p{font-size:.86rem;color:var(--m);margin-bottom:1rem}
.cta-form{display:flex;gap:.5rem;max-width:360px;margin:0 auto;flex-wrap:wrap;justify-content:center}
.cta-form input{flex:1;min-width:150px;padding:.65rem 1rem;border-radius:50px;border:1px solid var(--b);font-size:.86rem;font-family:inherit}
.cta-form button{background:var(--a);color:white;border:none;padding:.65rem 1.3rem;border-radius:50px;font-weight:600;cursor:pointer;font-family:inherit;font-size:.86rem}
footer{background:var(--gd);color:rgba(255,255,255,.6);text-align:center;padding:1.5rem;font-size:.8rem;margin-top:2rem}
footer strong{color:white}
@media(max-width:640px){.hero{padding:2rem 1.2rem}.container{padding:1.5rem 1rem}.abo-item{grid-template-columns:1fr auto;gap:.5rem}.abo-btns{grid-column:1/-1}.abo-prix{display:none}}

/* Menu hamburger mobile */
.hamburger{display:none;flex-direction:column;gap:5px;cursor:pointer;background:none;border:none;padding:.3rem}
.hamburger span{display:block;width:24px;height:2px;background:var(--gd,#085041);border-radius:2px;transition:all .3s}
.mobile-menu{display:none;position:fixed;top:0;left:0;right:0;bottom:0;background:rgba(255,255,255,.98);z-index:999;flex-direction:column;align-items:center;justify-content:center;gap:1.5rem}
.mobile-menu.open{display:flex}
.mobile-menu a{font-family:'Playfair Display',serif;font-size:1.3rem;font-weight:700;color:#085041;text-decoration:none}
.mobile-menu .close-btn{position:absolute;top:1.2rem;right:1.5rem;background:none;border:none;font-size:1.8rem;cursor:pointer;color:#085041}
.mobile-menu .nav-cta{background:#1D9E75;color:white!important;padding:.5rem 1.4rem;border-radius:50px}
@media(max-width:768px){
  .hamburger{display:flex}
  nav .nav-links, nav > a:not(.logo), nav > div{display:none!important}
  nav li{display:none!important}
}
</style>

