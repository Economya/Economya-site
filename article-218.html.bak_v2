<style>
  *,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
  body{font-family:'DM Sans',sans-serif;background:#FAFAF8;color:#2C2C2A;line-height:1.7}
  nav{display:flex;justify-content:space-between;align-items:center;padding:.9rem 1.8rem;background:#fff;border-bottom:1px solid rgba(0,0,0,.08);position:sticky;top:0;z-index:99}
  .logo{font-family:'Playfair Display',serif;font-weight:900;font-size:1.3rem;color:#085041;text-decoration:none}
  .logo span{color:#EF9F27}
  .back{font-size:.82rem;color:#5F5E5A;text-decoration:none}
  .back:hover{color:#1D9E75}

  /* HERO — nuit marine → bleu saphir → turquoise */
  .hero{background:linear-gradient(135deg,#020C18 0%,#083060 32%,#1060B0 62%,#20A0D0 84%,#80E0F0 100%);padding:3.8rem 2rem 3.2rem;text-align:center;position:relative;overflow:hidden}
  .hero::before{content:'🛡️';position:absolute;font-size:14rem;opacity:.05;top:50%;left:50%;transform:translate(-50%,-50%);pointer-events:none}
  .hero-cat{font-size:.82rem;font-weight:500;color:rgba(255,255,255,.6);margin-bottom:.6rem;letter-spacing:.05em}
  .hero-cat strong{color:#fff}
  .hero h1{font-family:'Playfair Display',serif;font-size:clamp(1.8rem,4.5vw,2.7rem);font-weight:900;color:#fff;line-height:1.1;max-width:640px;margin:.3rem auto .9rem}
  .hero-badge{display:inline-block;background:linear-gradient(90deg,#80E0F0,#20A0D0);color:#020C18;font-size:.82rem;font-weight:700;padding:.35rem 1.1rem;border-radius:50px}
  .hero-meta{display:flex;justify-content:center;flex-wrap:wrap;gap:.55rem;margin-top:1.2rem}
  .hero-meta span{font-size:.73rem;color:rgba(255,255,255,.5);background:rgba(255,255,255,.09);padding:.2rem .75rem;border-radius:50px}

  article{max-width:700px;margin:0 auto;padding:2.5rem 1.5rem 5rem}
  article p{margin-bottom:1.3rem;font-size:.97rem;font-weight:300;line-height:1.75}
  h2{font-family:'Playfair Display',serif;font-size:1.2rem;font-weight:700;color:#083060;margin:2.2rem 0 .8rem}

  /* CONDITIONS ELIGIBILITE */
  .conditions{display:grid;grid-template-columns:1fr 1fr;gap:.7rem;margin:1.5rem 0}
  .cond{background:#fff;border:1px solid rgba(0,0,0,.08);border-radius:11px;padding:.85rem 1rem;display:flex;gap:.7rem;align-items:flex-start}
  .cond-ico{width:32px;height:32px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:.9rem;flex-shrink:0}
  .cond-ico.oui{background:linear-gradient(135deg,#065F46,#1D9E75);color:#fff}
  .cond-ico.non{background:linear-gradient(135deg,#7F1D1D,#B91C1C);color:#fff}
  .cond-text{font-size:.83rem;font-weight:300;color:#2C2C2A;line-height:1.5}
  .cond-text strong{display:block;font-weight:500;color:#083060;margin-bottom:.1rem}

  /* CALCUL ARE — visuel étapes */
  .calcul-are{background:#fff;border:1px solid rgba(0,0,0,.08);border-radius:13px;overflow:hidden;margin:1.5rem 0}
  .calcul-head{background:linear-gradient(90deg,#083060,#1060B0);padding:.8rem 1.2rem;color:#fff;font-family:'Playfair Display',serif;font-weight:700;font-size:.95rem}
  .calcul-step{display:grid;grid-template-columns:36px 1fr auto;gap:.7rem;align-items:center;padding:.7rem 1.1rem;border-bottom:1px solid rgba(0,0,0,.06)}
  .calcul-step:last-child{border-bottom:none;background:#EFF6FF}
  .calcul-num{width:36px;height:36px;border-radius:50%;background:linear-gradient(135deg,#083060,#1060B0);color:#80E0F0;font-family:'Playfair Display',serif;font-weight:900;font-size:.9rem;display:flex;align-items:center;justify-content:center;flex-shrink:0}
  .calcul-label{font-size:.84rem;font-weight:300;color:#2C2C2A}
  .calcul-label strong{display:block;font-weight:500;color:#083060;margin-bottom:.1rem}
  .calcul-result{font-weight:700;color:#1060B0;font-size:.88rem;white-space:nowrap;text-align:right}
  .calcul-result.final{color:#065F46;font-size:1rem}

  /* SIMULATION */
  .simul{background:linear-gradient(135deg,#020C18,#083060);border-radius:13px;padding:1.3rem 1.5rem;margin:1.5rem 0;color:#fff}
  .simul h3{font-family:'Playfair Display',serif;font-size:1rem;font-weight:700;color:#80E0F0;margin-bottom:.9rem}
  .simul-row{display:flex;justify-content:space-between;padding:.38rem 0;border-bottom:1px solid rgba(255,255,255,.07);font-size:.84rem}
  .simul-row:last-child{border-bottom:none;padding-top:.5rem;margin-top:.2rem}
  .simul-lab{font-weight:300;color:rgba(255,255,255,.8)}
  .simul-val{font-weight:600;color:#80E0F0;white-space:nowrap}
  .simul-lab.total{font-weight:600;color:#fff}
  .simul-val.total{font-size:1rem}
  .simul-val.green{color:#6EE7B7}

  /* DURÉE INDEMNISATION */
  .durees{display:grid;grid-template-columns:repeat(3,1fr);gap:.65rem;margin:1.5rem 0}
  .duree{background:#fff;border:1px solid rgba(0,0,0,.08);border-radius:11px;padding:.85rem .8rem;text-align:center}
  .duree-age{font-size:.72rem;font-weight:600;text-transform:uppercase;letter-spacing:.05em;color:#5F5E5A;margin-bottom:.3rem}
  .duree-val{font-family:'Playfair Display',serif;font-size:1.6rem;font-weight:900;color:#1060B0;line-height:1}
  .duree-unite{font-size:.72rem;color:#5F5E5A;font-weight:300;margin-top:.15rem}
  .duree-condition{font-size:.73rem;font-weight:300;color:#5F5E5A;margin-top:.3rem;line-height:1.35}

  /* DROITS MÉCONNUS */
  .droits{display:flex;flex-direction:column;gap:.5rem;margin:1.4rem 0}
  .droit{display:flex;gap:.75rem;align-items:flex-start;padding:.7rem 1rem;border-radius:10px;background:#fff;border:1px solid rgba(0,0,0,.07)}
  .droit-ico{font-size:1rem;flex-shrink:0;margin-top:.1rem}
  .droit-text{font-size:.83rem;font-weight:300;color:#2C2C2A;line-height:1.5}
  .droit-text strong{font-weight:500;color:#083060;display:block;margin-bottom:.1rem}

  .encadre{border-left:4px solid #1060B0;background:#EFF6FF;border-radius:0 10px 10px 0;padding:1rem 1.2rem;margin:1.5rem 0}
  .encadre strong{display:block;color:#083060;font-size:.9rem;margin-bottom:.3rem}
  .encadre p{font-size:.84rem;font-weight:300;color:#1060B0;margin:0;line-height:1.6}

  .conseil{background:linear-gradient(135deg,#020C18,#083060);border-radius:13px;padding:1.3rem 1.5rem;margin:2rem 0;color:#fff;border:1px solid rgba(128,224,240,.1)}
  .conseil strong{display:block;color:#80E0F0;font-weight:500;font-size:.93rem;margin-bottom:.4rem}
  .conseil p{font-size:.88rem;color:rgba(255,255,255,.8);font-weight:300;margin:0;line-height:1.65}

  footer{background:#085041;color:rgba(255,255,255,.6);text-align:center;padding:1.6rem;font-size:.8rem}
  footer strong{color:#fff}
  footer a{color:#EF9F27;text-decoration:none}
  @media(max-width:500px){.conditions{grid-template-columns:1fr}.durees{grid-template-columns:1fr 1fr}.calcul-step{grid-template-columns:32px 1fr}}

