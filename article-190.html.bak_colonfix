<!DOCTYPE html>
<html lang="fr">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Retraite : préparer sa retraite dès maintenant — Economya.fr</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;700;900&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet">
<style>
  *,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
  :root{
    --g:#1D9E75;--gl:#E1F5EE;--gd:#085041;--a:#EF9F27;--al:#FAEEDA;--ad:#633806;
    --t:#2C2C2A;--m:#5F5E5A;--bg:#FAFAF8;--w:#fff;--b:rgba(0,0,0,0.1);
    --sunset:#C04A00;--sunset-mid:#E8730A;--sunset-light:#FFF3E5;
    --gold:#D4A843;--sky:#4A9BB5;--coral:#E05050;
  }
  body{font-family:'DM Sans',sans-serif;background:var(--bg);color:var(--t);line-height:1.7}
  nav{display:flex;justify-content:space-between;align-items:center;padding:.9rem 1.8rem;background:var(--w);border-bottom:1px solid var(--b);position:sticky;top:0;z-index:99}
  .logo{font-family:'Playfair Display',serif;font-weight:900;font-size:1.3rem;color:var(--gd);text-decoration:none}
  .logo span{color:var(--a)}
  .back{font-size:.82rem;color:var(--m);text-decoration:none}
  .back:hover{color:var(--g)}

  .hero-art{
    background:linear-gradient(135deg,#1A0A00 0%,#C04A00 38%,#E8730A 68%,#F5C842 88%,#FFE8A0 100%);
    padding:3.5rem 2rem 3rem;text-align:center;position:relative;overflow:hidden
  }
  .hero-art::before{
    content:'🏖️';position:absolute;font-size:13rem;opacity:.06;
    top:50%;left:50%;transform:translate(jusqu'à -50%,jusqu'à -50%);pointer-events:none
  }
  .acat{font-size:.85rem;font-weight:500;color:rgba(255,255,255,.6);margin-bottom:.6rem;letter-spacing:.04em}
  .acat strong{color:#fff}
  .hero-art h1{
    font-family:'Playfair Display',serif;font-size:clamp(1.7rem,4vw,2.6rem);
    font-weight:900;line-height:1.1;color:#fff;max-width:620px;margin:0 auto .9rem
  }
  .abadge{
    display:inline-block;
    background:linear-gradient(90deg,#FFE8A0,var(--sky));
    color:#1A0A00;font-size:.82rem;font-weight:700;padding:.35rem 1rem;
    border-radius:50px;margin-top:.4rem
  }
  .meta{display:flex;justify-content:center;flex-wrap:wrap;gap:.6rem;margin-top:1.2rem}
  .meta span{font-size:.74rem;color:rgba(255,255,255,.55);background:rgba(255,255,255,.1);padding:.2rem .75rem;border-radius:50px}

  article{max-width:680px;margin:0 auto;padding:2.5rem 1.5rem 4rem}
  article p{margin-bottom:1.3rem;font-size:.97rem;font-weight:300}
  article h2{font-family:'Playfair Display',serif;font-size:1.2rem;font-weight:700;color:var(--sunset);margin:2rem 0 .7rem}

  /* Simulation retraite */
  .simulation{background:var(--w);border:1px solid var(--b);border-radius:13px;overflow:hidden;margin:1.5rem 0}
  .sim-head{background:linear-gradient(90deg,var(--sunset),var(--sunset-mid));padding:.8rem 1.1rem;color:#fff;font-family:'Playfair Display',serif;font-size:.95rem;font-weight:700}
  .sim-row{display:grid;grid-template-columns:1.4fr 1fr 1fr 1fr;font-size:.82rem;border-bottom:1px solid var(--b);align-items:center}
  .sim-row.header{background:var(--sunset-light);font-weight:600;font-size:.73rem;color:var(--sunset);text-transform:uppercase;letter-spacing:.04em}
  .sim-row:last-child{border-bottom:none;background:var(--sunset-light)}
  .sim-row:nth-child(even):not(.header):not(:last-child){background:#FAFAF8}
  .sim-cell{padding:.55rem .8rem;font-weight:300;color:var(--t)}
  .sim-cell.label{font-weight:500;color:var(--sunset)}
  .sim-cell.win{color:var(--gd);font-weight:600}
  .sim-cell.total{font-weight:700}

  /* Produits d'épargne retraite */
  .produits{display:flex;flex-direction:column;gap:.8rem;margin:1.5rem 0}
  .produit{border-radius:12px;overflow:hidden;border:1px solid rgba(192,74,0,.15);display:grid;grid-template-columns:80px 1fr}
  .produit-badge{background:linear-gradient(180deg,var(--sunset),var(--sunset-mid));color:#fff;display:flex;flex-direction:column;align-items:center;justify-content:center;padding:.8rem .5rem;text-align:center}
  .produit-nom-court{font-family:'Playfair Display',serif;font-size:1rem;font-weight:900;color:#FFE8A0;line-height:1.1}
  .produit-type{font-size:.58rem;font-weight:500;text-transform:uppercase;letter-spacing:.04em;color:rgba(255,255,255,.6);margin-top:.25rem}
  .produit-body{padding:.85rem 1rem;background:var(--w)}
  .produit-title{font-weight:500;font-size:.9rem;color:var(--sunset);margin-bottom:.2rem}
  .produit-desc{font-size:.83rem;font-weight:300;color:var(--m);line-height:1.55;margin-bottom:.4rem}
  .produit-tags{display:flex;flex-wrap:wrap;gap:.35rem}
  .ptag{font-size:.69rem;font-weight:500;padding:.1rem .5rem;border-radius:50px;background:var(--sunset-light);color:var(--sunset)}
  .ptag.green{background:var(--gl);color:var(--gd)}

  /* Règles d'or */
  .regles{display:flex;flex-direction:column;gap:0;border:1px solid var(--b);border-radius:12px;overflow:hidden;margin:1.5rem 0}
  .regle{display:grid;grid-template-columns:44px 1fr;border-bottom:1px solid var(--b)}
  .regle:last-child{border-bottom:none}
  .regle-num{background:linear-gradient(180deg,var(--sunset),var(--sunset-mid));color:#FFE8A0;font-family:'Playfair Display',serif;font-weight:900;font-size:1.1rem;display:flex;align-items:center;justify-content:center}
  .regle-body{padding:.75rem 1rem;background:var(--w)}
  .regle-title{font-weight:500;font-size:.88rem;color:var(--sunset);margin-bottom:.15rem}
  .regle-desc{font-size:.81rem;font-weight:300;color:var(--m);line-height:1.5}

  .conseil{
    background:linear-gradient(135deg,#1A0A00,#C04A00);
    border-radius:12px;padding:1.2rem 1.4rem;margin:1.8rem 0;color:#fff;
    border:1px solid rgba(212,168,67,.2)
  }
  .conseil strong{display:block;color:#FFE8A0;font-weight:500;font-size:.92rem;margin-bottom:.4rem}
  .conseil p{font-size:.88rem;color:rgba(255,255,255,.82);font-weight:300;margin:0;line-height:1.65}

  footer{background:var(--gd);color:rgba(255,255,255,0.6);text-align:center;padding:1.6rem;font-size:.8rem}
  footer strong{color:white}
  footer a{color:var(--a);text-decoration:none}
  @media(max-width:500px){.sim-row{grid-template-columns:1.2fr 1fr}.sim-cell:nth-child(3),.sim-cell:nth-child(4){display:none}}

/* Menu hamburger mobile */
.hamburger{display:none;flex-direction:column;gap:5px;cursor:pointer;background:none;border:none;padding:.3rem}
.hamburger span{display:block;width:24px;height:2px;background:var(--gd,#085041);border-radius:2px;transition:all .3s}
.mobile-menu{display:none;position:fixed;top:0;left:0;right:0;bottom:0;background:rgba(255,255,255,.98);z-index:999;flex-direction:column;align-items:center;justify-content:center;gap:1.5rem}
.mobile-menu.open{display:flex}
.mobile-menu a{font-family:'Playfair Display',serif;font-size:1.3rem;font-weight:700;color:#085041;text-decoration:none}
.mobile-menu .close-btn{position:absolute;top:1.2rem;right:1.5rem;background:none;border:none;font-size:1.8rem;cursor:pointer;color:#085041}
.mobile-menu .nav-cta{background:#1D9E75;color:white!important;padding:.5rem 1.4rem;border-radius:50px}
@media(max-width:768px){
  .hamburger{display:flex}
  nav .nav-links,nav > a:not(.logo),nav > div:not(.mobile-menu){display:none!important}
  nav li{display:none!important}
}
