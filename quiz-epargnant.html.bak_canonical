<script>
const questions = document.querySelectorAll('.question-card');
const totalQ = questions.length;
let currentQ = 0;
let totalScore = 0;
let selectedScore = null;

function updateProgress() {
  const pct = (currentQ / totalQ) * 100;
  document.getElementById('progress').style.width = pct + '%';
  document.getElementById('progress-text').textContent = `Question ${currentQ + 1} sur ${totalQ}`;
}

questions.forEach((card, idx) => {
  const options = card.querySelectorAll('.option');
  const btn = card.querySelector('.btn-next');

  options.forEach(opt => {
    opt.addEventListener('click', () => {
      options.forEach(o => o.classList.remove('selected'));
      opt.classList.add('selected');
      selectedScore = +opt.dataset.score;
      btn.style.display = 'block';
    });
  });

  btn.addEventListener('click', () => {
    if(selectedScore === null) return;
    totalScore += selectedScore;
    card.classList.remove('active');
    selectedScore = null;

    if(idx < totalQ - 1) {
      currentQ++;
      questions[currentQ].classList.add('active');
      updateProgress();
    } else {
      showResult();
    }
  });
});

function showResult() {
  document.getElementById('progress').style.width = '100%';
  document.getElementById('progress-text').textContent = 'Quiz terminé !';

  const max = totalQ * 3;
  const pct = totalScore / max;

  let resultId;
  if(pct < 0.25) resultId = 'result-depensier';
  else if(pct < 0.5) resultId = 'result-debutant';
  else if(pct < 0.75) resultId = 'result-organise';
  else resultId = 'result-expert';

  document.getElementById(resultId).classList.add('active');
  document.getElementById('cta-block').style.display = 'block';
  document.getElementById(resultId).scrollIntoView({behavior:'smooth', block:'start'});
}

function retry() {
  totalScore = 0;
  currentQ = 0;
  selectedScore = null;
  questions.forEach((card, idx) => {
    card.classList.remove('active');
    card.querySelectorAll('.option').forEach(o => o.classList.remove('selected'));
    card.querySelector('.btn-next').style.display = 'none';
  });
  document.querySelectorAll('.result-card').forEach(r => r.classList.remove('active'));
  document.getElementById('cta-block').style.display = 'none';
  questions[0].classList.add('active');
  updateProgress();
  window.scrollTo({top:0, behavior:'smooth'});
}

updateProgress();
</script>
