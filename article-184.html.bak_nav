<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;700;900&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet">
<style>
  *,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
  : root{
    --g:#1D9E75;--gl:#E1F5EE;--gd:#085041;--a:#EF9F27;--al:#FAEEDA;--ad:#633806;
    --t:#2C2C2A;--m:#5F5E5A;--bg:#FAFAF8;--w:#fff;--b:rgba(0,0,0,0.1);
    --purple:#1A0035;--purple-mid:#5B0EA6;--purple-light:#F0E6FF;
    --neon:#E040FB;--electric:#00E5FF;--gold:#FFD700;
  }
  body{font-family:'DM Sans',sans-serif;background:var(--bg);color:var(--t);line-height:1.7}
  nav{display:flex;justify-content:space-between;align-items:center;padding:.9rem 1.8rem;background:var(--w);border-bottom:1px solid var(--b);position:sticky;top:0;z-index:99}
  .logo{font-family:'Playfair Display',serif;font-weight:900;font-size:1.3rem;color:var(--gd);text-decoration:none}
  .logo span{color:var(--a)}
  .back{font-size:.82rem;color:var(--m);text-decoration:none}
  .back:hover{color:var(--g)}

  .hero-art{
    background:linear-gradient(135deg,#060010 0%,#1A0035 30%,#5B0EA6 60%,#E040FB 82%,#FFD700 100%);
    padding:3.5rem 2rem 3rem;text-align:center;position:relative;overflow:hidden
  }
  .hero-art::before{
    content:'🎵';position:absolute;font-size:13rem;opacity:.06;
    top:50%;left:50%;transform:translate(jusqu'à -50%,jusqu'à -50%);pointer-events:none
  }
  .acat{font-size:.85rem;font-weight:500;color:rgba(255,255,255,.6);margin-bottom:.6rem;letter-spacing:.04em}
  .acat strong{color:#fff}
  .hero-art h1{
    font-family:'Playfair Display',serif;font-size:clamp(1.7rem,4vw,2.6rem);
    font-weight:900;line-height:1.1;color:#fff;max-width:620px;margin:0 auto .9rem
  }
  .abadge{
    display:inline-block;
    background:linear-gradient(90deg,var(--gold),var(--electric));
    color:#060010;font-size:.82rem;font-weight:700;padding:.35rem 1rem;
    border-radius:50px;margin-top:.4rem
  }
  .meta{display:flex;justify-content:center;flex-wrap:wrap;gap:.6rem;margin-top:1.2rem}
  .meta span{font-size:.74rem;color:rgba(255,255,255,.55);background:rgba(255,255,255,.1);padding:.2rem .75rem;border-radius:50px}

  article{max-width:680px;margin:0 auto;padding:2.5rem 1.5rem 4rem}
  article p{margin-bottom:1.3rem;font-size:.97rem;font-weight:300}
  article h2{font-family:'Playfair Display',serif;font-size:1.2rem;font-weight:700;color:var(--purple-mid);margin:2rem 0 .7rem}

  /* Astuces concerts */
  .astuces{display:flex;flex-direction:column;gap:.7rem;margin:1.5rem 0}
  .astuce{background:var(--w);border:1px solid var(--b);border-radius:12px;overflow:hidden;display:grid;grid-template-columns:60px 1fr}
  .astuce-icon{background:linear-gradient(180deg,var(--purple),var(--purple-mid));display:flex;align-items:center;justify-content:center;font-size:1.6rem}
  .astuce-body{padding:.85rem 1rem}
  .astuce-title{font-weight:500;font-size:.9rem;color:var(--purple-mid);margin-bottom:.2rem}
  .astuce-desc{font-size:.83rem;font-weight:300;color:var(--m);line-height:1.55}
  .astuce-gain{display:inline-block;margin-top:.35rem;background:var(--purple-light);color:var(--purple-mid);font-size:.72rem;font-weight:600;padding:.1rem .5rem;border-radius:50px}

  /* Festivals comparés */
  .festivals{display:grid;grid-template-columns:1fr 1fr;gap:.7rem;margin:1.5rem 0}
  .festival{border-radius:12px;overflow:hidden;border:1px solid rgba(91,14,166,.15)}
  .festival-head{padding:.65rem .9rem;color:#fff;font-weight:600;font-size:.85rem;display:flex;justify-content:space-between;align-items:center}
  .festival-head.payant{background:linear-gradient(90deg,#4A0080,#7B1FA2)}
  .festival-head.gratuit{background:linear-gradient(90deg,#1B5E20,#2E7D32)}
  .festival-prix{font-size:.75rem;font-weight:700;background:rgba(255,255,255,.2);padding:.1rem .45rem;border-radius:50px}
  .festival-body{background:var(--w);padding:.75rem .9rem;font-size:.82rem;font-weight:300;color:var(--m);line-height:1.5}

  /* Budget festival malin */
  .budget{background:linear-gradient(135deg,#1A0035,#5B0EA6);border-radius:13px;padding:1.2rem 1.4rem;margin:1.5rem 0;color:#fff}
  .budget h3{font-family:'Playfair Display',serif;font-weight:700;font-size:1rem;color:var(--gold);margin-bottom:.9rem}
  .budget-row{display:flex;justify-content:space-between;padding:.4rem 0;border-bottom:1px solid rgba(255,255,255,.08);font-size:.85rem}
  .budget-row:last-child{border-bottom:none;padding-top:.6rem;margin-top:.3rem}
  .budget-nom{font-weight:300;color:rgba(255,255,255,.85)}
  .budget-val{font-weight:600;color:var(--gold);white-space:nowrap}
  .budget-nom.total{font-weight:600;color:#fff}
  .budget-val.total{font-size:.95rem}

  .conseil{
    background:linear-gradient(135deg,#060010,#1A0035);
    border-radius:12px;padding:1.2rem 1.4rem;margin:1.8rem 0;color:#fff;
    border:1px solid rgba(224,64,251,.15)
  }
  .conseil strong{display:block;color:var(--gold);font-weight:500;font-size:.92rem;margin-bottom:.4rem}
  .conseil p{font-size:.88rem;color:rgba(255,255,255,.82);font-weight:300;margin:0;line-height:1.65}

  footer{background:var(--gd);color:rgba(255,255,255,0.6);text-align:center;padding:1.6rem;font-size:.8rem}
  footer strong{color:white}
  footer a{color:var(--a);text-decoration:none}
  @media(max-width:500px){.festivals{grid-template-columns:1fr}}

/* Menu hamburger mobile */
.hamburger{display:none;flex-direction:column;gap:5px;cursor:pointer;background:none;border:none;padding:.3rem}
.hamburger span{display:block;width:24px;height:2px;background:var(--gd,#085041);border-radius:2px;transition:all .3s}
