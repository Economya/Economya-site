  {cat:'🚿 Hygiène',q:'Quel gel douche est le moins cher au litre ?',a:{icon:'🚿',name:'Dove Original 250ml',detail:'Gel douche • Grande marque',price:'3,50€',sub:'250ml',val:350},b:{icon:'🚿',name:'Marque distributeur 1L',detail:'Gel douche • Même composition',price:'1,20€',sub:'1 litre',val:120,badge:'✅ 7x moins cher/L'},correct:'b',economy:46,explication:'La marque distributeur coûte 7 fois moins cher au litre. 46€/an économisés !'},
