<!DOCTYPE html>
<html lang="fr">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Le Bon Deal — Economya.fr</title>
<meta name="description" content="Comparez 2 offres et choisissez la moins chère en moins de 10 secondes ! Le jeu de finance du quotidien par Economya.fr">
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@900&family=DM+Sans:wght@400;600;700&display=swap" rel="stylesheet">
<style>
*{box-sizing:border-box;margin:0;padding:0}
:root{--g:#1D9E75;--gd:#085041;--a:#EF9F27;--bg:#FAFAF8;--t:#2C2C2A;--m:#5F5E5A;--w:#fff;--b:rgba(0,0,0,0.08)}
body{font-family:'DM Sans',sans-serif;background:var(--bg);color:var(--t);min-height:100vh}
nav{display:flex;justify-content:space-between;align-items:center;padding:.9rem 1.8rem;background:var(--w);border-bottom:1px solid var(--b);position:sticky;top:0;z-index:99}
.logo{font-family:'Playfair Display',serif;font-weight:900;font-size:1.3rem;color:var(--gd);text-decoration:none}
.logo span{color:var(--a)}
.nav-back{text-decoration:none;color:var(--m);font-size:.82rem}
.hero{background:linear-gradient(135deg,#1a0533,#7c2d92,#a855f7);color:white;padding:2.5rem 2rem;text-align:center}
.hero-badge{display:inline-block;background:rgba(255,255,255,.15);color:white;padding:.3rem .9rem;border-radius:50px;font-size:.75rem;font-weight:700;text-transform:uppercase;letter-spacing:.08em;margin-bottom:.8rem}
.hero h1{font-family:'Playfair Display',serif;font-size:clamp(2rem,6vw,3rem);font-weight:900;margin-bottom:.4rem}
.hero h1 em{color:var(--a);font-style:normal}
.hero p{color:rgba(255,255,255,.75);font-size:.95rem}
.stats-bar{display:flex;justify-content:center;gap:2rem;padding:1rem;background:var(--w);border-bottom:1px solid var(--b);flex-wrap:wrap}
.stat-item{text-align:center}
.stat-val{font-family:'Playfair Display',serif;font-size:1.5rem;font-weight:900;color:var(--g);display:block}
.stat-lbl{font-size:.7rem;color:var(--m);text-transform:uppercase;letter-spacing:.05em}
.container{max-width:700px;margin:0 auto;padding:2rem 1.5rem}
.timer-wrap{text-align:center;margin-bottom:1rem}
.timer-bar{height:10px;background:var(--b);border-radius:50px;overflow:hidden;margin-bottom:.4rem}
.timer-fill{height:100%;background:linear-gradient(90deg,var(--g),var(--a));border-radius:50px;transition:width .1s linear}
.timer-text{font-family:'Playfair Display',serif;font-size:2rem;font-weight:900;color:var(--gd)}
.timer-text.urgent{color:#ef4444;animation:pulse .5s infinite}
@keyframes pulse{0%,100%{transform:scale(1)}50%{transform:scale(1.1)}}
.question-badge{display:inline-block;background:rgba(124,45,146,.1);color:#7c2d92;padding:.3rem .8rem;border-radius:50px;font-size:.75rem;font-weight:700;margin-bottom:.8rem}
.question-text{font-family:'Playfair Display',serif;font-size:1.2rem;font-weight:700;color:var(--gd);margin-bottom:1.5rem;line-height:1.4;text-align:center}
.deals{display:grid;grid-template-columns:1fr 1fr;gap:1rem;margin-bottom:1.5rem}
.deal-card{background:var(--w);border:2px solid var(--b);border-radius:16px;padding:1.5rem;text-align:center;cursor:pointer;transition:all .2s;position:relative}
.deal-card:hover{border-color:var(--g);transform:translateY(-2px);box-shadow:0 8px 24px rgba(0,0,0,.08)}
.deal-card.selected-correct{border-color:var(--g);background:#E1F5EE}
.deal-card.selected-wrong{border-color:#ef4444;background:#fef2f2}
.deal-card.reveal-correct{border-color:var(--g);background:#E1F5EE}
.deal-icon{font-size:2.5rem;margin-bottom:.6rem;display:block}
.deal-name{font-weight:700;font-size:.95rem;color:var(--t);margin-bottom:.3rem}
.deal-detail{font-size:.8rem;color:var(--m);margin-bottom:.8rem;line-height:1.4}
.deal-price{font-family:'Playfair Display',serif;font-size:1.8rem;font-weight:900;color:var(--gd)}
.deal-price-sub{font-size:.75rem;color:var(--m)}
.deal-badge{position:absolute;top:-8px;right:-8px;background:var(--a);color:white;font-size:.65rem;font-weight:700;padding:.2rem .5rem;border-radius:50px}
.vs{display:flex;align-items:center;justify-content:center}
.vs span{font-family:'Playfair Display',serif;font-size:1.5rem;font-weight:900;color:var(--m)}
.feedback{border-radius:16px;padding:1.2rem 1.5rem;margin-bottom:1rem;display:none}
.feedback.correct{background:#E1F5EE;border:1px solid var(--g)}
.feedback.wrong{background:#fef2f2;border:1px solid #ef4444}
.feedback h3{font-weight:700;margin-bottom:.3rem;font-size:.95rem}
.feedback p{font-size:.85rem;color:var(--m);line-height:1.5}
.feedback .economy{font-weight:700;color:var(--g)}
.score-display{background:var(--w);border-radius:16px;border:1px solid var(--b);padding:1.2rem;display:flex;justify-content:space-between;align-items:center;margin-bottom:1rem;flex-wrap:wrap;gap:.5rem}
.score-item{text-align:center}
.score-val{font-family:'Playfair Display',serif;font-size:1.4rem;font-weight:900;color:var(--g)}
.score-lbl{font-size:.7rem;color:var(--m);text-transform:uppercase}
.results{background:linear-gradient(135deg,var(--gd),#0F6E56);border-radius:16px;padding:2rem;text-align:center;color:white;display:none}
.results h2{font-family:'Playfair Display',serif;font-size:1.8rem;font-weight:900;margin-bottom:.5rem}
.results p{color:rgba(255,255,255,.75);margin-bottom:1.2rem}
.results-grid{display:grid;grid-template-columns:1fr 1fr 1fr;gap:1rem;margin:1.2rem 0}
.res-item{background:rgba(255,255,255,.1);border-radius:12px;padding:1rem}
.res-val{font-family:'Playfair Display',serif;font-size:1.5rem;font-weight:900;color:var(--a);display:block}
.res-lbl{font-size:.72rem;color:rgba(255,255,255,.6)}
.btn{padding:.7rem 1.8rem;border-radius:50px;font-weight:700;font-size:.9rem;cursor:pointer;font-family:inherit;border:none}
.btn-primary{background:linear-gradient(135deg,var(--gd),var(--g));color:white;width:100%}
.btn-secondary{background:rgba(255,255,255,.15);color:white}
@media(max-width:480px){.deals{grid-template-columns:1fr}.vs{display:none}}

/* Menu hamburger mobile */
.hamburger{display:none;flex-direction:column;gap:5px;cursor:pointer;background:none;border:none;padding:.3rem}
.hamburger span{display:block;width:24px;height:2px;background:var(--gd,#085041);border-radius:2px;transition:all .3s}
.mobile-menu{display:none;position:fixed;top:0;left:0;right:0;bottom:0;background:rgba(255,255,255,.98);z-index:999;flex-direction:column;align-items:center;justify-content:center;gap:1.5rem}
.mobile-menu.open{display:flex}
.mobile-menu a{font-family:'Playfair Display',serif;font-size:1.3rem;font-weight:700;color:#085041;text-decoration:none}
.mobile-menu .close-btn{position:absolute;top:1.2rem;right:1.5rem;background:none;border:none;font-size:1.8rem;cursor:pointer;color:#085041}
.mobile-menu .nav-cta{background:#1D9E75;color:white!important;padding:.5rem 1.4rem;border-radius:50px}
@media(max-width:768px){
  .hamburger{display:flex}
  nav .nav-links, nav > a:not(.logo), nav > div{display:none!important}
  nav li{display:none!important}
}
</style>
<link rel="canonical" href="https://economya.fr/le-bon-deal.html" />
</head>
<body>
<nav>
  <a class="logo" href="index.html">Econom<span>ya</span>.fr</a>
  <a class="nav-back" href="jeux.html">← Jeux</a>

<!-- Menu hamburger mobile -->

<button class="hamburger" onclick="toggleMenu()" aria-label="Menu"><span></span><span></span><span></span></button></nav><div class="mobile-menu" id="mobileMenu"><button class="close-btn" onclick="toggleMenu()">X</button><a href="index.html">Accueil</a><a href="jeux.html">Jeux</a><a href="outils-gratuits.html">Outils gratuits</a><a href="comparateurs.html">Comparateurs</a><a href="a-propos.html">A propos</a><a href="recherche.html">Rechercher</a></div>
<div class="hero">
  <div class="hero-badge">🎮 Jeu Exclusif</div>
  <h1>Le <em>Bon Deal</em></h1>
  <p>Choisissez l'offre la moins chère en moins de 10 secondes !</p>
</div>
<div class="stats-bar">
  <div class="stat-item"><span class="stat-val" id="stat-score">0</span><span class="stat-lbl">Score</span></div>
  <div class="stat-item"><span class="stat-val" id="stat-streak">0🔥</span><span class="stat-lbl">Série</span></div>
  <div class="stat-item"><span class="stat-val" id="stat-best">0</span><span class="stat-lbl">Meilleur</span></div>
  <div class="stat-item"><span class="stat-val" id="stat-economy">0€</span><span class="stat-lbl">Économisé</span></div>
</div>
<div class="container">
  <div id="game-area">
    <div class="timer-wrap">
      <div class="timer-bar"><div class="timer-fill" id="timer-fill" style="width:100%"></div></div>
      <div class="timer-text" id="timer-text">10</div>
    </div>
    <div style="text-align:center">
      <div class="question-badge" id="q-badge">Question 1/10</div>
      <div class="question-text" id="q-text">Chargement...</div>
    </div>
    <div class="deals" id="deals-container">
      <div class="deal-card" id="deal-a" onclick="selectDeal('a')">
        <span class="deal-icon" id="deal-a-icon">💡</span>
        <div class="deal-name" id="deal-a-name">—</div>
        <div class="deal-detail" id="deal-a-detail">—</div>
        <div class="deal-price" id="deal-a-price">—</div>
        <div class="deal-price-sub" id="deal-a-sub">—</div>
      </div>
      <div class="vs"><span>VS</span></div>
      <div class="deal-card" id="deal-b" onclick="selectDeal('b')">
        <span class="deal-icon" id="deal-b-icon">💡</span>
        <div class="deal-name" id="deal-b-name">—</div>
        <div class="deal-detail" id="deal-b-detail">—</div>
        <div class="deal-price" id="deal-b-price">—</div>
        <div class="deal-price-sub" id="deal-b-sub">—</div>
      </div>
    </div>
    <div class="feedback" id="feedback">
      <h3 id="fb-title"></h3>
      <p id="fb-text"></p>
    </div>
    <div class="score-display">
      <div class="score-item"><span class="score-val" id="disp-score">0</span><span class="score-lbl">Points</span></div>
      <div class="score-item"><span class="score-val" id="disp-q">1/10</span><span class="score-lbl">Question</span></div>
      <div class="score-item"><span class="score-val" id="disp-streak">0🔥</span><span class="score-lbl">Série</span></div>
    </div>
  </div>
  <div class="results" id="results">
    <div style="font-size:3rem;margin-bottom:.5rem" id="res-emoji">🏆</div>
    <h2 id="res-title">Résultat</h2>
    <p id="res-subtitle">—</p>
    <div class="results-grid">
      <div class="res-item"><span class="res-val" id="res-score">0</span><span class="res-lbl">Score</span></div>
      <div class="res-item"><span class="res-val" id="res-correct">0/10</span><span class="res-lbl">Bonnes réponses</span></div>
      <div class="res-item"><span class="res-val" id="res-economy">0€</span><span class="res-lbl">Économies potentielles</span></div>
    </div>
    <button class="btn btn-secondary" onclick="restartGame()" style="margin-top:.5rem">🔄 Rejouer</button>
  </div>
</div>
<script>
const ALL_QUESTIONS = [
  {cat:'📱 Téléphonie',q:'Quel forfait mobile est le moins cher pour 50 Go ?',a:{icon:'📱',name:'Orange',detail:'50 Go • Appels illimités • 4G+',price:'19,99€',sub:'/mois',val:1999},b:{icon:'📱',name:'Prixtel',detail:'50 Go • Appels illimités • 5G',price:'6,99€',sub:'/mois',val:699,badge:'✅ Moins cher'},correct:'b',economy:156,explication:'Prixtel propose le même service 13€/mois moins cher. Économie annuelle : 156€ !'},
  {cat:'🏦 Banque',q:'Quelle banque est la moins chère pour un compte courant ?',a:{icon:'🏛️',name:'Crédit Agricole',detail:'Compte courant • Carte Visa • Agences',price:'7,50€',sub:'/mois',val:750},b:{icon:'💚',name:'Boursobank',detail:'Compte courant • Carte Visa • 0 frais',price:'0€',sub:'/mois',val:0,badge:'✅ Gratuit'},correct:'b',economy:90,explication:'Boursobank est 100% gratuite. Économie vs banque traditionnelle : 90€/an !'},
  {cat:'🛒 Courses',q:'Où est-il moins cher de faire ses courses ?',a:{icon:'🟡',name:'Lidl',detail:'Panier 50 articles identiques',price:'87€',sub:'le panier',val:87,badge:'✅ Moins cher'},b:{icon:'🔵',name:'Carrefour',detail:'Panier 50 articles identiques',price:'112€',sub:'le panier',val:112},correct:'a',economy:300,explication:'Lidl est 22% moins cher. Économie mensuelle : 25€, soit 300€/an !'},
  {cat:'💊 Santé',q:'Quelle option est moins chère pour du paracétamol 1g ?',a:{icon:'💊',name:'Doliprane 1g',detail:'16 comprimés • Grande marque',price:'3,20€',sub:'la boîte',val:320},b:{icon:'💊',name:'Paracétamol générique',detail:'16 comprimés • Même principe actif',price:'1,10€',sub:'la boîte',val:110,badge:'✅ Identique'},correct:'b',economy:42,explication:'Le générique contient exactement le même principe actif. 3x moins cher !'},
  {cat:'📺 Streaming',q:'Quelle offre de streaming est la moins chère ?',a:{icon:'🔴',name:'Netflix Standard solo',detail:'2 écrans HD • 1 compte',price:'13,49€',sub:'/mois',val:1349},b:{icon:'🔴',name:'Netflix partagé',detail:'2 écrans HD • Partagé via Sharesub',price:'6,75€',sub:'/mois partagé',val:675,badge:'✅ Partagé'},correct:'b',economy:81,explication:'Partager son compte Netflix divise la facture par 2. Économie : 81€/an !'},
  {cat:'⚡ Énergie',q:'Quelle ampoule est la moins chère à utiliser ?',a:{icon:'💡',name:'Ampoule halogène',detail:'60W • Durée de vie : 1 000h',price:'1,50€',sub:'+ consommation élevée',val:150},b:{icon:'💡',name:'Ampoule LED',detail:'60W équivalent • Durée : 25 000h',price:'0,20€',sub:'+ -85% consommation',val:20,badge:'✅ -85% énergie'},correct:'b',economy:80,explication:'Une LED consomme 8W contre 60W halogène. Économie sur la durée : 80€ !'},
  {cat:'🚗 Assurance',q:'Quelle assurance auto est la moins chère ?',a:{icon:'🚗',name:'Direct Assurance',detail:'Tous risques • Véhicule 5 ans',price:'42€',sub:'/mois',val:4200},b:{icon:'🚗',name:'Sans comparaison',detail:'Tous risques • Sans négociation',price:'68€',sub:'/mois',val:6800},correct:'a',economy:312,explication:'Comparer son assurance auto économise 26€/mois en moyenne, soit 312€/an !'},
  {cat:'☕ Café',q:'Quelle option de café est la moins chère ?',a:{icon:'☕',name:'Capsule Nespresso',detail:'1 capsule • 1 café par jour',price:'0,45€',sub:'par café',val:45},b:{icon:'☕',name:'Café moulu',detail:'Cafetière filtre • 1 café/jour',price:'0,08€',sub:'par café',val:8,badge:'✅ 6x moins cher'},correct:'b',economy:135,explication:'Le café moulu est 6 fois moins cher que les capsules. Économie annuelle : 135€ !'},
  {cat:'📱 Internet',q:'Quel forfait internet est le moins cher ?',a:{icon:'🌐',name:'Freebox Revolution',detail:'Fibre 1 Gbit/s • TV incluse',price:'29,99€',sub:'/mois',val:2999,badge:'✅ Moins cher'},b:{icon:'🌐',name:'Orange Livebox',detail:'Fibre 1 Gbit/s • TV incluse',price:'49,99€',sub:'/mois',val:4999},correct:'a',economy:240,explication:'Free propose le même débit pour 20€/mois de moins. Économie : 240€/an !'},
  {cat:'🏠 Logement',q:'Quelle solution économise le plus sur le loyer ?',a:{icon:'🏠',name:'Appartement T2 seul',detail:'45m² • Paris 15ème',price:'1 450€',sub:'/mois',val:1450},b:{icon:'🏠',name:'Colocation T4',detail:'Chambre 18m² • Paris 15ème',price:'750€',sub:'/mois',val:750,badge:'✅ -48%'},correct:'b',economy:8400,explication:'La colocation divise votre loyer par 2. Économie annuelle : 8 400€ !'},
  {cat:'🧴 Beauté',q:'Quelle crème hydratante est la moins chère ?',a:{icon:'🧴',name:'Nivea Essentiel',detail:'200ml • Hydratation 24h',price:'4,50€',sub:'le tube',val:450,badge:'✅ Moins cher'},b:{icon:'✨',name:'La Roche-Posay',detail:'200ml • Hydratation 24h',price:'18,90€',sub:'le tube',val:1890},correct:'a',economy:174,explication:'Nivea et La Roche-Posay ont des formules similaires. Économie : 14,40€/tube, 174€/an !'},
  {cat:'🚌 Transport',q:'Quel transport est le moins cher Paris-Lyon ?',a:{icon:'🚌',name:'Bus Flixbus',detail:'Paris-Lyon • 4h de trajet',price:'9€',sub:'le trajet',val:900,badge:'✅ Moins cher'},b:{icon:'🚄',name:'TGV plein tarif',detail:'Paris-Lyon • 2h de trajet',price:'79€',sub:'le trajet',val:7900},correct:'a',economy:280,explication:'Le bus coûte 8x moins cher. Sur 4 allers-retours/an : 280€ économisés !'},
  {cat:'🍕 Alimentation',q:'Quel déjeuner est le moins cher au bureau ?',a:{icon:'🍱',name:'Gamelle maison',detail:'Repas préparé la veille',price:'3€',sub:'par repas',val:300,badge:'✅ Moins cher'},b:{icon:'🍔',name:'Restaurant rapide',detail:'Menu du midi',price:'12€',sub:'par repas',val:1200},correct:'a',economy:2340,explication:'Gamelle maison vs resto : 9€ économisés par repas × 5j × 52 sem = 2 340€/an !'},
  {cat:'💻 Tech',q:'Où acheter un iPhone reconditionné moins cher ?',a:{icon:'📱',name:'Apple Store neuf',detail:'iPhone 14 • Neuf • Garantie 1 an',price:'879€',sub:'',val:87900},b:{icon:'♻️',name:'Back Market Grade A',detail:'iPhone 14 • Reconditionné • Garantie 1 an',price:'520€',sub:'',val:52000,badge:'✅ -41%'},correct:'b',economy:359,explication:'Le reconditionné Grade A est indiscernable du neuf pour 359€ de moins !'},
  {cat:'🎬 Loisirs',q:'Quelle option cinéma est la moins chère ?',a:{icon:'🎬',name:'Séance plein tarif',detail:'1 séance UGC • Prix normal',price:'13,50€',sub:'par séance',val:1350},b:{icon:'🎬',name:'UGC Illimité',detail:'Illimité • 2+ séances/mois',price:'23€',sub:'/mois illimité',val:2300,badge:'✅ Dès 2 séances'},correct:'b',economy:216,explication:'UGC Illimité à 23€/mois = illimité. Dès 2 séances/mois vous êtes gagnant. 216€/an !'},
  {cat:'🧹 Maison',q:'Quel produit ménager est le moins cher ?',a:{icon:'🧹',name:'Mr Propre multi-surfaces',detail:'750ml • Nettoyage cuisine/salle de bain',price:'3,20€',sub:'le flacon',val:320},b:{icon:'🍋',name:'Vinaigre blanc',detail:'1 litre • Multi-surfaces universel',price:'0,65€',sub:'le litre',val:65,badge:'✅ 5x moins cher'},correct:'b',economy:62,explication:'Le vinaigre blanc remplace la plupart des produits ménagers pour 5x moins cher !'},
  {cat:'📚 Culture',q:'Où lire des livres pour moins cher ?',a:{icon:'📖',name:'Achat en librairie',detail:'Roman récent • Prix neuf',price:'21€',sub:'le livre',val:2100},b:{icon:'🏛️',name:'Médiathèque municipale',detail:'Même livre • Prêt gratuit',price:'0€',sub:'gratuit',val:0,badge:'✅ Gratuit'},correct:'b',economy:252,explication:'La médiathèque est gratuite ou quasi-gratuite. 12 livres/an = 252€ économisés !'},
  {cat:'✈️ Voyage',q:'Quelle option vol est la moins chère ?',a:{icon:'✈️',name:'Air France plein tarif',detail:'Paris-Barcelone • Aller simple',price:'189€',sub:'le vol',val:18900},b:{icon:'🟠',name:'Vueling / Volotea',detail:'Paris-Barcelone • Aller simple',price:'39€',sub:'le vol',val:3900,badge:'✅ -79%'},correct:'b',economy:300,explication:'Les compagnies low-cost proposent les mêmes trajets 5x moins cher. 300€ économisés/voyage !'},
  {cat:'🐕 Animaux',q:'Quel aliment pour chien est le meilleur rapport qualité/prix ?',a:{icon:'🐕',name:'Royal Canin premium',detail:'Croquettes 10kg • Grande marque',price:'89€',sub:'le sac 10kg',val:8900},b:{icon:'🐕',name:'Purina Pro Plan',detail:'Croquettes 10kg • Qualité équivalente',price:'54€',sub:'le sac 10kg',val:5400,badge:'✅ Équivalent'},correct:'b',economy:140,explication:'Purina Pro Plan a une composition similaire pour 35€ moins cher par sac. 140€/an économisés !'},
  {cat:'💇 Coiffure',q:'Quelle option est la moins chère pour une coupe homme ?',a:{icon:'💇',name:'Coiffeur en salon',detail:'Coupe homme • Centre-ville',price:'25€',sub:'la coupe',val:2500},b:{icon:'✂️',name:'École de coiffure',detail:'Coupe homme • Élèves supervisés',price:'8€',sub:'la coupe',val:800,badge:'✅ -68%'},correct:'b',economy:204,explication:'Les écoles de coiffure proposent des coupes de qualité à -70%. 204€/an économisés !'},
