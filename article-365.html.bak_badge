p{margin-bottom:1rem;font-size:.95rem}

/* DÉCISION */
.decisions{display:flex;flex-direction:column;gap:.85rem;margin:1.5rem 0}
.decision{background:var(--w);border:1px solid var(--b);border-radius:var(--r);padding:1.1rem 1.3rem}
.decision.gratuit{border-left:4px solid var(--g)}
.decision.payer{border-left:4px solid var(--blue)}
.decision h3{font-size:.92rem;font-weight:700;margin-bottom:.3rem;display:flex;align-items:center;gap:.5rem}
.decision.gratuit h3{color:var(--gd)}
.decision.payer h3{color:var(--blue)}
.decision p{font-size:.85rem;color:var(--m);font-weight:300;margin:0}

/* PLATEFORMES */
.plates{display:grid;grid-template-columns:repeat(auto-fit,minmax(175px,1fr));gap:.9rem;margin:1.5rem 0}
.plate{background:var(--w);border:1px solid var(--b);border-radius:var(--r);padding:1.1rem;text-align:center;transition:transform .2s;position:relative}
.plate:hover{transform:translateY(-2px)}
.plate.top{border:2px solid var(--g)}
.top-badge{position:absolute;top:-10px;left:50%;transform:translateX(jusqu'à -50%);background:var(--g);color:white;font-size:.64rem;font-weight:700;padding:.14rem .65rem;border-radius:50px;white-space:nowrap}
