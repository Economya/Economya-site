  .acat strong{color:#fff}
  .hero-art h1{
    font-family:'Playfair Display',serif;font-size:clamp(1.7rem,4vw,2.6rem);
    font-weight:900;line-height:1.1;color:#fff;max-width:620px;margin:0 auto .9rem
  }
  .abadge{
    display:inline-block;
    background:linear-gradient(90deg,#FFD700,#FF6B35);
    color:#0A0000;font-size:.82rem;font-weight:700;padding:.35rem 1rem;
    border-radius:50px;margin-top:.4rem
  }
  .meta{display:flex;justify-content:center;flex-wrap:wrap;gap:.6rem;margin-top:1.2rem}
  .meta span{font-size:.74rem;color:rgba(255,255,255,.55);background:rgba(255,255,255,.1);padding:.2rem .75rem;border-radius:50px}

  article{max-width:680px;margin:0 auto;padding:2.5rem 1.5rem 4rem}
  article p{margin-bottom:1.3rem;font-size:.97rem;font-weight:300}
  article h2{font-family:'Playfair Display',serif;font-size:1.2rem;font-weight:700;color:var(--red-dark);margin:2rem 0 .7rem}

  /* Tarifs en jauge */
  .tarifs{display:flex;flex-direction:column;gap:.7rem;margin:1.5rem 0}
  .tarif-row{background:var(--w);border:1px solid var(--b);border-radius:10px;padding:.8rem 1rem;display:flex;align-items:center;gap:1rem}
  .tarif-label{font-size:.87rem;flex:1;font-weight:300}
  .tarif-label strong{font-weight:500;color:var(--t);display:block;font-size:.9rem}
  .tarif-bar-wrap{width:140px;flex-shrink:0}
  .tarif-bar{height:8px;border-radius:50px;margin-bottom:.3rem}
  .tarif-bar.plein{background:#C0122C;width:100%}
  .tarif-bar.abonnement{background:#E07B00;width:40%}
  .tarif-bar.reduit{background:#1D9E75;width:55%}
  .tarif-bar.seance{background:#6C3BE2;width:28%}
  .tarif-bar.gratuit{background:#00C2CB;width:8%}
  .tarif-price{font-size:.82rem;font-weight:600;color:var(--m);white-space:nowrap}

  /* Abonnements comparés */
  .abos{display:grid;grid-template-columns:1fr 1fr;gap:.7rem;margin:1.5rem 0}
  .abo{background:var(--w);border:1px solid var(--b);border-radius:11px;padding:.9rem 1rem;font-size:.85rem}
  .abo-name{font-weight:600;font-size:.9rem;color:var(--red-dark);margin-bottom:.2rem}
  .abo-price{display:inline-block;background:var(--red-light);color:var(--red);font-size:.75rem;font-weight:600;padding:.1rem .5rem;border-radius:50px;margin-bottom:.4rem}
  .abo-desc{font-size:.82rem;font-weight:300;color:var(--m);line-height:1.5}

  .conseil{
    background:linear-gradient(135deg,#5C0010,#C0122C);
    border-radius:12px;padding:1.2rem 1.4rem;margin:1.8rem 0;color:#fff
  }
  .conseil strong{display:block;color:#FFD700;font-weight:500;font-size:.92rem;margin-bottom:.4rem}
  .conseil p{font-size:.88rem;color:rgba(255,255,255,.82);font-weight:300;margin:0;line-height:1.65}

  footer{background:var(--gd);color:rgba(255,255,255,0.6);text-align:center;padding:1.6rem;font-size:.8rem}
  footer strong{color:white}
  footer a{color:var(--a);text-decoration:none}
  @media(max-width:500px){.abos{grid-template-columns:1fr}.tarif-bar-wrap{width:90px}}

/* Menu hamburger mobile */
