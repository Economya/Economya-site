<title>Épargner avec un petit salaire — Economya.fr</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;700;900&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet">
<style>
  *,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
  : root{
    --g:#1D9E75;--gl:#E1F5EE;--gd:#085041;--a:#EF9F27;--al:#FAEEDA;--ad:#633806;
    --t:#2C2C2A;--m:#5F5E5A;--bg:#FAFAF8;--w:#fff;--b:rgba(0,0,0,0.1);
    --forest:#0D3B1E;--forest-mid:#1B6B3A;--forest-light:#E8F5EC;
    --gold:#C8960A;--lime:#AAED6B;--sky:#A8D8EA;
  }
  body{font-family:'DM Sans',sans-serif;background:var(--bg);color:var(--t);line-height:1.7}
  nav{display:flex;justify-content:space-between;align-items:center;padding:.9rem 1.8rem;background:var(--w);border-bottom:1px solid var(--b);position:sticky;top:0;z-index:99}
  .logo{font-family:'Playfair Display',serif;font-weight:900;font-size:1.3rem;color:var(--gd);text-decoration:none}
  .logo span{color:var(--a)}
  .back{font-size:.82rem;color:var(--m);text-decoration:none}
  .back:hover{color:var(--g)}

  .hero-art{
    background:linear-gradient(135deg,#030D07 0%,#0D3B1E 35%,#1B6B3A 65%,#C8960A 100%);
    padding:3.5rem 2rem 3rem;text-align:center;position:relative;overflow:hidden
  }
  .hero-art::before{
    content:'💶';position:absolute;font-size:13rem;opacity:.06;
    top:50%;left:50%;transform:translate(jusqu'à -50%,jusqu'à -50%);pointer-events:none
  }
  .acat{font-size:.85rem;font-weight:500;color:rgba(255,255,255,.6);margin-bottom:.6rem;letter-spacing:.04em}
  .acat strong{color:#fff}
  .hero-art h1{
    font-family:'Playfair Display',serif;font-size:clamp(1.7rem,4vw,2.6rem);
    font-weight:900;line-height:1.1;color:#fff;max-width:620px;margin:0 auto .9rem
  }
  .abadge{
    display:inline-block;
    background:linear-gradient(90deg,var(--lime),var(--sky));
    color:#030D07;font-size:.82rem;font-weight:700;padding:.35rem 1rem;
    border-radius:50px;margin-top:.4rem
  }
  .meta{display:flex;justify-content:center;flex-wrap:wrap;gap:.6rem;margin-top:1.2rem}
  .meta span{font-size:.74rem;color:rgba(255,255,255,.55);background:rgba(255,255,255,.1);padding:.2rem .75rem;border-radius:50px}

  article{max-width:680px;margin:0 auto;padding:2.5rem 1.5rem 4rem}
  article p{margin-bottom:1.3rem;font-size:.97rem;font-weight:300}
  article h2{font-family:'Playfair Display',serif;font-size:1.2rem;font-weight:700;color:var(--forest);margin:2rem 0 .7rem}

  /* Méthodes d'épargne */
  .methodes{display:flex;flex-direction:column;gap:.8rem;margin:1.5rem 0}
  .methode{border-radius:12px;overflow:hidden;border:1px solid rgba(27,107,58,.15);display:grid;grid-template-columns:80px 1fr}
  .methode-pct{background:linear-gradient(180deg,var(--forest),var(--forest-mid));color:#fff;display:flex;flex-direction:column;align-items:center;justify-content:center;padding:.8rem .5rem;text-align:center}
  .methode-val{font-family:'Playfair Display',serif;font-size:1.3rem;font-weight:900;color:var(--lime);line-height:1}
  .methode-label{font-size:.6rem;font-weight:600;text-transform:uppercase;letter-spacing:.05em;color:rgba(255,255,255,.6);margin-top:.25rem}
  .methode-body{padding:.85rem 1rem;background:var(--w)}
  .methode-title{font-weight:500;font-size:.9rem;color:var(--forest);margin-bottom:.2rem}
  .methode-desc{font-size:.83rem;font-weight:300;color:var(--m);line-height:1.55}
  .methode-ex{margin-top:.4rem;font-size:.78rem;background:var(--forest-light);color:var(--forest);padding:.3rem .6rem;border-radius:6px;display:inline-block;font-weight:500}

  /* Simulation croissance */
  .simulation{background:var(--w);border:1px solid var(--b);border-radius:13px;overflow:hidden;margin:1.5rem 0}
  .sim-head{background:linear-gradient(90deg,var(--forest),var(--forest-mid));padding:.75rem 1.1rem;color:#fff;font-family:'Playfair Display',serif;font-size:.95rem;font-weight:700}
  .sim-row{display:grid;grid-template-columns:1fr 1fr 1fr 1fr;font-size:.82rem;border-bottom:1px solid var(--b);align-items:center}
  .sim-row.header{background:var(--forest-light);font-weight:600;font-size:.74rem;color:var(--forest);text-transform:uppercase;letter-spacing:.04em}
  .sim-row:last-child{border-bottom:none;background:var(--forest-light)}
  .sim-cell{padding:.55rem .8rem;font-weight:300;color:var(--t)}
  .sim-cell.label{font-weight:500;color:var(--forest)}
  .sim-cell.total{font-weight:700;color:var(--forest)}
  .sim-cell.gain{font-weight:600;color:var(--g)}

  /* Postes à réduire */
  .postes{display:grid;grid-template-columns:1fr 1fr;gap:.6rem;margin:1.5rem 0}
  .poste{background:var(--w);border:1px solid var(--b);border-radius:10px;padding:.75rem .9rem;display:flex;gap:.6rem;align-items:flex-start}
  .poste-icon{font-size:1.2rem;flex-shrink:0}
  .poste-body{}
  .poste-nom{font-weight:500;font-size:.85rem;color:var(--forest);margin-bottom:.15rem}
  .poste-desc{font-size:.78rem;font-weight:300;color:var(--m);line-height:1.4}
  .poste-gain{font-size:.72rem;font-weight:600;color:var(--g);margin-top:.2rem}

  .conseil{
    background:linear-gradient(135deg,#030D07,#0D3B1E);
    border-radius:12px;padding:1.2rem 1.4rem;margin:1.8rem 0;color:#fff;
    border:1px solid rgba(170,237,107,.12)
  }
  .conseil strong{display:block;color:var(--lime);font-weight:500;font-size:.92rem;margin-bottom:.4rem}
  .conseil p{font-size:.88rem;color:rgba(255,255,255,.82);font-weight:300;margin:0;line-height:1.65}

  footer{background:var(--gd);color:rgba(255,255,255,0.6);text-align:center;padding:1.6rem;font-size:.8rem}
  footer strong{color:white}
  footer a{color:var(--a);text-decoration:none}
  @media(max-width:500px){.postes{grid-template-columns:1fr}.sim-row{grid-template-columns:1fr 1fr 1fr}.sim-cell:last-child{display:none}}

/* Menu hamburger mobile */
.hamburger{display:none;flex-direction:column;gap:5px;cursor:pointer;background:none;border:none;padding:.3rem}
.hamburger span{display:block;width:24px;height:2px;background:var(--gd,#085041);border-radius:2px;transition:all .3s}
.mobile-menu{display:none;position:fixed;top:0;left:0;right:0;bottom:0;background:rgba(255,255,255,.98);z-index:999;flex-direction:column;align-items:center;justify-content:center;gap:1.5rem}
.mobile-menu.open{display:flex}
.mobile-menu a{font-family:'Playfair Display',serif;font-size:1.3rem;font-weight:700;color:#085041;text-decoration:none}
