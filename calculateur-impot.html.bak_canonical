<script>
const fmt = n => Math.round(n).toLocaleString('fr-FR') + ' €';

// Barème IR 2026 (revenus 2025)
const BAREME = [
  { min: 0,      max: 11600,  taux: 0,    label: "Jusqu'à 11 600 €" },
  { min: 11600,  max: 29579,  taux: 0.11, label: "11 600 € à 29 579 €" },
  { min: 29579,  max: 84577,  taux: 0.30, label: "29 579 € à 84 577 €" },
  { min: 84577,  max: 181917, taux: 0.41, label: "84 577 € à 181 917 €" },
  { min: 181917, max: Infinity,taux: 0.45, label: "Au-delà de 181 917 €" },
];

function calcImpot(revenuParPart) {
  let impot = 0;
  for(const t of BAREME) {
    if(revenuParPart <= t.min) break;
    const tranche = Math.min(revenuParPart, t.max) - t.min;
    impot += tranche * t.taux;
  }
  return impot;
}

function getTMI(revenuParPart) {
  for(let i = BAREME.length - 1; i >= 0; i--) {
    if(revenuParPart > BAREME[i].min) return BAREME[i].taux * 100;
  }
  return 0;
}

function calculate() {
  const revenus = +document.getElementById('revenus').value;
  const parts = +document.getElementById('situation').value;
  const deductions = +document.getElementById('deductions').value;

  document.getElementById('v-revenus').innerHTML = revenus.toLocaleString('fr-FR') + ' <span>€/an</span>';
  document.getElementById('v-deductions').innerHTML = deductions.toLocaleString('fr-FR') + ' <span>€</span>';

  // Abattement forfaitaire 10% (min 495€, max 14171€)
  const abattement = Math.min(Math.max(revenus * 0.10, 495), 14171);
  const revenuImposable = Math.max(0, revenus - abattement - deductions);
  const revenuParPart = revenuImposable / parts;

  const impotBrut = calcImpot(revenuParPart) * parts;

  // Décote (si impôt < seuil)
  let impotNet = impotBrut;
  const seuilDecote = parts === 1 ? 1929 : 3191;
  if(impotBrut < seuilDecote) {
    const decote = parts === 1 ? 897 - impotBrut * 0.4525 : 1483 - impotBrut * 0.4525;
    impotNet = Math.max(0, impotBrut - Math.max(0, decote));
  }

  const tmi = getTMI(revenuParPart);
  const tauxMoyen = revenus > 0 ? (impotNet / revenus * 100).toFixed(1) : 0;

  document.getElementById('r-impot').textContent = fmt(impotNet);
  document.getElementById('r-mensuel').textContent = fmt(impotNet / 12);
  document.getElementById('r-tmi').textContent = tmi + '%';
  document.getElementById('r-taux-moyen').textContent = tauxMoyen + '%';

  document.getElementById('d-revenus').textContent = fmt(revenus);
  document.getElementById('d-abattement').textContent = '- ' + fmt(abattement);
  document.getElementById('d-deductions').textContent = deductions > 0 ? '- ' + fmt(deductions) : fmt(0);
  document.getElementById('d-imposable').textContent = fmt(revenuImposable);
  document.getElementById('d-parts').textContent = parts + ' part' + (parts > 1 ? 's' : '');
  document.getElementById('d-par-part').textContent = fmt(revenuParPart);
  document.getElementById('d-brut').textContent = fmt(impotBrut);
  document.getElementById('d-net').textContent = fmt(impotNet);

  // Barème avec tranche active
  const tbody = document.getElementById('bareme-body');
  tbody.innerHTML = '';
  BAREME.forEach(t => {
    const active = revenuParPart > t.min;
    const tr = document.createElement('tr');
    if(active && revenuParPart <= t.max) tr.className = 'active';
    tr.innerHTML = `
      <td>${t.label}</td>
      <td>${(t.taux * 100).toFixed(0)}%</td>
      <td>${active ? (revenuParPart <= t.max ? '👈 Votre tranche' : '✅ Dépassée') : '—'}</td>
    `;
    tbody.appendChild(tr);
  });

  // Conseil
  const tip = document.getElementById('tip-text');
  if(impotNet === 0) {
    tip.innerHTML = '<strong>✅ Non imposable :</strong> Vos revenus sont en dessous du seuil d\'imposition. Vous n\'avez pas d\'impôt à payer cette année.';
  } else if(tmi >= 30) {
    tip.innerHTML = `<strong>💡 Optimisation possible :</strong> Avec un TMI de ${tmi}%, chaque euro versé sur un PER vous économise ${tmi} centimes d'impôt. Un versement de 5 000 € sur un PER = ${fmt(5000 * tmi/100)} d'impôt en moins.`;
  } else {
    tip.innerHTML = `<strong>💡 Conseil :</strong> Votre taux moyen est de ${tauxMoyen}%. Pensez à vérifier les déductions auxquelles vous avez droit : dons aux associations (66% déduit), emploi à domicile (50% déduit), frais réels si supérieurs à ${fmt(abattement)}.`;
  }
}

document.querySelectorAll('input[type=range]').forEach(el => el.addEventListener('input', calculate));
calculate();
</script>
