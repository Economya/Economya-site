p{margin-bottom:1rem;font-size:.95rem}

/* TAUX */
.taux{background:var(--sky-l);border-radius:var(--r);padding:1.3rem 1.5rem;margin:1.5rem 0}
.taux h3{font-family:'Playfair Display',serif;font-size:1.1rem;font-weight:700;color:#082f49;margin-bottom:.8rem}
