  /* LEXIQUE VIAGER */
  .lexique{display:flex;flex-direction:column;gap:.55rem;margin:1.5rem 0}
  .terme{background:#fff;border:1px solid rgba(0,0,0,.08);border-radius:10px;display:grid;grid-template-columns:130px 1fr;overflow:hidden}
  .terme-mot{background:linear-gradient(135deg,#3A0840,#7B1E6E);color:#F0C878;padding:.75rem .9rem;font-weight:700;font-size:.82rem;display:flex;align-items:center;line-height:1.3}
  .terme-def{padding:.75rem 1rem;font-size:.83rem;font-weight:300;color:#5F5E5A;line-height:1.55}

  /* AVANTAGES ET RISQUES PAR PROFIL */
  .profils{display:grid;grid-template-columns:1fr 1fr;gap:.9rem;margin:1.5rem 0}
  .profil{border-radius:12px;overflow:hidden;border:1px solid rgba(0,0,0,.08)}
  .profil-head{padding:.7rem 1rem;color:#fff;font-weight:700;font-size:.88rem}
  .profil-head.vendeur{background:linear-gradient(90deg,#3A0840,#7B1E6E)}
  .profil-head.acheteur{background:linear-gradient(90deg,#0A3040,#1A7AC0)}
  .profil-body{background:#fff;padding:.85rem 1rem}
  .profil-section{margin-bottom:.6rem}
  .profil-section:last-child{margin-bottom:0}
  .profil-sous-titre{font-size:.7rem;font-weight:600;text-transform:uppercase;letter-spacing:.06em;margin-bottom:.35rem}
  .profil-head.vendeur ~ .profil-body .profil-sous-titre.plus{color:#085041}
  .profil-head.vendeur ~ .profil-body .profil-sous-titre.moins{color:#9B1D1D}
  .profil-head.acheteur ~ .profil-body .profil-sous-titre.plus{color:#085041}
  .profil-head.acheteur ~ .profil-body .profil-sous-titre.moins{color:#9B1D1D}
  .profil-item{font-size:.8rem;font-weight:300;color:#2C2C2A;padding:.2rem 0;line-height:1.4;border-bottom:1px dotted rgba(0,0,0,.06)}
  .profil-item:last-child{border-bottom:none}
  .profil-item.plus::before{content:'✅ ';font-size:.75rem}
  .profil-item.moins::before{content:'⚠️ ';font-size:.75rem}

  /* SIMULATION CALCUL RENTE */
  .simul{background:linear-gradient(135deg,#100418,#3A0840);border-radius:13px;padding:1.3rem 1.5rem;margin:1.5rem 0;color:#fff}
  .simul h3{font-family:'Playfair Display',serif;font-size:1rem;font-weight:700;color:#F0C878;margin-bottom:1rem}
  .simul-grid{display:grid;grid-template-columns:1fr 1fr;gap:1rem}
  .simul-col h4{font-size:.74rem;font-weight:600;text-transform:uppercase;letter-spacing:.06em;color:rgba(255,255,255,.5);margin-bottom:.6rem;padding-bottom:.35rem;border-bottom:1px solid rgba(255,255,255,.1)}
  .simul-ligne{display:flex;justify-content:space-between;padding:.35rem 0;border-bottom:1px solid rgba(255,255,255,.06);font-size:.83rem}
  .simul-ligne:last-child{border-bottom:none;padding-top:.45rem;margin-top:.15rem}
  .simul-lab{font-weight:300;color:rgba(255,255,255,.75)}
  .simul-val{font-weight:600;color:#F0C878;white-space:nowrap}
  .simul-lab.total{font-weight:600;color:#fff}
  .simul-val.total{font-size:.95rem}

  /* CHECKLIST PRÉCAUTIONS */
  .precautions{display:flex;flex-direction:column;gap:.5rem;margin:1.4rem 0}
  .precaution{display:flex;gap:.75rem;align-items:flex-start;padding:.7rem 1rem;border-radius:10px;background:#fff;border:1px solid rgba(0,0,0,.07)}
  .prec-ico{font-size:1.1rem;flex-shrink:0;margin-top:.05rem}
