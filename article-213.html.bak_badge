  .encadre{border-left:4px solid #7B1E6E;background:#F9F0FF;border-radius:0 10px 10px 0;padding:1rem 1.2rem;margin:1.5rem 0}
  .encadre strong{display:block;color:#3A0840;font-size:.9rem;margin-bottom:.3rem}
