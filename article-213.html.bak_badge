  .conseil{background:linear-gradient(135deg,#100418,#3A0840);border-radius:13px;padding:1.3rem 1.5rem;margin:2rem 0;color:#fff;border:1px solid rgba(240,200,120,.1)}
  .conseil strong{display:block;color:#F0C878;font-weight:500;font-size:.93rem;margin-bottom:.4rem}
