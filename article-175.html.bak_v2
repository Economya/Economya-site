<!DOCTYPE html>
<html lang="fr">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Sport à domicile sans matériel — Economya.fr</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;700;900&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet">
<style>
  *,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
  :root{
    --g:#1D9E75;--gl:#E1F5EE;--gd:#085041;--a:#EF9F27;--al:#FAEEDA;--ad:#633806;
    --t:#2C2C2A;--m:#5F5E5A;--bg:#FAFAF8;--w:#fff;--b:rgba(0,0,0,0.1);
    --fire:#B5250A;--fire-mid:#E53935;--fire-light:#FFF3F3;
    --orange:#F57C00;--neon:#E8FF57;--dark:#1A0A00;
  }
  body{font-family:'DM Sans',sans-serif;background:var(--bg);color:var(--t);line-height:1.7}
  nav{display:flex;justify-content:space-between;align-items:center;padding:.9rem 1.8rem;background:var(--w);border-bottom:1px solid var(--b);position:sticky;top:0;z-index:99}
  .logo{font-family:'Playfair Display',serif;font-weight:900;font-size:1.3rem;color:var(--gd);text-decoration:none}
  .logo span{color:var(--a)}
  .back{font-size:.82rem;color:var(--m);text-decoration:none}
  .back:hover{color:var(--g)}

  .hero-art{
    background:linear-gradient(135deg,#1A0A00 0%,#B5250A 38%,#E53935 65%,#E8FF57 100%);
    padding:3.5rem 2rem 3rem;text-align:center;position:relative;overflow:hidden
  }
  .hero-art::before{
    content:'💪';position:absolute;font-size:13rem;opacity:.06;
    top:50%;left:50%;transform:translate(-50%,-50%);pointer-events:none
  }
  .acat{font-size:.85rem;font-weight:500;color:rgba(255,255,255,.6);margin-bottom:.6rem;letter-spacing:.04em}
  .acat strong{color:#fff}
  .hero-art h1{
    font-family:'Playfair Display',serif;font-size:clamp(1.7rem,4vw,2.6rem);
    font-weight:900;line-height:1.1;color:#fff;max-width:620px;margin:0 auto .9rem
  }
  .abadge{
    display:inline-block;
    background:linear-gradient(90deg,var(--neon),#fff);
    color:#1A0A00;font-size:.82rem;font-weight:700;padding:.35rem 1rem;
    border-radius:50px;margin-top:.4rem
  }
  .meta{display:flex;justify-content:center;flex-wrap:wrap;gap:.6rem;margin-top:1.2rem}
  .meta span{font-size:.74rem;color:rgba(255,255,255,.55);background:rgba(255,255,255,.1);padding:.2rem .75rem;border-radius:50px}

  article{max-width:680px;margin:0 auto;padding:2.5rem 1.5rem 4rem}
  article p{margin-bottom:1.3rem;font-size:.97rem;font-weight:300}
  article h2{font-family:'Playfair Display',serif;font-size:1.2rem;font-weight:700;color:var(--fire);margin:2rem 0 .7rem}

  /* Programme semaine */
  .programme{background:var(--w);border:1px solid var(--b);border-radius:13px;overflow:hidden;margin:1.5rem 0}
  .prog-head{background:linear-gradient(90deg,var(--dark),var(--fire));padding:.8rem 1.1rem;color:#fff;font-family:'Playfair Display',serif;font-size:.95rem;font-weight:700}
  .prog-jour{border-bottom:1px solid var(--b)}
  .prog-jour:last-child{border-bottom:none}
  .prog-jour-head{display:grid;grid-template-columns:90px 1fr auto;align-items:center;padding:.6rem 1rem;gap:.5rem;cursor:default}
  .prog-jour-nom{font-weight:600;font-size:.85rem;color:var(--fire)}
  .prog-jour-type{font-size:.8rem;font-weight:300;color:var(--m)}
  .prog-dur{font-size:.75rem;font-weight:600;background:var(--fire-light);color:var(--fire);padding:.1rem .5rem;border-radius:50px;white-space:nowrap}
  .prog-exos{padding:.4rem 1rem .7rem;display:flex;flex-wrap:wrap;gap:.4rem}
  .exo{font-size:.75rem;font-weight:400;background:#F5F5F5;color:var(--t);padding:.2rem .55rem;border-radius:50px}
  .prog-jour:nth-child(even) .prog-jour-head{background:#FAFAF8}
  .repos{background:var(--fire-light);color:var(--fire-mid);font-size:.8rem;font-weight:500;padding:.55rem 1rem;font-style:italic}

  /* Comparatif salle vs maison */
  .versus{display:grid;grid-template-columns:1fr auto 1fr;gap:.5rem;align-items:center;margin:1.5rem 0}
  .versus-block{border-radius:12px;overflow:hidden;border:1px solid var(--b)}
  .versus-head{padding:.65rem .9rem;color:#fff;text-align:center;font-weight:700;font-size:.87rem}
  .versus-head.salle{background:linear-gradient(135deg,#1A1A2E,#16213E)}
  .versus-head.maison{background:linear-gradient(135deg,var(--fire),var(--orange))}
  .versus-body{background:var(--w);padding:.7rem .9rem;font-size:.82rem;font-weight:300;line-height:1.6}
  .versus-item{padding:.2rem 0;border-bottom:1px dotted var(--b);color:var(--m)}
  .versus-item:last-child{border-bottom:none}
  .versus-mid{font-family:'Playfair Display',serif;font-size:1.3rem;font-weight:900;color:var(--fire);text-align:center}

  /* Ressources gratuites */
  .ressources{display:grid;grid-template-columns:1fr 1fr;gap:.7rem;margin:1.5rem 0}
  .ressource{background:var(--w);border:1px solid var(--b);border-radius:11px;padding:.85rem 1rem}
  .ressource-icon{font-size:1.3rem;margin-bottom:.3rem}
  .ressource-nom{font-weight:500;font-size:.88rem;color:var(--fire);margin-bottom:.2rem}
  .ressource-desc{font-size:.8rem;font-weight:300;color:var(--m);line-height:1.45}

  .conseil{
    background:linear-gradient(135deg,#1A0A00,#B5250A);
    border-radius:12px;padding:1.2rem 1.4rem;margin:1.8rem 0;color:#fff
  }
  .conseil strong{display:block;color:var(--neon);font-weight:500;font-size:.92rem;margin-bottom:.4rem}
  .conseil p{font-size:.88rem;color:rgba(255,255,255,.82);font-weight:300;margin:0;line-height:1.65}

  footer{background:var(--gd);color:rgba(255,255,255,0.6);text-align:center;padding:1.6rem;font-size:.8rem}
  footer strong{color:white}
  footer a{color:var(--a);text-decoration:none}
  @media(max-width:500px){.versus{grid-template-columns:1fr}.versus-mid{display:none}.ressources{grid-template-columns:1fr}}

/* Menu hamburger mobile */
.hamburger{display:none;flex-direction:column;gap:5px;cursor:pointer;background:none;border:none;padding:.3rem}
.hamburger span{display:block;width:24px;height:2px;background:var(--gd,#085041);border-radius:2px;transition:all .3s}
.mobile-menu{display:none;position:fixed;top:0;left:0;right:0;bottom:0;background:rgba(255,255,255,.98);z-index:999;flex-direction:column;align-items:center;justify-content:center;gap:1.5rem}
.mobile-menu.open{display:flex}
.mobile-menu a{font-family:'Playfair Display',serif;font-size:1.3rem;font-weight:700;color:#085041;text-decoration:none}
.mobile-menu .close-btn{position:absolute;top:1.2rem;right:1.5rem;background:none;border:none;font-size:1.8rem;cursor:pointer;color:#085041}
.mobile-menu .nav-cta{background:#1D9E75;color:white!important;padding:.5rem 1.4rem;border-radius:50px}
@media(max-width:768px){
  .hamburger{display:flex}
  nav .nav-links,nav > a:not(.logo),nav > div:not(.mobile-menu){display:none!important}
  nav li{display:none!important}
}
</style>
