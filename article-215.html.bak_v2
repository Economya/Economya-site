<style>
  *,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
  body{font-family:'DM Sans',sans-serif;background:#FAFAF8;color:#2C2C2A;line-height:1.7}
  nav{display:flex;justify-content:space-between;align-items:center;padding:.9rem 1.8rem;background:#fff;border-bottom:1px solid rgba(0,0,0,.08);position:sticky;top:0;z-index:99}
  .logo{font-family:'Playfair Display',serif;font-weight:900;font-size:1.3rem;color:#085041;text-decoration:none}
  .logo span{color:#EF9F27}
  .back{font-size:.82rem;color:#5F5E5A;text-decoration:none}
  .back:hover{color:#1D9E75}

  /* HERO — bleu nuit → cobalt royal → or */
  .hero{background:linear-gradient(135deg,#060412 0%,#160A40 30%,#2A1888 60%,#6040E0 84%,#F0D060 100%);padding:3.8rem 2rem 3.2rem;text-align:center;position:relative;overflow:hidden}
  .hero::before{content:'🏦';position:absolute;font-size:14rem;opacity:.05;top:50%;left:50%;transform:translate(-50%,-50%);pointer-events:none}
  .hero-cat{font-size:.82rem;font-weight:500;color:rgba(255,255,255,.6);margin-bottom:.6rem;letter-spacing:.05em}
  .hero-cat strong{color:#fff}
  .hero h1{font-family:'Playfair Display',serif;font-size:clamp(1.8rem,4.5vw,2.7rem);font-weight:900;color:#fff;line-height:1.1;max-width:640px;margin:.3rem auto .9rem}
  .hero-badge{display:inline-block;background:linear-gradient(90deg,#F0D060,#C09020);color:#060412;font-size:.82rem;font-weight:700;padding:.35rem 1.1rem;border-radius:50px}
  .hero-meta{display:flex;justify-content:center;flex-wrap:wrap;gap:.55rem;margin-top:1.2rem}
  .hero-meta span{font-size:.73rem;color:rgba(255,255,255,.5);background:rgba(255,255,255,.09);padding:.2rem .75rem;border-radius:50px}

  article{max-width:700px;margin:0 auto;padding:2.5rem 1.5rem 5rem}
  article p{margin-bottom:1.3rem;font-size:.97rem;font-weight:300;line-height:1.75}
  h2{font-family:'Playfair Display',serif;font-size:1.2rem;font-weight:700;color:#160A40;margin:2.2rem 0 .8rem}

  /* AVANTAGES VISUELS — 3 grandes cartes */
  .avantages{display:grid;grid-template-columns:repeat(3,1fr);gap:.75rem;margin:1.5rem 0}
  .avantage{background:#fff;border:1px solid rgba(0,0,0,.08);border-radius:12px;padding:1rem .9rem;text-align:center}
  .avantage-ico{font-size:1.8rem;margin-bottom:.4rem}
  .avantage-titre{font-weight:600;font-size:.85rem;color:#160A40;margin-bottom:.3rem;line-height:1.3}
  .avantage-desc{font-size:.76rem;font-weight:300;color:#5F5E5A;line-height:1.45}

  /* ÉTAPES CRÉATION */
  .etapes{display:flex;flex-direction:column;gap:0;margin:1.5rem 0;position:relative}
  .etapes::before{content:'';position:absolute;left:21px;top:22px;bottom:22px;width:2px;background:linear-gradient(180deg,#2A1888,#6040E0 60%,rgba(96,64,224,.1))}
  .etape{display:grid;grid-template-columns:44px 1fr;gap:.9rem;padding:.75rem 0;align-items:flex-start}
  .etape-dot{width:44px;height:44px;border-radius:50%;background:linear-gradient(135deg,#160A40,#2A1888);color:#F0D060;font-family:'Playfair Display',serif;font-weight:900;font-size:1.1rem;display:flex;align-items:center;justify-content:center;flex-shrink:0;position:relative;z-index:1;box-shadow:0 2px 10px rgba(42,24,136,.3)}
  .etape-body{padding-top:.35rem}
  .etape-titre{font-weight:500;font-size:.9rem;color:#160A40;margin-bottom:.2rem}
  .etape-desc{font-size:.83rem;font-weight:300;color:#5F5E5A;line-height:1.55}
  .etape-cout{display:inline-block;margin-top:.35rem;font-size:.73rem;font-weight:600;padding:.1rem .55rem;border-radius:50px;background:#EEE8FF;color:#160A40}

  /* IR VS IS */
  .regime{display:grid;grid-template-columns:1fr 1fr;gap:.9rem;margin:1.5rem 0}
  .reg{border-radius:12px;overflow:hidden;border:1px solid rgba(0,0,0,.08)}
  .reg-head{padding:.7rem 1rem;color:#fff;font-weight:700;font-size:.88rem}
  .reg-head.ir{background:linear-gradient(135deg,#0E3828,#1A6E50)}
  .reg-head.is{background:linear-gradient(135deg,#160A40,#2A1888)}
  .reg-body{background:#fff;padding:.85rem 1rem}
  .reg-row{display:flex;justify-content:space-between;gap:.5rem;padding:.3rem 0;border-bottom:1px dotted rgba(0,0,0,.07);font-size:.82rem}
  .reg-row:last-child{border-bottom:none}
  .reg-label{font-weight:300;color:#5F5E5A}
  .reg-val{font-weight:500;color:#2C2C2A;text-align:right;font-size:.8rem}

  /* SIMULATION TRANSMISSION */
  .simul{background:linear-gradient(135deg,#060412,#160A40);border-radius:13px;padding:1.3rem 1.5rem;margin:1.5rem 0;color:#fff}
  .simul h3{font-family:'Playfair Display',serif;font-size:1rem;font-weight:700;color:#F0D060;margin-bottom:.9rem}
  .simul-row{display:flex;justify-content:space-between;padding:.4rem 0;border-bottom:1px solid rgba(255,255,255,.07);font-size:.84rem}
  .simul-row:last-child{border-bottom:none;padding-top:.55rem;margin-top:.2rem}
  .simul-lab{font-weight:300;color:rgba(255,255,255,.8)}
  .simul-val{font-weight:600;color:#F0D060;white-space:nowrap}
  .simul-lab.total{font-weight:600;color:#fff}
  .simul-val.total{font-size:1rem}
  .simul-val.green{color:#6EE7B7}

  /* INCONVÉNIENTS */
  .inconvenients{display:flex;flex-direction:column;gap:.5rem;margin:1.4rem 0}
  .inconv{display:flex;gap:.75rem;align-items:flex-start;padding:.7rem 1rem;border-radius:10px;background:#fff;border:1px solid rgba(0,0,0,.07)}
  .inconv-ico{font-size:1rem;flex-shrink:0;margin-top:.1rem}
  .inconv-text{font-size:.83rem;font-weight:300;color:#2C2C2A;line-height:1.5}
