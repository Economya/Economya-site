<script>
const fmt = n => Math.round(n).toLocaleString('fr-FR') + ' €';

const BIENS = [
  { icon:'🏠', nom:'Studio Paris', prix:250000 },
  { icon:'🏡', nom:'Appart 2 pièces province', prix:150000 },
  { icon:'🏘️', nom:'Maison campagne', prix:200000 },
  { icon:'🏙️', nom:'Appart 3 pièces grande ville', prix:300000 },
  { icon:'🏰', nom:'Maison avec jardin', prix:400000 },
  { icon:'🌟', nom:'Villa bord de mer', prix:600000 },
];

function calculate() {
  const revenus = +document.getElementById('revenus').value;
  const credits = +document.getElementById('credits').value;
  const apport = +document.getElementById('apport').value;
  const duree = +document.getElementById('duree').value;

  document.getElementById('v-revenus').innerHTML = revenus.toLocaleString('fr-FR') + ' <span>€/mois</span>';
  document.getElementById('v-credits').innerHTML = credits.toLocaleString('fr-FR') + ' <span>€/mois</span>';
  document.getElementById('v-apport').innerHTML = apport.toLocaleString('fr-FR') + ' <span>€</span>';
  document.getElementById('v-duree').innerHTML = duree + ' <span>ans</span>';

  const mensualiteMax = revenus * 0.35;
  const mensualiteImmo = Math.max(0, mensualiteMax - credits);
  const tauxMensuel = 0.035 / 12;
  const n = duree * 12;

  // Calcul montant empruntable
  const emprunt = mensualiteImmo * (1 - Math.pow(1 + tauxMensuel, -n)) / tauxMensuel;
  const budgetTotal = emprunt + apport;
  const tauxEndettement = ((mensualiteImmo + credits) / revenus * 100).toFixed(0);

  document.getElementById('r-capacite').textContent = fmt(budgetTotal);
  document.getElementById('r-sous').textContent = `budget total avec apport de ${fmt(apport)}`;
  document.getElementById('r-mensualite').textContent = fmt(mensualiteImmo);
  document.getElementById('r-emprunt').textContent = fmt(emprunt);
  document.getElementById('r-taux-endettement').textContent = tauxEndettement + '%';

  document.getElementById('d-revenus').textContent = fmt(revenus);
  document.getElementById('d-max').textContent = fmt(mensualiteMax);
  document.getElementById('d-credits').textContent = '- ' + fmt(credits);
  document.getElementById('d-mensualite').textContent = fmt(mensualiteImmo);
  document.getElementById('d-emprunt').textContent = fmt(emprunt);
  document.getElementById('d-apport').textContent = '+ ' + fmt(apport);
  document.getElementById('d-total').textContent = fmt(budgetTotal);

  // Biens
  const biensGrid = document.getElementById('biens-grid');
  biensGrid.innerHTML = '';
  BIENS.forEach(b => {
    const possible = budgetTotal >= b.prix * 0.92; // avec frais de notaire
    biensGrid.innerHTML += `
      <div class="bien-card ${possible ? 'possible' : 'impossible'}">
        <div class="bien-icon">${b.icon}</div>
        <div class="bien-nom">${b.nom}</div>
        <div class="bien-prix">~${fmt(b.prix)}</div>
        <div class="bien-statut ${possible ? 'oui' : 'non'}">${possible ? '✅ Accessible' : '❌ Hors budget'}</div>
      </div>
    `;
  });

  // Conseil
  const tip = document.getElementById('tip-text');
  if(credits > revenus * 0.15) {
    tip.innerHTML = `<strong>⚠️ Crédits existants élevés :</strong> Vos crédits en cours réduisent fortement votre capacité d'emprunt immobilier. Envisagez de les rembourser avant votre achat pour augmenter votre budget de ${fmt(credits * n / 1.5)}.`;
  } else if(apport < emprunt * 0.1) {
    tip.innerHTML = `<strong>💡 Augmentez votre apport :</strong> Avec seulement ${(apport/budgetTotal*100).toFixed(0)}% d'apport, certaines banques peuvent refuser. Visez 10% minimum. Chaque tranche de 10 000 € d'apport supplémentaire améliore votre dossier.`;
  } else {
    tip.innerHTML = `<strong>✅ Bonne capacité :</strong> Avec ${fmt(budgetTotal)} de budget, vous avez accès à un bon choix de biens. Comparez les offres de plusieurs banques — un écart de 0,2% sur le taux représente ${fmt(emprunt * 0.002 * duree)} d'économies sur la durée totale.`;
  }
}

document.querySelectorAll('input[type=range]').forEach(el => el.addEventListener('input', calculate));
calculate();
</script>
