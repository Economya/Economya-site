  .filtre-badge{font-size:.72rem;font-weight:700;padding:.2rem .55rem;border-radius:50px;display:block;white-space:nowrap}
  .filtre-badge.top{background:var(--ocean-light);color:var(--deep)}
  .filtre-badge.mid{background:var(--al);color:var(--ad)}

  .conseil{
    background:linear-gradient(135deg,#010B14,#03045E);
    border-radius:12px;padding:1.2rem 1.4rem;margin:1.8rem 0;color:#fff;
    border:1px solid rgba(144,224,239,.15)
  }
  .conseil strong{display:block;color:var(--foam);font-weight:500;font-size:.92rem;margin-bottom:.4rem}
  .conseil p{font-size:.88rem;color:rgba(255,255,255,.82);font-weight:300;margin:0;line-height:1.65}

  footer{background:var(--gd);color:rgba(255,255,255,0.6);text-align:center;padding:1.6rem;font-size:.8rem}
  footer strong{color:white}
  footer a{color:var(--a);text-decoration:none}
