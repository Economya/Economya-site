  /* Comparatif chiffré */
  .compar{display:grid;grid-template-columns:1fr auto 1fr;gap:.6rem;align-items:stretch;margin:1.5rem 0}
  .compar-block{border-radius:13px;overflow:hidden;border:1px solid var(--b)}
  .compar-head{padding:.75rem 1rem;text-align:center;color:#fff;font-weight:700;font-size:.88rem}
  .compar-head.bouteille{background:linear-gradient(135deg,#4A1010,#C0392B)}
  .compar-head.robinet{background:linear-gradient(135deg,#03045E,#0077B6)}
  .compar-body{padding:.8rem 1rem;background:var(--w)}
  .compar-item{display:flex;justify-content:space-between;padding:.3rem 0;border-bottom:1px dotted var(--b);font-size:.83rem}
  .compar-item:last-child{border-bottom:none}
  .compar-label{font-weight:300;color:var(--m)}
  .compar-val{font-weight:600;color:var(--t)}
  .compar-val.rouge{color:#B91C1C}
