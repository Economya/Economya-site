<style>
  *,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
  : root{
    --g:#1D9E75;--gl:#E1F5EE;--gd:#085041;--a:#EF9F27;--al:#FAEEDA;--ad:#633806;
    --t:#2C2C2A;--m:#5F5E5A;--bg:#FAFAF8;--w:#fff;--b:rgba(0,0,0,0.1);
    --ocean:#0077B6;--ocean-mid:#0096C7;--ocean-light:#CAF0F8;
