  /* Impact environnemental */
  .impact{background:linear-gradient(135deg,#E8F8FF,#CAF0F8);border:1px solid rgba(0,119,182,.2);border-radius:13px;padding:1.2rem 1.4rem;margin:1.5rem 0}
  .impact h3{font-family:'Playfair Display',serif;font-weight:700;color:var(--deep);font-size:.97rem;margin-bottom:.8rem}
  .impact-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:.6rem}
  .impact-stat{text-align:center;background:rgba(255,255,255,.7);border-radius:10px;padding:.7rem .5rem}
  .impact-val{font-family:'Playfair Display',serif;font-size:1.4rem;font-weight:900;color:var(--ocean);line-height:1}
  .impact-label{font-size:.72rem;font-weight:300;color:var(--m);margin-top:.25rem;line-height:1.3}

  /* Alternatives filtrées */
  .filtres{display:flex;flex-direction:column;gap:.7rem;margin:1.5rem 0}
  .filtre{background:var(--w);border:1px solid var(--b);border-radius:11px;display:grid;grid-template-columns:52px 1fr auto;align-items:center;gap:.7rem;padding:.75rem .9rem}
  .filtre-icon{font-size:1.5rem;text-align:center}
  .filtre-body{}
  .filtre-nom{font-weight:500;font-size:.9rem;color:var(--deep);margin-bottom:.15rem}
  .filtre-desc{font-size:.8rem;font-weight:300;color:var(--m);line-height:1.4}
