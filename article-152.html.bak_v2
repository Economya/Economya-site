<html lang="fr">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Capsule wardrobe : 20 pièces pour tout porter — Economya.fr</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;700;900&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet">
<style>
  *,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
  :root{
    --g:#1D9E75;--gl:#E1F5EE;--gd:#085041;--a:#EF9F27;--al:#FAEEDA;--ad:#633806;
    --t:#2C2C2A;--m:#5F5E5A;--bg:#FAFAF8;--w:#fff;--b:rgba(0,0,0,0.1);
    --noir:#1A1A1A;--charcoal:#2D2D2D;--warm:#F7F3EE;
    --blush:#E8C5B0;--slate:#6B7A8D;--ecru:#EDE8DF;
  }
  body{font-family:'DM Sans',sans-serif;background:var(--bg);color:var(--t);line-height:1.7}
  nav{display:flex;justify-content:space-between;align-items:center;padding:.9rem 1.8rem;background:var(--w);border-bottom:1px solid var(--b);position:sticky;top:0;z-index:99}
  .logo{font-family:'Playfair Display',serif;font-weight:900;font-size:1.3rem;color:var(--gd);text-decoration:none}
  .logo span{color:var(--a)}
  .back{font-size:.82rem;color:var(--m);text-decoration:none}
  .back:hover{color:var(--g)}

  .hero-art{
    background:linear-gradient(135deg,#0A0A0A 0%,#1A1A1A 30%,#2D2D2D 58%,#6B7A8D 82%,#E8C5B0 100%);
    padding:3.5rem 2rem 3rem;text-align:center;position:relative;overflow:hidden
  }
  .hero-art::before{
    content:'👗';position:absolute;font-size:13rem;opacity:.06;
    top:50%;left:50%;transform:translate(-50%,-50%);pointer-events:none
  }
  .acat{font-size:.85rem;font-weight:500;color:rgba(255,255,255,.6);margin-bottom:.6rem;letter-spacing:.04em}
  .acat strong{color:#fff}
  .hero-art h1{
    font-family:'Playfair Display',serif;font-size:clamp(1.7rem,4vw,2.6rem);
    font-weight:900;line-height:1.1;color:#fff;max-width:620px;margin:0 auto .9rem
  }
  .abadge{
    display:inline-block;
    background:linear-gradient(90deg,var(--ecru),var(--blush));
    color:#0A0A0A;font-size:.82rem;font-weight:700;padding:.35rem 1rem;
    border-radius:50px;margin-top:.4rem
  }
  .meta{display:flex;justify-content:center;flex-wrap:wrap;gap:.6rem;margin-top:1.2rem}
  .meta span{font-size:.74rem;color:rgba(255,255,255,.55);background:rgba(255,255,255,.1);padding:.2rem .75rem;border-radius:50px}

  article{max-width:680px;margin:0 auto;padding:2.5rem 1.5rem 4rem}
  article p{margin-bottom:1.3rem;font-size:.97rem;font-weight:300}
  article h2{font-family:'Playfair Display',serif;font-size:1.2rem;font-weight:700;color:var(--charcoal);margin:2rem 0 .7rem}

  /* Les 20 pièces */
  .capsule{display:grid;grid-template-columns:1fr 1fr;gap:0;margin:1.5rem 0;border:1px solid var(--b);border-radius:13px;overflow:hidden}
  .capsule-cat{background:var(--charcoal);color:#fff;padding:.6rem 1rem;font-size:.72rem;font-weight:600;text-transform:uppercase;letter-spacing:.07em;grid-column:1/-1;border-bottom:1px solid rgba(255,255,255,.08)}
  .capsule-item{padding:.55rem 1rem;font-size:.84rem;font-weight:300;color:var(--t);border-bottom:1px solid var(--b);display:flex;align-items:center;gap:.6rem}
  .capsule-item:nth-child(odd){background:var(--w)}
  .capsule-item:nth-child(even){background:#FAFAF8}
  .capsule-item:last-child{border-bottom:none}
  .capsule-num{font-family:'Playfair Display',serif;font-weight:900;font-size:1rem;color:var(--ecru);min-width:1.4rem;line-height:1;color:var(--slate)}

  /* Règle des couleurs */
  .couleurs{display:flex;gap:.5rem;margin:1.3rem 0;flex-wrap:wrap}
  .couleur-chip{border-radius:50px;padding:.35rem .9rem;font-size:.78rem;font-weight:500;border:1px solid rgba(0,0,0,.08)}

  /* Calcul coût */
  .calcul{display:grid;grid-template-columns:1fr 1fr;gap:.7rem;margin:1.5rem 0}
  .calcul-block{border-radius:12px;padding:1rem 1.1rem;text-align:center}
  .calcul-block.avant{background:#FEE2E2;border:1px solid rgba(185,28,28,.15)}
  .calcul-block.apres{background:var(--gl);border:1px solid rgba(29,158,117,.2)}
  .calcul-label{font-size:.72rem;font-weight:500;text-transform:uppercase;letter-spacing:.06em;margin-bottom:.4rem}
  .calcul-block.avant .calcul-label{color:#991B1B}
  .calcul-block.apres .calcul-label{color:var(--gd)}
  .calcul-val{font-family:'Playfair Display',serif;font-size:1.7rem;font-weight:900}
  .calcul-block.avant .calcul-val{color:#B91C1C}
  .calcul-block.apres .calcul-val{color:var(--gd)}
  .calcul-sub{font-size:.75rem;color:var(--m);margin-top:.2rem;font-weight:300}

  .conseil{
    background:linear-gradient(135deg,#1A1A1A,#2D2D2D);
    border-radius:12px;padding:1.2rem 1.4rem;margin:1.8rem 0;color:#fff
  }
  .conseil strong{display:block;color:var(--blush);font-weight:500;font-size:.92rem;margin-bottom:.4rem}
  .conseil p{font-size:.88rem;color:rgba(255,255,255,.82);font-weight:300;margin:0;line-height:1.65}

  footer{background:var(--gd);color:rgba(255,255,255,0.6);text-align:center;padding:1.6rem;font-size:.8rem}
  footer strong{color:white}
  footer a{color:var(--a);text-decoration:none}
  @media(max-width:500px){.capsule{grid-template-columns:1fr}.calcul{grid-template-columns:1fr}}

/* Menu hamburger mobile */
.hamburger{display:none;flex-direction:column;gap:5px;cursor:pointer;background:none;border:none;padding:.3rem}
.hamburger span{display:block;width:24px;height:2px;background:var(--gd,#085041);border-radius:2px;transition:all .3s}
.mobile-menu{display:none;position:fixed;top:0;left:0;right:0;bottom:0;background:rgba(255,255,255,.98);z-index:999;flex-direction:column;align-items:center;justify-content:center;gap:1.5rem}
.mobile-menu.open{display:flex}
.mobile-menu a{font-family:'Playfair Display',serif;font-size:1.3rem;font-weight:700;color:#085041;text-decoration:none}
.mobile-menu .close-btn{position:absolute;top:1.2rem;right:1.5rem;background:none;border:none;font-size:1.8rem;cursor:pointer;color:#085041}
.mobile-menu .nav-cta{background:#1D9E75;color:white!important;padding:.5rem 1.4rem;border-radius:50px}
@media(max-width:768px){
  .hamburger{display:flex}
  nav .nav-links,nav > a:not(.logo),nav > div:not(.mobile-menu){display:none!important}
  nav li{display:none!important}
}
</style>
