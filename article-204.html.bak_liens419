  .logo{font-family:'Playfair Display',serif;font-weight:900;font-size:1.3rem;color:#085041;text-decoration:none}
  .logo span{color:#EF9F27}
  .back{font-size:.82rem;color:#5F5E5A;text-decoration:none}
  .back:hover{color:#1D9E75}

  /* HERO — ardoise → violet prune → rose poudré */
  .hero{background:linear-gradient(135deg,#0D0A18 0%,#2D1760 32%,#6B21A8 62%,#C026D3 84%,#F0ABFC 100%);padding:3.8rem 2rem 3.2rem;text-align:center;position:relative;overflow:hidden}
  .hero::before{content:'⚖️';position:absolute;font-size:14rem;opacity:.05;top:50%;left:50%;transform:translate(jusqu'à -50%,jusqu'à -50%);pointer-events:none}
