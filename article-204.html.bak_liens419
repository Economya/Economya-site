  .hero-cat strong{color:#fff}
  .hero h1{font-family:'Playfair Display',serif;font-size:clamp(1.8rem,4.5vw,2.7rem);font-weight:900;color:#fff;line-height:1.1;max-width:640px;margin:.3rem auto .9rem}
  .hero-badge{display:inline-block;background:linear-gradient(90deg,#F0ABFC,#E879F9);color:#0D0A18;font-size:.82rem;font-weight:700;padding:.35rem 1.1rem;border-radius:50px}
  .hero-meta{display:flex;justify-content:center;flex-wrap:wrap;gap:.55rem;margin-top:1.2rem}
  .hero-meta span{font-size:.73rem;color:rgba(255,255,255,.5);background:rgba(255,255,255,.09);padding:.2rem .75rem;border-radius:50px}

  article{max-width:700px;margin:0 auto;padding:2.5rem 1.5rem 5rem}
  article p{margin-bottom:1.3rem;font-size:.97rem;font-weight:300;line-height:1.75}
  h2{font-family:'Playfair Display',serif;font-size:1.2rem;font-weight:700;color:#2D1760;margin:2.2rem 0 .8rem}

  /* DÉCOMPOSITION VISUELLE EN BLOCS */
  .decompo{display:flex;flex-direction:column;gap:.7rem;margin:1.5rem 0}
  .bloc{border-radius:12px;overflow:hidden;border:1px solid rgba(0,0,0,.08)}
  .bloc-head{display:flex;justify-content:space-between;align-items:center;padding:.75rem 1.1rem;color:#fff}
  .bloc-head.impots{background:linear-gradient(90deg,#3B0764,#6B21A8)}
  .bloc-head.emol{background:linear-gradient(90deg,#0C4A6E,#0284C7)}
  .bloc-head.debours{background:linear-gradient(90deg,#14532D,#15803D)}
  .bloc-head.contrib{background:linear-gradient(90deg,#7C2D12,#C2410C)}
  .bloc-nom{font-weight:600;font-size:.88rem}
  .bloc-pct{font-family:'Playfair Display',serif;font-size:1.1rem;font-weight:900}
  .bloc-body{background:#fff;padding:.75rem 1.1rem;font-size:.83rem;font-weight:300;color:#5F5E5A;line-height:1.55}

  /* TABLEAU COMPARATIF NEUF/ANCIEN */
  .compare{display:grid;grid-template-columns:1fr 1fr;gap:1rem;margin:1.5rem 0}
  .compare-col{border-radius:12px;overflow:hidden;border:1px solid rgba(0,0,0,.08)}
  .compare-head{padding:.7rem 1rem;color:#fff;font-weight:700;font-size:.9rem;text-align:center}
  .compare-head.ancien{background:linear-gradient(135deg,#2D1760,#6B21A8)}
  .compare-head.neuf{background:linear-gradient(135deg,#14532D,#15803D)}
  .compare-body{background:#fff;padding:.8rem 1rem}
  .compare-item{display:flex;justify-content:space-between;padding:.3rem 0;border-bottom:1px dotted rgba(0,0,0,.08);font-size:.83rem}
  .compare-item:last-child{border-bottom:none;font-weight:600;font-size:.9rem;padding-top:.5rem}
  .compare-label{font-weight:300;color:#5F5E5A}
  .compare-val{font-weight:500;color:#2C2C2A}
  .compare-val.total{color:#6B21A8}
  .compare-val.total.green{color:#15803D}

  /* SIMULATEUR */
  .simul{background:linear-gradient(135deg,#0D0A18,#2D1760);border-radius:13px;padding:1.3rem 1.5rem;margin:1.5rem 0;color:#fff}
  .simul h3{font-family:'Playfair Display',serif;font-size:1rem;font-weight:700;color:#F0ABFC;margin-bottom:1rem}
  .simul-row{display:flex;justify-content:space-between;align-items:baseline;padding:.4rem 0;border-bottom:1px solid rgba(255,255,255,.08);font-size:.85rem}
  .simul-row:last-child{border-bottom:none;padding-top:.6rem;margin-top:.2rem}
  .simul-label{font-weight:300;color:rgba(255,255,255,.8)}
  .simul-val{font-weight:600;color:#F0ABFC;white-space:nowrap}
  .simul-label.total{font-weight:600;color:#fff}
  .simul-val.total{font-size:1.1rem}

  /* ASTUCES POUR RÉDUIRE */
  .astuces{display:grid;grid-template-columns:1fr 1fr;gap:.7rem;margin:1.5rem 0}
  .astuce{background:#fff;border:1px solid rgba(0,0,0,.08);border-radius:11px;padding:.9rem 1rem}
  .astuce-ico{font-size:1.4rem;margin-bottom:.35rem}
  .astuce-titre{font-weight:500;font-size:.88rem;color:#2D1760;margin-bottom:.2rem}
  .astuce-desc{font-size:.8rem;font-weight:300;color:#5F5E5A;line-height:1.45}

  .conseil{background:linear-gradient(135deg,#0D0A18,#2D1760);border-radius:13px;padding:1.3rem 1.5rem;margin:2rem 0;color:#fff;border:1px solid rgba(240,171,252,.12)}
  .conseil strong{display:block;color:#F0ABFC;font-weight:500;font-size:.93rem;margin-bottom:.4rem}
  .conseil p{font-size:.88rem;color:rgba(255,255,255,.8);font-weight:300;margin:0;line-height:1.65}

  footer{background:#085041;color:rgba(255,255,255,.6);text-align:center;padding:1.6rem;font-size:.8rem}
  footer strong{color:#fff}
  footer a{color:#EF9F27;text-decoration:none}
  @media(max-width:500px){.compare{grid-template-columns:1fr}.astuces{grid-template-columns:1fr}}

