  <meta name="twitter:title" content="Simulateur d'épargne">
  <meta name="twitter:description" content="Conseils, outils et astuces pour économiser au quotidien sur Economya.fr">
  <meta name="twitter:image" content="https://economya.fr/og-image.svg">
<link rel="canonical" href="https://economya.fr/simulateur-epargne.html" />
<meta name="description" content="Simulateur d'épargne — Economya.fr" />
</head>
<body>
<nav>
  <a class="logo" href="index.html">Econom<span>ya</span>.fr</a>
  <a class="nav-back" href="index.html">← Tous les articles</a>
  <a href="recherche.html" style="text-decoration:none;color:var(--m);font-size:.82rem;font-weight:500">🔍 Rechercher</a>

<!-- Menu hamburger mobile -->

<button class="hamburger" onclick="toggleMenu()" aria-label="Menu"><span></span><span></span><span></span></button></nav><div class="mobile-menu" id="mobileMenu"><button class="close-btn" onclick="toggleMenu()">X</button><a href="index.html">Accueil</a><a href="jeux.html">Jeux</a><a href="outils-gratuits.html">Outils gratuits</a><a href="comparateurs.html">Comparateurs</a><a href="a-propos.html">A propos</a><a href="recherche.html">Rechercher</a></div>

<div class="hero">
  <h1>Simulateur d'<em>épargne</em></h1>
  <p>Calculez combien votre épargne va rapporter selon vos versements, votre taux et votre horizon de placement.</p>
</div>

<div class="container">
  <div class="card">
    <h2>⚙️ Vos paramètres</h2>
    <div class="grid">
      <div class="field">
        <label>Versement mensuel</label>
        <div class="val" id="v-mensuel">200 <span>€/mois</span></div>
        <input type="range" id="mensuel" min="10" max="2000" step="10" value="200">
      </div>
      <div class="field">
        <label>Capital initial</label>
        <div class="val" id="v-initial">1 000 <span>€</span></div>
        <input type="range" id="initial" min="0" max="50000" step="500" value="1000">
      </div>
      <div class="field">
        <label>Taux annuel</label>
        <div class="val" id="v-taux">3,0 <span>%</span></div>
        <input type="range" id="taux" min="0.5" max="10" step="0.5" value="3">
      </div>
      <div class="field">
        <label>Durée</label>
        <div class="val" id="v-duree">10 <span>ans</span></div>
        <input type="range" id="duree" min="1" max="40" step="1" value="10">
      </div>
    </div>
  </div>

  <div class="results">
    <h2>📊 Résultats de votre simulation</h2>
    <div class="res-grid">
      <div class="res-item">
        <span class="num" id="r-total">0 €</span>
        <div class="lbl">Capital final</div>
      </div>
      <div class="res-item">
        <span class="num" id="r-verse">0 €</span>
        <div class="lbl">Total versé</div>
      </div>
      <div class="res-item">
        <span class="num" id="r-interets">0 €</span>
        <div class="lbl">Intérêts gagnés</div>
      </div>
      <div class="res-item">
        <span class="num" id="r-rendement">0%</span>
        <div class="lbl">Rendement total</div>
      </div>
    </div>
  </div>

  <div class="chart-wrap">
    <h2>📈 Évolution de votre épargne</h2>
    <canvas id="myChart"></canvas>
  </div>

  <div class="tip" id="tip-text">
    <strong>💡 Conseil :</strong> Avec 200 €/mois à 3%, vous doublez votre capital en 20 ans grâce aux intérêts composés.
  </div>

  <div class="cta">
    <h3>📬 Recevez nos conseils épargne chaque semaine</h3>
    <p>Les meilleurs placements, taux et astuces pour faire fructifier votre argent.</p>
    <div class="cta-form">
      <input type="email" placeholder="votre@email.fr">
      <button>Je m'abonne</button>
    </div>
  </div>
</div>


<!-- Boutons partage -->
<div style="background:#fff;border-radius:16px;border:1px solid rgba(0,0,0,0.08);padding:1.2rem 1.5rem;margin:2rem auto;max-width:680px;text-align:center">
  <p style="font-size:.82rem;font-weight:600;color:#5F5E5A;margin-bottom:.8rem;text-transform:uppercase;letter-spacing:.05em">Partager cet article</p>
  <div style="display:flex;gap:.6rem;justify-content:center;flex-wrap:wrap">
    <a href="https://www.facebook.com/sharer/sharer.php?u=URL_PAGE" target="_blank" rel="noopener" style="background:#1877F2;color:white;text-decoration:none;padding:.5rem 1.1rem;border-radius:50px;font-size:.82rem;font-weight:600;display:inline-flex;align-items:center;gap:.4rem">📘 Facebook</a>
    <a href="https://twitter.com/intent/tweet?url=URL_PAGE&text=TITRE_PAGE" target="_blank" rel="noopener" style="background:#000;color:white;text-decoration:none;padding:.5rem 1.1rem;border-radius:50px;font-size:.82rem;font-weight:600;display:inline-flex;align-items:center;gap:.4rem">𝕏 Twitter</a>
    <a href="https://www.linkedin.com/sharing/share-offsite/?url=URL_PAGE" target="_blank" rel="noopener" style="background:#0A66C2;color:white;text-decoration:none;padding:.5rem 1.1rem;border-radius:50px;font-size:.82rem;font-weight:600;display:inline-flex;align-items:center;gap:.4rem">💼 LinkedIn</a>
    <a href="whatsapp://send?text=TITRE_PAGE - URL_PAGE" target="_blank" rel="noopener" style="background:#25D366;color:white;text-decoration:none;padding:.5rem 1.1rem;border-radius:50px;font-size:.82rem;font-weight:600;display:inline-flex;align-items:center;gap:.4rem">💬 WhatsApp</a>
    <a href="https://pinterest.com/pin/create/button/?url=URL_PAGE&description=TITRE_PAGE" target="_blank" rel="noopener" style="background:#E60023;color:white;text-decoration:none;padding:.5rem 1.1rem;border-radius:50px;font-size:.82rem;font-weight:600;display:inline-flex;align-items:center;gap:.4rem">📌 Pinterest</a>
  </div>
</div>
<script>
(function(){
  var url = encodeURIComponent(window.location.href);
  var titre = encodeURIComponent(document.title);
  document.querySelectorAll('a[href*="URL_PAGE"]').forEach(function(a){
    a.href = a.href.replace(/URL_PAGE/g, url).replace(/TITRE_PAGE/g, titre);
  });
})();
</script>

<footer>
  <strong>Economya.fr</strong> · Votre meilleur allié finance · Fait avec ❤️ en France<br>
  <span style="font-size:.75rem;margin-top:.4rem;display:block">© 2025 · Simulation à titre indicatif, ne constitue pas un conseil financier.</span>
</footer>

<script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/4.4.0/chart.umd.min.js"></script>
<script>
const fmt = n => {
  if(n >= 1000000) return (n/1000000).toFixed(1) + 'M €';
  if(n >= 1000) return Math.round(n).toLocaleString('fr-FR') + ' €';
  return Math.round(n) + ' €';
};

let chart;

function calculate() {
  const mensuel = +document.getElementById('mensuel').value;
  const initial = +document.getElementById('initial').value;
  const taux = +document.getElementById('taux').value / 100;
  const duree = +document.getElementById('duree').value;
  const tauxMensuel = taux / 12;
  const mois = duree * 12;

  // Mise à jour affichage sliders
  document.getElementById('v-mensuel').innerHTML = mensuel.toLocaleString('fr-FR') + ' <span>€/mois</span>';
  document.getElementById('v-initial').innerHTML = initial.toLocaleString('fr-FR') + ' <span>€</span>';
  document.getElementById('v-taux').innerHTML = (+document.getElementById('taux').value).toFixed(1) + ' <span>%</span>';
  document.getElementById('v-duree').innerHTML = duree + ' <span>ans</span>';

  // Calcul intérêts composés
  let capital = initial;
  const labels = [];
  const dataCapital = [];
  const dataVerse = [];

  for(let a = 0; a <= duree; a++) {
    labels.push(a + ' an' + (a > 1 ? 's' : ''));
    const verse = initial + mensuel * 12 * a;
    let cap = initial * Math.pow(1 + taux, a);
    if(tauxMensuel > 0) {
      cap += mensuel * (Math.pow(1 + tauxMensuel, a*12) - 1) / tauxMensuel;
    } else {
      cap += mensuel * a * 12;
    }
    dataCapital.push(Math.round(cap));
    dataVerse.push(Math.round(verse));
  }

  const totalVerse = initial + mensuel * mois;
  const capitalFinal = dataCapital[duree];
  const interets = capitalFinal - totalVerse;
  const rendement = ((capitalFinal - totalVerse) / totalVerse * 100).toFixed(1);

  document.getElementById('r-total').textContent = fmt(capitalFinal);
  document.getElementById('r-verse').textContent = fmt(totalVerse);
  document.getElementById('r-interets').textContent = fmt(interets);
  document.getElementById('r-rendement').textContent = rendement + '%';

  // Conseil dynamique
  const tipEl = document.getElementById('tip-text');
  if(interets > totalVerse * 0.5) {
    tipEl.innerHTML = `<strong>🎉 Excellent !</strong> Les intérêts composés font travailler votre argent — vous gagnez <strong>${fmt(interets)}</strong> sans effort supplémentaire.`;
  } else {
    tipEl.innerHTML = `<strong>💡 Conseil :</strong> Augmentez la durée ou le taux pour maximiser les intérêts composés. Sur ${duree} ans vous gagnez ${fmt(interets)} d'intérêts.`;
  }

  // Graphique
  if(chart) chart.destroy();
  const ctx = document.getElementById('myChart').getContext('2d');
  chart = new Chart(ctx, {
    type: 'line',
    data: {
      labels,
      datasets: [
        {
          label: 'Capital avec intérêts',
          data: dataCapital,
          borderColor: '#1D9E75',
          backgroundColor: 'rgba(29,158,117,0.1)',
          fill: true,
          tension: 0.4,
          pointRadius: 3
        },
        {
          label: 'Total versé',
          data: dataVerse,
          borderColor: '#EF9F27',
          backgroundColor: 'rgba(239,159,39,0.05)',
          fill: true,
          tension: 0.4,
          borderDash: [5,5],
          pointRadius: 2
        }
      ]
    },
    options: {
      responsive: true,
      plugins: {
        legend: { position: 'bottom' },
        tooltip: {
          callbacks: {
            label: ctx => ctx.dataset.label + ' : ' + ctx.parsed.y.toLocaleString('fr-FR') + ' €'
          }
        }
      },
      scales: {
        y: {
          ticks: {
            callback: v => v >= 1000 ? (v/1000).toFixed(0) + 'k €' : v + ' €'
          }
        }
      }
    }
  });
}

document.querySelectorAll('input[type=range]').forEach(el => {
  el.addEventListener('input', calculate);
});

calculate();
</script>
<script>function toggleMenu(){var m=document.getElementById("mobileMenu");m.classList.toggle("open");document.body.style.overflow=m.classList.contains("open")?"hidden":"";}</script></body>
</html>
