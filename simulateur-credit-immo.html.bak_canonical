<script>
const fmt = n => Math.round(n).toLocaleString('fr-FR') + ' €';
const fmtM = n => (Math.round(n * 100) / 100).toLocaleString('fr-FR', {minimumFractionDigits:2, maximumFractionDigits:2}) + ' €';

function calculate() {
  const prix = +document.getElementById('prix').value;
  const apport = +document.getElementById('apport').value;
  const taux = +document.getElementById('taux').value;
  const duree = +document.getElementById('duree').value;

  document.getElementById('v-prix').innerHTML = prix.toLocaleString('fr-FR') + ' <span>€</span>';
  document.getElementById('v-apport').innerHTML = apport.toLocaleString('fr-FR') + ' <span>€</span>';
  document.getElementById('v-taux').innerHTML = taux.toFixed(1) + ' <span>%</span>';
  document.getElementById('v-duree').innerHTML = duree + ' <span>ans</span>';

  const emprunt = Math.max(0, prix - apport);
  const tauxM = taux / 100 / 12;
  const n = duree * 12;

  let mensualite;
  if(tauxM === 0) {
    mensualite = emprunt / n;
  } else {
    mensualite = emprunt * tauxM * Math.pow(1 + tauxM, n) / (Math.pow(1 + tauxM, n) - 1);
  }

  const totalRembourse = mensualite * n;
  const totalInterets = totalRembourse - emprunt;
  const tauxEffort = (mensualite / 3500 * 100).toFixed(1);

  document.getElementById('r-mensualite').textContent = fmtM(mensualite);
  document.getElementById('r-emprunt').textContent = fmt(emprunt);
  document.getElementById('r-total').textContent = fmt(totalRembourse);
  document.getElementById('r-interets').textContent = fmt(totalInterets);
  document.getElementById('r-taux-effort').textContent = tauxEffort + '%';

  // Conseil
  const tip = document.getElementById('tip-text');
  const pct = apport / prix * 100;
  if(pct < 10) {
    tip.innerHTML = '<strong>⚠️ Apport faible :</strong> Les banques recommandent 10% minimum. Augmentez votre apport pour obtenir un meilleur taux et éviter les frais de garantie élevés.';
  } else if(+tauxEffort > 35) {
    tip.innerHTML = `<strong>⚠️ Taux d'effort élevé :</strong> Votre mensualité représente ${tauxEffort}% de revenus (sur 3 500 €). Les banques acceptent généralement jusqu'à 35%. Allongez la durée ou réduisez le montant.`;
  } else {
    tip.innerHTML = `<strong>✅ Projet finançable :</strong> Avec ${pct.toFixed(0)}% d'apport et une mensualité de ${fmtM(mensualite)}, votre dossier est solide. Comparez les offres de plusieurs banques pour négocier le meilleur taux.`;
  }

  // Tableau amortissement
  const tbody = document.getElementById('tableau-body');
  tbody.innerHTML = '';
  let capitalRestant = emprunt;

  const maxAnnees = Math.min(5, duree);
  for(let a = 1; a <= maxAnnees; a++) {
    let capitalAnnee = 0;
    let interetsAnnee = 0;
    for(let m = 0; m < 12; m++) {
      const interetsMois = capitalRestant * tauxM;
      const capitalMois = mensualite - interetsMois;
      capitalAnnee += capitalMois;
      interetsAnnee += interetsMois;
      capitalRestant -= capitalMois;
    }
    const tr = document.createElement('tr');
    tr.innerHTML = `
      <td><strong>Année ${a}</strong></td>
      <td>${fmtM(mensualite)}</td>
      <td>${fmt(capitalAnnee)}</td>
      <td>${fmt(interetsAnnee)}</td>
      <td>${fmt(Math.max(0, capitalRestant))}</td>
    `;
    tbody.appendChild(tr);
  }
}

document.querySelectorAll('input[type=range]').forEach(el => el.addEventListener('input', calculate));
calculate();
</script>
