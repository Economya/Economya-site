  article{max-width:700px;margin:0 auto;padding:2.5rem 1.5rem 5rem}
  article p{margin-bottom:1.3rem;font-size:.97rem;font-weight:300;line-height:1.75}
  h2{font-family:'Playfair Display',serif;font-size:1.2rem;font-weight:700;color:#301818;margin:2.2rem 0 .8rem}

  /* MAJORATION VISUELLE */
  .majorations{display:grid;grid-template-columns:repeat(3,1fr);gap:.75rem;margin:1.5rem 0}
  .major{background:#fff;border:1px solid rgba(0,0,0,.08);border-radius:12px;text-align:center;padding:1rem .9rem;overflow:hidden;position:relative}
  .major::before{content:'';position:absolute;top:0;left:0;right:0;height:4px}
  .major:nth-child(1)::before{background:linear-gradient(90deg,#703020,#C05828)}
  .major:nth-child(2)::before{background:linear-gradient(90deg,#C05828,#E08040)}
  .major:nth-child(3)::before{background:linear-gradient(90deg,#303070,#6060C0)}
  .major-label{font-size:.72rem;font-weight:600;text-transform:uppercase;letter-spacing:.05em;color:#5F5E5A;margin-bottom:.4rem}
  .major-pct{font-family:'Playfair Display',serif;font-size:2.2rem;font-weight:900;line-height:1}
  .major:nth-child(1) .major-pct{color:#C05828}
  .major:nth-child(2) .major-pct{color:#E08040}
  .major:nth-child(3) .major-pct{color:#6060C0}
  .major-detail{font-size:.73rem;font-weight:300;color:#5F5E5A;margin-top:.3rem;line-height:1.35}

  /* CALCUL TAUX HORAIRE */
  .calcul{background:#fff;border:1px solid rgba(0,0,0,.08);border-radius:13px;overflow:hidden;margin:1.5rem 0}
  .calcul-head{background:linear-gradient(90deg,#301818,#703020);padding:.8rem 1.2rem;color:#fff;font-family:'Playfair Display',serif;font-weight:700;font-size:.95rem}
  .calcul-row{display:grid;grid-template-columns:1.2fr 1fr 1fr 1fr;align-items:center;border-bottom:1px solid rgba(0,0,0,.06);font-size:.82rem;min-height:42px}
  .calcul-row.header{background:#FFF5EE;font-weight:600;font-size:.72rem;color:#703020;text-transform:uppercase;letter-spacing:.04em}
  .calcul-row:last-child{border-bottom:none;background:#FFF5EE}
  .calcul-row:nth-child(even):not(.header):not(:last-child){background:#FAFAFA}
  .calcul-cell{padding:.5rem .85rem;font-weight:300;color:#2C2C2A}
  .calcul-cell.label{font-weight:500;color:#703020}
  .calcul-cell.montant{font-weight:600;color:#C05828}
  .calcul-cell.total{font-weight:700;color:#065F46}

  /* DROITS — tableau simple */
  .tableau{width:100%;border-collapse:collapse;margin:1.5rem 0;font-size:.83rem}
  .tableau thead tr{background:linear-gradient(90deg,#301818,#703020);color:#fff}
  .tableau thead th{padding:.65rem .9rem;text-align:left;font-weight:500}
  .tableau tbody tr:nth-child(even){background:#FFF5EE}
  .tableau tbody tr:nth-child(odd){background:#fff}
  .tableau tbody td{padding:.58rem .9rem;border-bottom:1px solid rgba(0,0,0,.06);font-weight:300}
  .tableau tbody td:first-child{font-weight:500;color:#703020}
  .tableau td.ok{color:#065F46;font-weight:500}
  .tableau td.warn{color:#8B4500;font-weight:500}

  /* CAS PARTICULIERS */
  .cas{display:flex;flex-direction:column;gap:.55rem;margin:1.4rem 0}
  .cas-item{display:flex;gap:.75rem;align-items:flex-start;padding:.7rem 1rem;border-radius:10px;background:#fff;border:1px solid rgba(0,0,0,.07)}
  .cas-ico{font-size:1.1rem;flex-shrink:0;margin-top:.08rem}
  .cas-text{font-size:.83rem;font-weight:300;color:#2C2C2A;line-height:1.5}
  .cas-text strong{font-weight:500;color:#703020;display:block;margin-bottom:.1rem}

  /* SIMULATION */
  .simul{background:linear-gradient(135deg,#100808,#301818);border-radius:13px;padding:1.3rem 1.5rem;margin:1.5rem 0;color:#fff}
  .simul h3{font-family:'Playfair Display',serif;font-size:1rem;font-weight:700;color:#F0A060;margin-bottom:.9rem}
  .simul-row{display:flex;justify-content:space-between;padding:.4rem 0;border-bottom:1px solid rgba(255,255,255,.07);font-size:.84rem}
  .simul-row:last-child{border-bottom:none;padding-top:.55rem;margin-top:.2rem}
  .simul-lab{font-weight:300;color:rgba(255,255,255,.8)}
  .simul-val{font-weight:600;color:#F0A060;white-space:nowrap}
  .simul-lab.total{font-weight:600;color:#fff}
  .simul-val.total{font-size:1rem}
  .simul-val.green{color:#6EE7B7}

  .encadre{border-left:4px solid #C05828;background:#FFF5EE;border-radius:0 10px 10px 0;padding:1rem 1.2rem;margin:1.5rem 0}
  .encadre strong{display:block;color:#703020;font-size:.9rem;margin-bottom:.3rem}
  .encadre p{font-size:.84rem;font-weight:300;color:#8B4500;margin:0;line-height:1.6}

  .conseil{background:linear-gradient(135deg,#100808,#301818);border-radius:13px;padding:1.3rem 1.5rem;margin:2rem 0;color:#fff;border:1px solid rgba(240,160,96,.12)}
  .conseil strong{display:block;color:#F0A060;font-weight:500;font-size:.93rem;margin-bottom:.4rem}
  .conseil p{font-size:.88rem;color:rgba(255,255,255,.8);font-weight:300;margin:0;line-height:1.65}

  footer{background:#085041;color:rgba(255,255,255,.6);text-align:center;padding:1.6rem;font-size:.8rem}
  footer strong{color:#fff}
  footer a{color:#EF9F27;text-decoration:none}
  @media(max-width:500px){.majorations{grid-template-columns:1fr 1fr}.calcul-row{grid-template-columns:1fr 1fr}}

