  .hero-badge{display:inline-block;background:linear-gradient(90deg,#F0A060,#C05828);color:#100808;font-size:.82rem;font-weight:700;padding:.35rem 1.1rem;border-radius:50px}
  .hero-meta{display:flex;justify-content:center;flex-wrap:wrap;gap:.55rem;margin-top:1.2rem}
