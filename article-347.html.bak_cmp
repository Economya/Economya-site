p{margin-bottom:1rem;font-size:.95rem}

/* COMPARATIF */
.compare{display:grid;grid-template-columns:1fr 1fr;gap:1.2rem;margin:1.5rem 0}
@media(max-width:520px){.compare{grid-template-columns:1fr}}
.comp{border-radius:var(--r);padding:1.3rem}
.comp.nu{background:#f9fafb;border:1px solid var(--b)}
.comp.coloc{background:var(--gl);border:2px solid #86efac}
.comp-title{font-weight:700;font-size:.95rem;margin-bottom:.6rem}
.comp.nu .comp-title{color:var(--m)}
.comp.coloc .comp-title{color:var(--gd)}
.comp-items{list-style:none;display:flex;flex-direction:column;gap:.35rem}
