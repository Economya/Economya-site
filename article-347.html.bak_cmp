.comp-items li:last-child{border-bottom:none;font-weight:700;padding-top:.4rem}
.comp.nu .comp-items li{color:var(--m)}
.comp.coloc .comp-items li{color:var(--gd)}

/* ASTUCES */
.astuces{display:flex;flex-direction:column;gap:.85rem;margin:1.5rem 0}
