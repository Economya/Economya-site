<!DOCTYPE html>
<html lang="fr">
<head>
<meta charset="UTF-8">
<meta name="description" content="Complémentaire santé solidaire (CSS) gratuite — Mutuelle gratuite ou 1€/jour. Guide complet sur Economya.fr">

<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Complémentaire santé solidaire (CSS) gratuite — Economya.fr</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;700;900&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet">
<style>
  *,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
  body{font-family:'DM Sans',sans-serif;background:#FAFAF8;color:#2C2C2A;line-height:1.7}
  nav{display:flex;justify-content:space-between;align-items:center;padding:.9rem 1.8rem;background:#fff;border-bottom:1px solid rgba(0,0,0,.08);position:sticky;top:0;z-index:99}
  .logo{font-family:'Playfair Display',serif;font-weight:900;font-size:1.3rem;color:#085041;text-decoration:none}
  .logo span{color:#EF9F27}
  .back{font-size:.82rem;color:#5F5E5A;text-decoration:none}
  .back:hover{color:#1D9E75}

  /* HERO — vert forêt profond → olive → citron vert */
  .hero{background:linear-gradient(135deg,#041008 0%,#0E3818 32%,#287040 62%,#48B060 84%,#A0E880 100%);padding:3.8rem 2rem 3.2rem;text-align:center;position:relative;overflow:hidden}
  .hero::before{content:'🆓';position:absolute;font-size:14rem;opacity:.05;top:50%;left:50%;transform:translate(jusqu'à -50%,jusqu'à -50%);pointer-events:none}
  .hero-cat{font-size:.82rem;font-weight:500;color:rgba(255,255,255,.6);margin-bottom:.6rem;letter-spacing:.05em}
  .hero-cat strong{color:#fff}
  .hero h1{font-family:'Playfair Display',serif;font-size:clamp(1.8rem,4.5vw,2.7rem);font-weight:900;color:#fff;line-height:1.1;max-width:640px;margin:.3rem auto .9rem}
  .hero-badge{display:inline-block;background:linear-gradient(90deg,#A0E880,#48B060);color:#041008;font-size:.82rem;font-weight:700;padding:.35rem 1.1rem;border-radius:50px}
  .hero-meta{display:flex;justify-content:center;flex-wrap:wrap;gap:.55rem;margin-top:1.2rem}
  .hero-meta span{font-size:.73rem;color:rgba(255,255,255,.5);background:rgba(255,255,255,.09);padding:.2rem .75rem;border-radius:50px}

  article{max-width:700px;margin:0 auto;padding:2.5rem 1.5rem 5rem}
  article p{margin-bottom:1.3rem;font-size:.97rem;font-weight:300;line-height:1.75}
  h2{font-family:'Playfair Display',serif;font-size:1.2rem;font-weight:700;color:#0E3818;margin:2.2rem 0 .8rem}

  /* LES 2 NIVEAUX */
  .niveaux{display:grid;grid-template-columns:1fr 1fr;gap:.9rem;margin:1.5rem 0}
  .niveau{border-radius:13px;overflow:hidden;border:1px solid rgba(0,0,0,.08)}
  .niv-head{padding:.8rem 1rem;color:#fff;font-weight:700;font-size:.9rem;text-align:center}
  .niv-head.gratuit{background:linear-gradient(135deg,#0E3818,#287040)}
  .niv-head.euro{background:linear-gradient(135deg,#0A2848,#1060A8)}
  .niv-body{background:#fff;padding:.9rem 1rem}
  .niv-prix{font-family:'Playfair Display',serif;font-size:2.2rem;font-weight:900;text-align:center;line-height:1;margin:.3rem 0 .1rem}
  .niv-prix.green{color:#287040}
  .niv-prix.blue{color:#1060A8}
  .niv-sous{font-size:.72rem;color:#5F5E5A;text-align:center;margin-bottom:.6rem}
  .niv-row{display:flex;justify-content:space-between;padding:.25rem 0;border-bottom:1px dotted rgba(0,0,0,.07);font-size:.81rem}
  .niv-row:last-child{border-bottom:none}
  .niv-label{font-weight:300;color:#5F5E5A}
  .niv-val{font-weight:500;color:#2C2C2A}

  /* PLAFONDS */
  .tableau{width:100%;border-collapse:collapse;margin:1.5rem 0;font-size:.82rem}
  .tableau thead tr{background:linear-gradient(90deg,#0E3818,#287040);color:#fff}
  .tableau thead th{padding:.65rem .85rem;text-align:left;font-weight:500}
  .tableau tbody tr:nth-child(even){background:#F0FDF4}
  .tableau tbody tr:nth-child(odd){background:#fff}
  .tableau tbody td{padding:.55rem .85rem;border-bottom:1px solid rgba(0,0,0,.06);font-weight:300}
  .tableau tbody td:first-child{font-weight:500;color:#0E3818}
  .tableau td.ok{color:#065F46;font-weight:600}
  .tableau td.warn{color:#8B4500;font-weight:500}

  /* GARANTIES */
  .garanties{display:grid;grid-template-columns:1fr 1fr;gap:.65rem;margin:1.5rem 0}
  .gar{background:#fff;border:1px solid rgba(0,0,0,.08);border-radius:10px;padding:.8rem .9rem}
  .gar-ico{font-size:1.2rem;margin-bottom:.3rem}
  .gar-titre{font-weight:500;font-size:.85rem;color:#0E3818;margin-bottom:.18rem}
  .gar-desc{font-size:.78rem;font-weight:300;color:#5F5E5A;line-height:1.45}

  /* ÉTAPES DEMANDE */
  .etapes{display:flex;flex-direction:column;gap:0;margin:1.5rem 0;position:relative}
  .etapes::before{content:'';position:absolute;left:21px;top:22px;bottom:22px;width:2px;background:linear-gradient(180deg,#287040,#48B060 60%,rgba(72,176,96,.1))}
  .etape{display:grid;grid-template-columns:44px 1fr;gap:.9rem;padding:.7rem 0}
  .etape-dot{width:44px;height:44px;border-radius:50%;background:linear-gradient(135deg,#0E3818,#287040);color:#A0E880;font-family:'Playfair Display',serif;font-weight:900;font-size:1rem;display:flex;align-items:center;justify-content:center;flex-shrink:0;position:relative;z-index:1;box-shadow:0 2px 10px rgba(40,112,64,.3)}
  .etape-body{padding-top:.3rem}
  .etape-titre{font-weight:500;font-size:.9rem;color:#0E3818;margin-bottom:.2rem}
  .etape-desc{font-size:.83rem;font-weight:300;color:#5F5E5A;line-height:1.55}
  .etape-tip{display:inline-block;margin-top:.3rem;font-size:.72rem;font-weight:600;padding:.1rem .55rem;border-radius:50px;background:#ECFDF5;color:#065F46}

  /* SIMULATION */
  .simul{background:linear-gradient(135deg,#041008,#0E3818);border-radius:13px;padding:1.3rem 1.5rem;margin:1.5rem 0;color:#fff}
  .simul h3{font-family:'Playfair Display',serif;font-size:1rem;font-weight:700;color:#A0E880;margin-bottom:.9rem}
  .simul-row{display:flex;justify-content:space-between;padding:.4rem 0;border-bottom:1px solid rgba(255,255,255,.07);font-size:.84rem}
  .simul-row:last-child{border-bottom:none;padding-top:.55rem;margin-top:.2rem}
  .simul-lab{font-weight:300;color:rgba(255,255,255,.8)}
  .simul-val{font-weight:600;color:#A0E880;white-space:nowrap}
  .simul-lab.total{font-weight:600;color:#fff}
  .simul-val.total{font-size:1rem}
  .simul-val.red{color:#FF8080}

  .encadre{border-left:4px solid #287040;background:#F0FDF4;border-radius:0 10px 10px 0;padding:1rem 1.2rem;margin:1.5rem 0}
  .encadre strong{display:block;color:#0E3818;font-size:.9rem;margin-bottom:.3rem}
  .encadre p{font-size:.84rem;font-weight:300;color:#1A5A30;margin:0;line-height:1.6}

  .conseil{background:linear-gradient(135deg,#041008,#0E3818);border-radius:13px;padding:1.3rem 1.5rem;margin:2rem 0;color:#fff;border:1px solid rgba(160,232,128,.1)}
  .conseil strong{display:block;color:#A0E880;font-weight:500;font-size:.93rem;margin-bottom:.4rem}
  .conseil p{font-size:.88rem;color:rgba(255,255,255,.8);font-weight:300;margin:0;line-height:1.65}

  footer{background:#085041;color:rgba(255,255,255,.6);text-align:center;padding:1.6rem;font-size:.8rem}
  footer strong{color:#fff}
  footer a{color:#EF9F27;text-decoration:none}
  @media(max-width:500px){.niveaux{grid-template-columns:1fr}.garanties{grid-template-columns:1fr}.etapes::before{left:18px}}

/* Menu hamburger mobile */
.hamburger{display:none;flex-direction:column;gap:5px;cursor:pointer;background:none;border:none;padding:.3rem}
.hamburger span{display:block;width:24px;height:2px;background:var(--gd,#085041);border-radius:2px;transition:all .3s}
.mobile-menu{display:none;position:fixed;top:0;left:0;right:0;bottom:0;background:rgba(255,255,255,.98);z-index:999;flex-direction:column;align-items:center;justify-content:center;gap:1.5rem}
.mobile-menu.open{display:flex}
.mobile-menu a{font-family:'Playfair Display',serif;font-size:1.3rem;font-weight:700;color:#085041;text-decoration:none}
.mobile-menu .close-btn{position:absolute;top:1.2rem;right:1.5rem;background:none;border:none;font-size:1.8rem;cursor:pointer;color:#085041}
.mobile-menu .nav-cta{background:#1D9E75;color:white!important;padding:.5rem 1.4rem;border-radius:50px}
@media(max-width:768px){
  .hamburger{display:flex}
  nav .nav-links,nav > a:not(.logo),nav > div:not(.mobile-menu){display:none!important}
  nav li{display:none!important}
}
