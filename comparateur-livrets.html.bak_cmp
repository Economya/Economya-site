<!DOCTYPE html>
<html lang="fr">
<head>
  <link rel="icon" type="image/svg+xml" href="favicon.svg">
  <meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Comparateur Livrets d'Épargne 2026 — Economya.fr</title>
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;700;900&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet">
<style>
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
:root{--g:#1D9E75;--gl:#E1F5EE;--gd:#085041;--a:#EF9F27;--al:#FAEEDA;--r:16px;--t:#2C2C2A;--m:#5F5E5A;--bg:#FAFAF8;--w:#fff;--b:rgba(0,0,0,0.08)}
body{font-family:'DM Sans',sans-serif;background:var(--bg);color:var(--t);min-height:100vh}
nav{display:flex;justify-content:space-between;align-items:center;padding:.9rem 1.8rem;background:var(--w);border-bottom:1px solid var(--b);position:sticky;top:0;z-index:99}
.logo{font-family:'Playfair Display',serif;font-weight:900;font-size:1.3rem;color:var(--gd);text-decoration:none}
.logo span{color:var(--a)}
.nav-back{text-decoration:none;color:var(--m);font-size:.82rem;font-weight:500}
.hero{background:linear-gradient(135deg,#064e3b,#065f46,#059669);color:white;padding:3rem 2rem 2.5rem;text-align:center}
.hero h1{font-family:'Playfair Display',serif;font-size:clamp(1.8rem,4vw,2.8rem);font-weight:900;margin-bottom:.6rem}
.hero h1 em{color:#EF9F27;font-style:normal}
.hero p{font-size:.95rem;color:rgba(255,255,255,.75);max-width:500px;margin:0 auto}
.container{max-width:900px;margin:0 auto;padding:2.5rem 1.5rem}
.card{background:var(--w);border-radius:var(--r);border:1px solid var(--b);padding:2rem;margin-bottom:1.5rem;box-shadow:0 4px 20px rgba(0,0,0,.04)}
.card h2{font-family:'Playfair Display',serif;font-size:1.2rem;font-weight:700;margin-bottom:1.5rem;color:var(--gd)}
.montant-wrap{display:flex;align-items:center;gap:1rem;flex-wrap:wrap}
.montant-wrap label{font-size:.9rem;font-weight:600;color:var(--m);white-space:nowrap}
.montant-input{display:flex;align-items:center;gap:.5rem;background:var(--bg);border:2px solid var(--g);border-radius:50px;padding:.5rem 1.2rem;flex:1;max-width:300px}
.montant-input input{border:none;background:transparent;font-size:1.3rem;font-family:'Playfair Display',serif;font-weight:700;color:var(--gd);width:100%;outline:none}
.montant-input span{font-size:1.1rem;color:var(--g);font-weight:700}
.livrets{display:flex;flex-direction:column;gap:1rem;margin-bottom:1.5rem}
.livret{background:var(--w);border:1px solid var(--b);border-radius:var(--r);padding:1.3rem 1.5rem;display:grid;grid-template-columns:auto 1fr auto auto;gap:1rem;align-items:center;transition:box-shadow .2s}
.livret:hover{box-shadow:0 4px 16px rgba(29,158,117,.1)}
.livret.best{border:2px solid var(--g);background:var(--gl)}
.livret.best .best-badge{display:inline-block;background:var(--g);color:white;font-size:.65rem;font-weight:700;padding:.15rem .6rem;border-radius:50px;margin-left:.5rem;vertical-align:middle}
.best-badge{display:none}
.l-icon{font-size:2rem}
.l-body h3{font-size:.95rem;font-weight:700;margin-bottom:.15rem}
.l-body .l-desc{font-size:.78rem;color:var(--m);line-height:1.4}
.l-taux{text-align:center}
.l-taux .taux-num{font-family:'Playfair Display',serif;font-size:1.6rem;font-weight:900;color:var(--g);display:block}
.l-taux .taux-lbl{font-size:.7rem;color:var(--m)}
.l-gain{text-align:right}
.l-gain .gain-num{font-family:'Playfair Display',serif;font-size:1.3rem;font-weight:700;color:var(--gd);display:block}
.l-gain .gain-lbl{font-size:.7rem;color:var(--m)}
.conditions{display:grid;grid-template-columns:repeat(auto-fit,minmax(200px,1fr));gap:1rem;margin-bottom:1.5rem}
.condition{background:var(--w);border:1px solid var(--b);border-radius:12px;padding:1rem 1.2rem}
.condition h3{font-size:.82rem;font-weight:700;margin-bottom:.5rem;color:var(--gd)}
.condition ul{list-style:none;font-size:.78rem;color:var(--m)}
.condition ul li{padding:.2rem 0;padding-left:1rem;position:relative}
.condition ul li::before{content:'•';position:absolute;left:0;color:var(--g)}
.tip{background:var(--gl);border-left:4px solid var(--g);border-radius:var(--r);padding:1rem 1.4rem;font-size:.9rem;color:var(--gd);margin-bottom:1.5rem}
.tip strong{font-weight:600}
.cta{background:linear-gradient(135deg,var(--al),#FFF8EE);border-radius:var(--r);padding:1.8rem;text-align:center}
.cta h3{font-family:'Playfair Display',serif;font-size:1.1rem;color:#633806;margin-bottom:.4rem}
.cta p{font-size:.86rem;color:var(--m);margin-bottom:1rem}
.cta-form{display:flex;gap:.5rem;max-width:360px;margin:0 auto;flex-wrap:wrap;justify-content:center}
.cta-form input{flex:1;min-width:150px;padding:.65rem 1rem;border-radius:50px;border:1px solid var(--b);font-size:.86rem;font-family:inherit}
.cta-form button{background:var(--a);color:white;border:none;padding:.65rem 1.3rem;border-radius:50px;font-weight:600;cursor:pointer;font-family:inherit;font-size:.86rem}
footer{background:var(--gd);color:rgba(255,255,255,.6);text-align:center;padding:1.5rem;font-size:.8rem;margin-top:2rem}
footer strong{color:white}
@media(max-width:640px){.hero{padding:2rem 1.2rem}.container{padding:1.5rem 1rem}.livret{grid-template-columns:1fr 1fr;gap:.8rem}.l-icon{display:none}}

/* Menu hamburger mobile */
.hamburger{display:none;flex-direction:column;gap:5px;cursor:pointer;background:none;border:none;padding:.3rem}
.hamburger span{display:block;width:24px;height:2px;background:var(--gd,#085041);border-radius:2px;transition:all .3s}
.mobile-menu{display:none;position:fixed;top:0;left:0;right:0;bottom:0;background:rgba(255,255,255,.98);z-index:999;flex-direction:column;align-items:center;justify-content:center;gap:1.5rem}
.mobile-menu.open{display:flex}
.mobile-menu a{font-family:'Playfair Display',serif;font-size:1.3rem;font-weight:700;color:#085041;text-decoration:none}
.mobile-menu .close-btn{position:absolute;top:1.2rem;right:1.5rem;background:none;border:none;font-size:1.8rem;cursor:pointer;color:#085041}
.mobile-menu .nav-cta{background:#1D9E75;color:white!important;padding:.5rem 1.4rem;border-radius:50px}
@media(max-width:768px){
  .hamburger{display:flex}
  nav .nav-links, nav > a:not(.logo), nav > div{display:none!important}
  nav li{display:none!important}
}
</style>

