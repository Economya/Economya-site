<style>
  *,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
  body{font-family:'DM Sans',sans-serif;background:#FAFAF8;color:#2C2C2A;line-height:1.7}
  nav{display:flex;justify-content:space-between;align-items:center;padding:.9rem 1.8rem;background:#fff;border-bottom:1px solid rgba(0,0,0,.08);position:sticky;top:0;z-index:99}
  .logo{font-family:'Playfair Display',serif;font-weight:900;font-size:1.3rem;color:#085041;text-decoration:none}
  .logo span{color:#EF9F27}
  .back{font-size:.82rem;color:#5F5E5A;text-decoration:none}
  .back:hover{color:#1D9E75}

  /* HERO — bleu médical → cyan → blanc cassé */
  .hero{background:linear-gradient(135deg,#030A18 0%,#0A2848 32%,#1060A8 62%,#2898D8 84%,#88D8F8 100%);padding:3.8rem 2rem 3.2rem;text-align:center;position:relative;overflow:hidden}
  .hero::before{content:'🦷';position:absolute;font-size:14rem;opacity:.05;top:50%;left:50%;transform:translate(-50%,-50%);pointer-events:none}
  .hero-cat{font-size:.82rem;font-weight:500;color:rgba(255,255,255,.6);margin-bottom:.6rem;letter-spacing:.05em}
  .hero-cat strong{color:#fff}
  .hero h1{font-family:'Playfair Display',serif;font-size:clamp(1.8rem,4.5vw,2.7rem);font-weight:900;color:#fff;line-height:1.1;max-width:640px;margin:.3rem auto .9rem}
  .hero-badge{display:inline-block;background:linear-gradient(90deg,#88D8F8,#2898D8);color:#030A18;font-size:.82rem;font-weight:700;padding:.35rem 1.1rem;border-radius:50px}
  .hero-meta{display:flex;justify-content:center;flex-wrap:wrap;gap:.55rem;margin-top:1.2rem}
  .hero-meta span{font-size:.73rem;color:rgba(255,255,255,.5);background:rgba(255,255,255,.09);padding:.2rem .75rem;border-radius:50px}

  article{max-width:700px;margin:0 auto;padding:2.5rem 1.5rem 5rem}
  article p{margin-bottom:1.3rem;font-size:.97rem;font-weight:300;line-height:1.75}
  h2{font-family:'Playfair Display',serif;font-size:1.2rem;font-weight:700;color:#0A2848;margin:2.2rem 0 .8rem}

  /* 3 DOMAINES */
  .domaines{display:grid;grid-template-columns:repeat(3,1fr);gap:.75rem;margin:1.5rem 0}
  .domaine{border-radius:13px;overflow:hidden;border:1px solid rgba(0,0,0,.08)}
  .dom-head{padding:.75rem .9rem;color:#fff;font-weight:700;font-size:.88rem;text-align:center}
  .dom-head.dentaire{background:linear-gradient(135deg,#0A2848,#1060A8)}
  .dom-head.optique{background:linear-gradient(135deg,#1A3A10,#3A7840)}
  .dom-head.auditif{background:linear-gradient(135deg,#5C2800,#A05010)}
  .dom-body{background:#fff;padding:.85rem .9rem}
  .dom-ico{font-size:2rem;text-align:center;display:block;margin-bottom:.4rem}
  .dom-point{font-size:.8rem;font-weight:300;color:#2C2C2A;padding:.2rem 0;border-bottom:1px dotted rgba(0,0,0,.07);line-height:1.4}
  .dom-point:last-child{border-bottom:none}
  .dom-point::before{content:'✅ ';font-size:.72rem}

  /* TABLEAU DENTAIRE */
  .tableau{width:100%;border-collapse:collapse;margin:1.5rem 0;font-size:.82rem}
  .tableau thead tr{background:linear-gradient(90deg,#0A2848,#1060A8);color:#fff}
  .tableau thead th{padding:.6rem .85rem;text-align:left;font-weight:500}
  .tableau tbody tr:nth-child(even){background:#EFF6FF}
  .tableau tbody tr:nth-child(odd){background:#fff}
  .tableau tbody td{padding:.55rem .85rem;border-bottom:1px solid rgba(0,0,0,.06);font-weight:300;vertical-align:middle}
  .tableau tbody td:first-child{font-weight:500;color:#0A2848}
  .tableau td.zero{color:#065F46;font-weight:700}
  .tableau td.reste{color:#8B4500;font-weight:500}
  .tableau td.libre{color:#9B1D1D;font-weight:400}

  /* CONDITIONS D'ACCÈS */
  .conditions{display:flex;flex-direction:column;gap:.5rem;margin:1.4rem 0}
  .cond{display:flex;gap:.75rem;align-items:flex-start;padding:.7rem 1rem;border-radius:10px;background:#fff;border:1px solid rgba(0,0,0,.07)}
  .cond-num{width:28px;height:28px;border-radius:50%;background:linear-gradient(135deg,#0A2848,#1060A8);color:#88D8F8;font-weight:700;font-size:.8rem;display:flex;align-items:center;justify-content:center;flex-shrink:0}
  .cond-text{font-size:.83rem;font-weight:300;color:#2C2C2A;line-height:1.5}
  .cond-text strong{font-weight:500;color:#0A2848;display:block;margin-bottom:.1rem}

  /* SIMULATION */
  .simul{background:linear-gradient(135deg,#030A18,#0A2848);border-radius:13px;padding:1.3rem 1.5rem;margin:1.5rem 0;color:#fff}
  .simul h3{font-family:'Playfair Display',serif;font-size:1rem;font-weight:700;color:#88D8F8;margin-bottom:.9rem}
  .simul-grid{display:grid;grid-template-columns:1fr 1fr;gap:1.2rem}
  .simul-col h4{font-size:.72rem;font-weight:600;text-transform:uppercase;letter-spacing:.06em;color:rgba(255,255,255,.45);margin-bottom:.6rem;padding-bottom:.3rem;border-bottom:1px solid rgba(255,255,255,.09)}
  .simul-row{display:flex;justify-content:space-between;padding:.35rem 0;border-bottom:1px solid rgba(255,255,255,.06);font-size:.83rem}
  .simul-row:last-child{border-bottom:none;padding-top:.45rem}
  .simul-lab{font-weight:300;color:rgba(255,255,255,.75)}
  .simul-val{font-weight:600;color:#88D8F8;white-space:nowrap}
  .simul-lab.total{font-weight:600;color:#fff}
  .simul-val.total{font-size:.95rem}
  .simul-val.green{color:#6EE7B7}
  .simul-val.red{color:#FF8080}

  /* CE QUI N'EST PAS COUVERT */
  .noncouvert{display:grid;grid-template-columns:1fr 1fr;gap:.65rem;margin:1.5rem 0}
  .nc{background:#fff;border:1px solid rgba(0,0,0,.08);border-radius:10px;padding:.8rem .9rem;display:flex;gap:.6rem;align-items:flex-start}
  .nc-ico{font-size:1rem;flex-shrink:0}
  .nc-text{font-size:.81rem;font-weight:300;color:#2C2C2A;line-height:1.45}
  .nc-text strong{display:block;font-weight:500;color:#9B1D1D;font-size:.84rem;margin-bottom:.1rem}

  .encadre{border-left:4px solid #1060A8;background:#EFF6FF;border-radius:0 10px 10px 0;padding:1rem 1.2rem;margin:1.5rem 0}
  .encadre strong{display:block;color:#0A2848;font-size:.9rem;margin-bottom:.3rem}
  .encadre p{font-size:.84rem;font-weight:300;color:#1060A8;margin:0;line-height:1.6}

  .conseil{background:linear-gradient(135deg,#030A18,#0A2848);border-radius:13px;padding:1.3rem 1.5rem;margin:2rem 0;color:#fff;border:1px solid rgba(136,216,248,.1)}
  .conseil strong{display:block;color:#88D8F8;font-weight:500;font-size:.93rem;margin-bottom:.4rem}
  .conseil p{font-size:.88rem;color:rgba(255,255,255,.8);font-weight:300;margin:0;line-height:1.65}

  footer{background:#085041;color:rgba(255,255,255,.6);text-align:center;padding:1.6rem;font-size:.8rem}
  footer strong{color:#fff}
  footer a{color:#EF9F27;text-decoration:none}
  @media(max-width:500px){.domaines{grid-template-columns:1fr}.simul-grid{grid-template-columns:1fr}.noncouvert{grid-template-columns:1fr}}

/* Menu hamburger mobile */
.hamburger{display:none;flex-direction:column;gap:5px;cursor:pointer;background:none;border:none;padding:.3rem}
.hamburger span{display:block;width:24px;height:2px;background:var(--gd,#085041);border-radius:2px;transition:all .3s}
.mobile-menu{display:none;position:fixed;top:0;left:0;right:0;bottom:0;background:rgba(255,255,255,.98);z-index:999;flex-direction:column;align-items:center;justify-content:center;gap:1.5rem}
.mobile-menu.open{display:flex}
.mobile-menu a{font-family:'Playfair Display',serif;font-size:1.3rem;font-weight:700;color:#085041;text-decoration:none}
.mobile-menu .close-btn{position:absolute;top:1.2rem;right:1.5rem;background:none;border:none;font-size:1.8rem;cursor:pointer;color:#085041}
.mobile-menu .nav-cta{background:#1D9E75;color:white!important;padding:.5rem 1.4rem;border-radius:50px}
@media(max-width:768px){
  .hamburger{display:flex}
  nav .nav-links,nav > a:not(.logo),nav > div:not(.mobile-menu){display:none!important}
  nav li{display:none!important}
}
