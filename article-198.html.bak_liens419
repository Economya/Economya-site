<style>
  *,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
  : root{
    --g:#1D9E75;--gl:#E1F5EE;--gd:#085041;--a:#EF9F27;--al:#FAEEDA;--ad:#633806;
    --t:#2C2C2A;--m:#5F5E5A;--bg:#FAFAF8;--w:#fff;--b:rgba(0,0,0,0.1);
    --wheat:#8B5E2A;--wheat-mid:#C4892F;--wheat-light:#FDF5E6;
    --crust:#5C3A0E;--dough:#F5D5A0;--cream:#FFFDF7;
  }
  body{font-family:'DM Sans',sans-serif;background:var(--bg);color:var(--t);line-height:1.7}
  nav{display:flex;justify-content:space-between;align-items:center;padding:.9rem 1.8rem;background:var(--w);border-bottom:1px solid var(--b);position:sticky;top:0;z-index:99}
  .logo{font-family:'Playfair Display',serif;font-weight:900;font-size:1.3rem;color:var(--gd);text-decoration:none}
  .logo span{color:var(--a)}
  .back{font-size:.82rem;color:var(--m);text-decoration:none}
  .back:hover{color:var(--g)}

  .hero-art{
    background:linear-gradient(135deg,#1A0A00 0%,#5C3A0E 35%,#8B5E2A 65%,#C4892F 85%,#F5D5A0 100%);
    padding:3.5rem 2rem 3rem;text-align:center;position:relative;overflow:hidden
  }
  .hero-art::before{
    content:'🍞';position:absolute;font-size:13rem;opacity:.07;
    top:50%;left:50%;transform:translate(jusqu'à -50%,jusqu'à -50%);pointer-events:none
  }
  .acat{font-size:.85rem;font-weight:500;color:rgba(255,255,255,.65);margin-bottom:.6rem;letter-spacing:.04em}
  .acat strong{color:#fff}
  .hero-art h1{
    font-family:'Playfair Display',serif;font-size:clamp(1.7rem,4vw,2.6rem);
    font-weight:900;line-height:1.1;color:#fff;max-width:620px;margin:0 auto .9rem
  }
  .abadge{
    display:inline-block;
    background:linear-gradient(90deg,var(--dough),var(--wheat-mid));
    color:#1A0A00;font-size:.82rem;font-weight:700;padding:.35rem 1rem;
    border-radius:50px;margin-top:.4rem
  }
  .meta{display:flex;justify-content:center;flex-wrap:wrap;gap:.6rem;margin-top:1.2rem}
  .meta span{font-size:.74rem;color:rgba(255,255,255,.55);background:rgba(255,255,255,.12);padding:.2rem .75rem;border-radius:50px}

  article{max-width:680px;margin:0 auto;padding:2.5rem 1.5rem 4rem}
  article p{margin-bottom:1.3rem;font-size:.97rem;font-weight:300}
  article h2{font-family:'Playfair Display',serif;font-size:1.2rem;font-weight:700;color:var(--crust);margin:2rem 0 .7rem}

  /* Recette principale */
  .recette{background:var(--cream);border:1px solid rgba(139,94,42,.2);border-radius:14px;overflow:hidden;margin:1.5rem 0}
  .recette-head{background:linear-gradient(90deg,var(--crust),var(--wheat));padding:.9rem 1.2rem;color:#fff}
  .recette-head h3{font-family:'Playfair Display',serif;font-size:1.05rem;font-weight:900;margin-bottom:.15rem}
  .recette-head p{font-size:.76rem;color:rgba(255,255,255,.7);margin:0}
  .recette-body{display:grid;grid-template-columns:1fr 1fr}
  .rec-col{padding:.9rem 1.1rem}
  .rec-col:first-child{border-right:1px solid rgba(139,94,42,.12)}
  .rec-label{font-size:.68rem;font-weight:600;text-transform:uppercase;letter-spacing:.07em;color:var(--wheat);margin-bottom:.55rem}
  .rec-item{font-size:.84rem;font-weight:300;padding:.22rem 0;border-bottom:1px dotted rgba(139,94,42,.15);color:var(--t);display:flex;justify-content:space-between;gap:.5rem}
  .rec-item span{font-weight:500;color:var(--crust);white-space:nowrap}
  .rec-step{display:flex;gap:.6rem;margin-bottom:.5rem;font-size:.83rem;font-weight:300;color:var(--t);align-items:flex-start;line-height:1.5}
  .rec-n{background:var(--wheat);color:#fff;border-radius:50%;width:20px;height:20px;font-size:.67rem;font-weight:700;display:flex;align-items:center;justify-content:center;flex-shrink:0;margin-top:.07rem}

  /* Timeline fermentation */
  .timeline{display:flex;flex-direction:column;gap:0;margin:1.5rem 0;position:relative}
  .timeline::before{content:'';position:absolute;left:19px;top:20px;bottom:20px;width:2px;background:linear-gradient(180deg,var(--wheat),var(--dough));opacity:.4}
  .tl-item{display:flex;gap:.9rem;padding:.7rem 0;align-items:flex-start}
  .tl-dot{width:38px;height:38px;border-radius:50%;background:linear-gradient(135deg,var(--crust),var(--wheat));color:#fff;font-size:.75rem;font-weight:700;display:flex;align-items:center;justify-content:center;flex-shrink:0;position:relative;z-index:1;box-shadow:0 2px 8px rgba(139,94,42,.3)}
  .tl-body{}
  .tl-temps{font-size:.7rem;font-weight:600;color:var(--wheat);text-transform:uppercase;letter-spacing:.05em;margin-bottom:.1rem}
  .tl-action{font-weight:500;font-size:.88rem;color:var(--crust);margin-bottom:.1rem}
  .tl-detail{font-size:.8rem;font-weight:300;color:var(--m);line-height:1.4}

  /* Comparatif */
  .cout{display:grid;grid-template-columns:1fr auto 1fr;gap:.6rem;align-items:center;margin:1.5rem 0;background:var(--w);border:1px solid var(--b);border-radius:12px;padding:1.1rem 1.2rem}
  .cout-block{text-align:center}
  .cout-label{font-size:.7rem;font-weight:500;text-transform:uppercase;letter-spacing:.06em;color:var(--m);margin-bottom:.3rem}
  .cout-val{font-family:'Playfair Display',serif;font-size:1.5rem;font-weight:900}
  .cout-val.rouge{color:#B91C1C}
  .cout-val.vert{color:var(--gd)}
  .cout-sub{font-size:.72rem;color:var(--m);margin-top:.15rem;font-weight:300}
  .cout-arrow{font-size:1.3rem;color:var(--wheat);text-align:center}

  /* Variantes */
  .variantes{display:grid;grid-template-columns:1fr 1fr;gap:.6rem;margin:1.5rem 0}
  .variante{background:var(--w);border:1px solid var(--b);border-radius:10px;padding:.8rem .9rem}
  .variante-emoji{font-size:1.3rem;margin-bottom:.25rem}
  .variante-nom{font-weight:500;font-size:.86rem;color:var(--crust);margin-bottom:.15rem}
  .variante-desc{font-size:.78rem;font-weight:300;color:var(--m);line-height:1.4}

  .conseil{
    background:linear-gradient(135deg,#1A0A00,#5C3A0E);
    border-radius:12px;padding:1.2rem 1.4rem;margin:1.8rem 0;color:#fff
  }
  .conseil strong{display:block;color:var(--dough);font-weight:500;font-size:.92rem;margin-bottom:.4rem}
  .conseil p{font-size:.88rem;color:rgba(255,255,255,.82);font-weight:300;margin:0;line-height:1.65}

  footer{background:var(--gd);color:rgba(255,255,255,0.6);text-align:center;padding:1.6rem;font-size:.8rem}
  footer strong{color:white}
  footer a{color:var(--a);text-decoration:none}
  @media(max-width:500px){.recette-body{grid-template-columns:1fr}.rec-col:first-child{border-right:none;border-bottom:1px solid rgba(139,94,42,.12)}.variantes{grid-template-columns:1fr}.cout{grid-template-columns:1fr}.cout-arrow{transform:rotate(90deg)}}

/* Menu hamburger mobile */
.hamburger{display:none;flex-direction:column;gap:5px;cursor:pointer;background:none;border:none;padding:.3rem}
.hamburger span{display:block;width:24px;height:2px;background:var(--gd,#085041);border-radius:2px;transition:all .3s}
.mobile-menu{display:none;position:fixed;top:0;left:0;right:0;bottom:0;background:rgba(255,255,255,.98);z-index:999;flex-direction:column;align-items:center;justify-content:center;gap:1.5rem}
.mobile-menu.open{display:flex}
.mobile-menu a{font-family:'Playfair Display',serif;font-size:1.3rem;font-weight:700;color:#085041;text-decoration:none}
.mobile-menu .close-btn{position:absolute;top:1.2rem;right:1.5rem;background:none;border:none;font-size:1.8rem;cursor:pointer;color:#085041}
.mobile-menu .nav-cta{background:#1D9E75;color:white!important;padding:.5rem 1.4rem;border-radius:50px}
@media(max-width:768px){
  .hamburger{display:flex}
  nav .nav-links,nav > a:not(.logo),nav > div:not(.mobile-menu){display:none!important}
  nav li{display:none!important}
}
