  <div class="specs">
    <div class="specs-head">
      <span>Composant</span>
      <span>Bureautique</span>
      <span>Créatif/Dev</span>
      <span>Gaming léger</span>
    </div>
    <div class="specs-row">
      <span>Processeur</span>
      <span class="s-good">Intel i5 8e+ / Ryzen 5</span>
      <span class="s-good">Intel i7 10e+ / Ryzen 7</span>
