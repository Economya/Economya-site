  article{max-width:680px;margin:0 auto;padding:2.5rem 1.5rem 4rem}
  article p{margin-bottom:1.3rem;font-size:.97rem;font-weight:300}
  article h2{font-family:'Playfair Display',serif;font-size:1.2rem;font-weight:700;color:var(--violet-dark);margin:2rem 0 .7rem}

  /* Blocs d'aides visuels */
  .aide-list{display:flex;flex-direction:column;gap:.7rem;margin:1.5rem 0}
  .aide{display:flex;gap:0;border-radius:12px;overflow:hidden;box-shadow:0 2px 12px rgba(108,59,226,.08)}
  .aide-bar{width:6px;flex-shrink:0}
  .aide-bar.violet{background:linear-gradient(180deg,var(--violet),var(--rose))}
  .aide-bar.cyan{background:linear-gradient(180deg,var(--cyan),var(--g))}
  .aide-bar.gold{background:linear-gradient(180deg,var(--gold),var(--rose))}
  .aide-inner{background:var(--w);padding:.85rem 1.1rem;flex:1;border:1px solid rgba(108,59,226,.1);border-left:none;border-radius:0 12px 12px 0}
  .aide-title{font-weight:500;font-size:.92rem;margin-bottom:.2rem;color:var(--t)}
  .aide-montant{display:inline-block;font-size:.72rem;font-weight:500;padding:.1rem .55rem;border-radius:50px;margin-bottom:.35rem}
  .aide-montant.violet{background:var(--violet-light);color:var(--violet-dark)}
  .aide-montant.cyan{background:#E0FAFA;color:#006B70}
  .aide-montant.gold{background:var(--al);color:var(--ad)}
  .aide-desc{font-size:.83rem;color:var(--m);font-weight:300;line-height:1.5}

  /* Encadré conseil */
  .conseil{
    background:linear-gradient(135deg,#F0EBFF,#fce4f7);
    border-radius:12px;padding:1.1rem 1.3rem;margin:1.8rem 0;
    border:1px solid rgba(108,59,226,.15)
  }
  .conseil strong{color:var(--violet-dark);font-weight:500;display:block;margin-bottom:.35rem;font-size:.92rem}
  .conseil p{font-size:.88rem;color:var(--t);font-weight:300;margin:0}

  footer{background:var(--gd);color:rgba(255,255,255,0.6);text-align:center;padding:1.6rem;font-size:.8rem}
  footer strong{color:white}
  footer a{color:var(--a);text-decoration:none}

/* Menu hamburger mobile */
.hamburger{display:none;flex-direction:column;gap:5px;cursor:pointer;background:none;border:none;padding:.3rem}
