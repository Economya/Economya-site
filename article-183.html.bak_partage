<title>Pannes électriques simples : les gérer soi-même — Economya.fr</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;700;900&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet">
<style>
  *,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
  : root{
    --g:#1D9E75;--gl:#E1F5EE;--gd:#085041;--a:#EF9F27;--al:#FAEEDA;--ad:#633806;
    --t:#2C2C2A;--m:#5F5E5A;--bg:#FAFAF8;--w:#fff;--b:rgba(0,0,0,0.1);
    --volt:#1A2C0A;--volt-mid:#2E5010;--volt-light:#F0F7E6;
    --yellow:#FFD700;--orange:#FF8C00;--red:#DC143C;
  }
  body{font-family:'DM Sans',sans-serif;background:var(--bg);color:var(--t);line-height:1.7}
  nav{display:flex;justify-content:space-between;align-items:center;padding:.9rem 1.8rem;background:var(--w);border-bottom:1px solid var(--b);position:sticky;top:0;z-index:99}
  .logo{font-family:'Playfair Display',serif;font-weight:900;font-size:1.3rem;color:var(--gd);text-decoration:none}
  .logo span{color:var(--a)}
  .back{font-size:.82rem;color:var(--m);text-decoration:none}
  .back:hover{color:var(--g)}

  .hero-art{
    background:linear-gradient(135deg,#060A02 0%,#1A2C0A 32%,#2E5010 60%,#FFD700 88%,#FF8C00 100%);
    padding:3.5rem 2rem 3rem;text-align:center;position:relative;overflow:hidden
  }
  .hero-art::before{
    content:'⚡';position:absolute;font-size:13rem;opacity:.06;
    top:50%;left:50%;transform:translate(jusqu'à -50%,jusqu'à -50%);pointer-events:none
  }
  .acat{font-size:.85rem;font-weight:500;color:rgba(255,255,255,.6);margin-bottom:.6rem;letter-spacing:.04em}
  .acat strong{color:#fff}
  .hero-art h1{
    font-family:'Playfair Display',serif;font-size:clamp(1.7rem,4vw,2.6rem);
    font-weight:900;line-height:1.1;color:#fff;max-width:620px;margin:0 auto .9rem
  }
  .abadge{
    display:inline-block;
    background:linear-gradient(90deg,var(--yellow),var(--orange));
    color:#060A02;font-size:.82rem;font-weight:700;padding:.35rem 1rem;
    border-radius:50px;margin-top:.4rem
  }
  .meta{display:flex;justify-content:center;flex-wrap:wrap;gap:.6rem;margin-top:1.2rem}
  .meta span{font-size:.74rem;color:rgba(255,255,255,.55);background:rgba(255,255,255,.1);padding:.2rem .75rem;border-radius:50px}

  article{max-width:680px;margin:0 auto;padding:2.5rem 1.5rem 4rem}
  article p{margin-bottom:1.3rem;font-size:.97rem;font-weight:300}
  article h2{font-family:'Playfair Display',serif;font-size:1.2rem;font-weight:700;color:var(--volt);margin:2rem 0 .7rem}

  /* Pannes DIY */
  .pannes{display:flex;flex-direction:column;gap:.8rem;margin:1.5rem 0}
  .panne{border-radius:12px;overflow:hidden;border:1px solid rgba(46,80,16,.15)}
  .panne-head{display:grid;grid-template-columns:1fr auto auto;gap:.6rem;align-items:center;padding:.75rem 1.1rem;color:#fff}
  .panne-head.facile{background:linear-gradient(90deg,#1B5E20,#2E7D32)}
  .panne-head.moyen{background:linear-gradient(90deg,var(--volt),var(--volt-mid))}
  .panne-head.stop{background:linear-gradient(90deg,#5C0010,#9B0020)}
  .panne-titre{font-weight:600;font-size:.9rem}
  .panne-diff{font-size:.69rem;font-weight:600;background:rgba(255,255,255,.2);padding:.1rem .5rem;border-radius:50px;white-space:nowrap}
  .panne-eco{color:var(--yellow);font-weight:700;font-size:.82rem;white-space:nowrap}
  .panne-body{background:var(--w);padding:.85rem 1.1rem}
  .panne-desc{font-size:.84rem;font-weight:300;color:var(--m);line-height:1.55;margin-bottom:.6rem}
  .panne-steps{display:flex;flex-direction:column;gap:.35rem}
  .panne-step{display:flex;gap:.6rem;font-size:.82rem;font-weight:300;color:var(--t);align-items:flex-start}
  .step-n{background:var(--volt-mid);color:#fff;border-radius:50%;width:19px;height:19px;font-size:.65rem;font-weight:700;display:flex;align-items:center;justify-content:center;flex-shrink:0;margin-top:.07rem}
  .step-n.vert{background:#2E7D32}
  .danger-box{background:#FEF2F2;border-left:4px solid var(--red);border-radius:0 8px 8px 0;padding:.75rem 1rem;font-size:.83rem;color:#7F1D1D;font-weight:300;line-height:1.55}
  .danger-box strong{font-weight:600;display:block;margin-bottom:.2rem}

  /* Outils indispensables */
  .outils{display:grid;grid-template-columns:1fr 1fr;gap:.6rem;margin:1.5rem 0}
  .outil{background:var(--w);border:1px solid var(--b);border-radius:10px;padding:.75rem .9rem;display:flex;gap:.7rem;align-items:flex-start}
  .outil-icon{font-size:1.2rem;flex-shrink:0}
  .outil-body{}
  .outil-nom{font-weight:500;font-size:.85rem;color:var(--volt);margin-bottom:.1rem}
  .outil-desc{font-size:.78rem;font-weight:300;color:var(--m);line-height:1.4}
  .outil-prix{font-size:.72rem;font-weight:600;color:var(--g);margin-top:.15rem}

  .conseil{
    background:linear-gradient(135deg,#060A02,#1A2C0A);
    border-radius:12px;padding:1.2rem 1.4rem;margin:1.8rem 0;color:#fff;
    border:1px solid rgba(255,215,0,.15)
  }
  .conseil strong{display:block;color:var(--yellow);font-weight:500;font-size:.92rem;margin-bottom:.4rem}
  .conseil p{font-size:.88rem;color:rgba(255,255,255,.82);font-weight:300;margin:0;line-height:1.65}

  footer{background:var(--gd);color:rgba(255,255,255,0.6);text-align:center;padding:1.6rem;font-size:.8rem}
  footer strong{color:white}
  footer a{color:var(--a);text-decoration:none}
  @media(max-width:500px){.outils{grid-template-columns:1fr}.panne-head{grid-template-columns:1fr auto}}

