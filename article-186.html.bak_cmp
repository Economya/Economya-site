<style>
  *,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
  :root{
    --g:#1D9E75;--gl:#E1F5EE;--gd:#085041;--a:#EF9F27;--al:#FAEEDA;--ad:#633806;
    --t:#2C2C2A;--m:#5F5E5A;--bg:#FAFAF8;--w:#fff;--b:rgba(0,0,0,0.1);
    --turq:#007F8C;--turq-dark:#004A52;--turq-light:#E0F5F7;
    --mint:#00C9A7;--lemon:#F7E04B;--white:#F8FFFE;
  }
  body{font-family:'DM Sans',sans-serif;background:var(--bg);color:var(--t);line-height:1.7}
  nav{display:flex;justify-content:space-between;align-items:center;padding:.9rem 1.8rem;background:var(--w);border-bottom:1px solid var(--b);position:sticky;top:0;z-index:99}
  .logo{font-family:'Playfair Display',serif;font-weight:900;font-size:1.3rem;color:var(--gd);text-decoration:none}
  .logo span{color:var(--a)}
  .back{font-size:.82rem;color:var(--m);text-decoration:none}
  .back:hover{color:var(--g)}

  .hero-art{
    background:linear-gradient(135deg,#001A1C 0%,#004A52 35%,#007F8C 65%,#00C9A7 88%,#F7E04B 100%);
    padding:3.5rem 2rem 3rem;text-align:center;position:relative;overflow:hidden
  }
  .hero-art::before{
    content:'🧹';position:absolute;font-size:13rem;opacity:.06;
    top:50%;left:50%;transform:translate(jusqu'à -50%,jusqu'à -50%);pointer-events:none
  }
  .acat{font-size:.85rem;font-weight:500;color:rgba(255,255,255,.6);margin-bottom:.6rem;letter-spacing:.04em}
  .acat strong{color:#fff}
  .hero-art h1{
    font-family:'Playfair Display',serif;font-size:clamp(1.7rem,4vw,2.6rem);
    font-weight:900;line-height:1.1;color:#fff;max-width:620px;margin:0 auto .9rem
  }
  .abadge{
    display:inline-block;
    background:linear-gradient(90deg,var(--lemon),var(--mint));
    color:#001A1C;font-size:.82rem;font-weight:700;padding:.35rem 1rem;
    border-radius:50px;margin-top:.4rem
  }
  .meta{display:flex;justify-content:center;flex-wrap:wrap;gap:.6rem;margin-top:1.2rem}
  .meta span{font-size:.74rem;color:rgba(255,255,255,.55);background:rgba(255,255,255,.1);padding:.2rem .75rem;border-radius:50px}

  article{max-width:680px;margin:0 auto;padding:2.5rem 1.5rem 4rem}
  article p{margin-bottom:1.3rem;font-size:.97rem;font-weight:300}
  article h2{font-family:'Playfair Display',serif;font-size:1.2rem;font-weight:700;color:var(--turq-dark);margin:2rem 0 .7rem}

  /* Ingrédients de base */
  .ingredients{display:grid;grid-template-columns:repeat(4,1fr);gap:.6rem;margin:1.5rem 0}
  .ingr{background:var(--w);border:1px solid var(--b);border-radius:10px;padding:.75rem .7rem;text-align:center}
  .ingr-icon{font-size:1.4rem;margin-bottom:.3rem}
  .ingr-nom{font-weight:500;font-size:.82rem;color:var(--turq-dark);margin-bottom:.15rem}
  .ingr-role{font-size:.72rem;font-weight:300;color:var(--m);line-height:1.3;margin-bottom:.25rem}
  .ingr-prix{font-size:.7rem;font-weight:600;color:var(--g)}

  /* Recettes ménagères */
  .recettes{display:flex;flex-direction:column;gap:.8rem;margin:1.5rem 0}
  .recette{border-radius:13px;overflow:hidden;border:1px solid rgba(0,127,140,.15)}
  .recette-head{display:flex;justify-content:space-between;align-items:center;padding:.75rem 1.1rem;color:#fff;gap:.5rem}
  .recette-head.wc{background:linear-gradient(90deg,#001A1C,#004A52)}
  .recette-head.vitres{background:linear-gradient(90deg,#0E2030,#0077B6)}
  .recette-head.cuisine{background:linear-gradient(90deg,#2A1A00,#8B4513)}
  .recette-head.lessive{background:linear-gradient(90deg,#1B3A2A,#2D6A4F)}
  .recette-titre{font-weight:700;font-size:.9rem;font-family:'Playfair Display',serif}
  .recette-meta{text-align:right;flex-shrink:0}
  .recette-cout{color:var(--lemon);font-weight:700;font-size:.83rem}
  .recette-vs{color:rgba(255,255,255,.55);font-size:.7rem}
  .recette-body{display:grid;grid-template-columns:1fr 1fr;background:#FDFFFE}
  .rec-col{padding:.85rem 1rem}
  .rec-col:first-child{border-right:1px solid rgba(0,127,140,.1)}
  .rec-label{font-size:.68rem;font-weight:600;text-transform:uppercase;letter-spacing:.07em;color:var(--turq);margin-bottom:.55rem}
  .rec-item{font-size:.82rem;font-weight:300;padding:.2rem 0;border-bottom:1px dotted rgba(0,127,140,.15);color:var(--t);display:flex;justify-content:space-between;gap:.5rem}
  .rec-item span{font-weight:500;color:var(--turq-dark);white-space:nowrap}
  .rec-step{display:flex;gap:.55rem;margin-bottom:.4rem;font-size:.82rem;font-weight:300;color:var(--t);align-items:flex-start;line-height:1.45}
  .rec-n{background:var(--turq);color:#fff;border-radius:50%;width:19px;height:19px;font-size:.65rem;font-weight:700;display:flex;align-items:center;justify-content:center;flex-shrink:0;margin-top:.07rem}

  /* Tableau économies */
  .ecos{width:100%;border-collapse:collapse;margin:1.5rem 0;font-size:.84rem}
  .ecos thead tr{background:linear-gradient(90deg,var(--turq-dark),var(--turq));color:#fff}
  .ecos thead th{padding:.6rem .9rem;text-align:left;font-weight:500}
  .ecos tbody tr:nth-child(even){background:var(--turq-light)}
  .ecos tbody tr:nth-child(odd){background:var(--w)}
  .ecos tbody td{padding:.55rem .9rem;border-bottom:1px solid var(--b);font-weight:300}
  .ecos tbody td:first-child{font-weight:500;color:var(--turq-dark)}
  .ecos td.prix-achat{color:#B91C1C;font-weight:500;white-space:nowrap}
  .ecos td.prix-maison{color:var(--gd);font-weight:600;white-space:nowrap}
  .ecos tr.total td{font-weight:700;background:var(--turq-light)}
  .ecos tr.total td.prix-achat{font-size:.9rem}
  .ecos tr.total td.prix-maison{font-size:.9rem}

  .conseil{
    background:linear-gradient(135deg,#001A1C,#004A52);
    border-radius:12px;padding:1.2rem 1.4rem;margin:1.8rem 0;color:#fff;
    border:1px solid rgba(0,201,167,.15)
  }
  .conseil strong{display:block;color:var(--lemon);font-weight:500;font-size:.92rem;margin-bottom:.4rem}
  .conseil p{font-size:.88rem;color:rgba(255,255,255,.82);font-weight:300;margin:0;line-height:1.65}

  footer{background:var(--gd);color:rgba(255,255,255,0.6);text-align:center;padding:1.6rem;font-size:.8rem}
  footer strong{color:white}
  footer a{color:var(--a);text-decoration:none}
  @media(max-width:500px){.ingredients{grid-template-columns:1fr 1fr}.recette-body{grid-template-columns:1fr}.rec-col:first-child{border-right:none;border-bottom:1px solid rgba(0,127,140,.1)}}

/* Menu hamburger mobile */
.hamburger{display:none;flex-direction:column;gap:5px;cursor:pointer;background:none;border:none;padding:.3rem}
.hamburger span{display:block;width:24px;height:2px;background:var(--gd,#085041);border-radius:2px;transition:all .3s}
