<style>
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
:root{--g:#1D9E75;--gl:#E1F5EE;--gd:#085041;--a:#EF9F27;--al:#FAEEDA;--ad:#633806;--emerald:#059669;--emerald-l:#ecfdf5;--t:#2C2C2A;--m:#5F5E5A;--bg:#FAFAF8;--w:#fff;--b:rgba(0,0,0,0.08);--r:14px}
body{font-family:'DM Sans',sans-serif;background:var(--bg);color:var(--t);line-height:1.7}
nav{display:flex;justify-content:space-between;align-items:center;padding:.9rem 1.8rem;background:var(--w);border-bottom:1px solid var(--b);position:sticky;top:0;z-index:99}
.logo{font-family:'Playfair Display',serif;font-weight:900;font-size:1.3rem;color:var(--gd);text-decoration:none}
.logo span{color:var(--a)}
.nav-back{text-decoration:none;color:var(--m);font-size:.82rem;font-weight:500}
.nav-back:hover{color:var(--g)}
.ah{background:linear-gradient(135deg,#022c22,#065f46,#059669);color:white;padding:3rem 2rem 2.5rem;position:relative;overflow:hidden}
.ah::before{content:'🔥';position:absolute;font-size:16rem;right:-1rem;top:-2rem;opacity:.07;pointer-events:none;line-height:1}
.hi{max-width:760px;margin:0 auto;position:relative;z-index:1;text-align:center}
.cat-pill{display:inline-flex;align-items:center;gap:.4rem;background:rgba(255,255,255,.12);border:1px solid rgba(255,255,255,.2);color:#a7f3d0;font-size:.72rem;font-weight:600;text-transform:uppercase;letter-spacing:.08em;padding:.28rem .9rem;border-radius:50px;margin-bottom:.9rem}
.ah h1{font-family:'Playfair Display',serif;font-size:clamp(1.8rem,4vw,2.8rem);font-weight:900;line-height:1.15;margin-bottom:.9rem}
.ah h1 em{color:#6ee7b7;font-style:normal}
.savings-badge{display:inline-flex;align-items:center;gap:.5rem;background:linear-gradient(135deg,#f59e0b,#059669);color:white;font-size:.88rem;font-weight:700;padding:.45rem 1.2rem;border-radius:50px;margin-bottom:1.3rem;box-shadow:0 4px 14px rgba(5,150,105,.35)}
.meta-row{display:flex;flex-wrap:wrap;gap:.6rem;justify-content:center}
.meta-item{display:inline-flex;align-items:center;gap:.3rem;background:rgba(255,255,255,.1);border:1px solid rgba(255,255,255,.15);padding:.22rem .7rem;border-radius:50px;color:rgba(255,255,255,.8);font-size:.74rem}
.theme-tag{background:linear-gradient(135deg,#059669,#d97706);color:white;font-weight:600;padding:.22rem .8rem;border-radius:50px;font-size:.72rem}
.ab{max-width:760px;margin:0 auto;padding:2.5rem 2rem 4rem}
.lead{font-size:1.05rem;color:var(--m);font-weight:300;border-left:4px solid var(--emerald);padding-left:1.2rem;margin-bottom:2rem;line-height:1.8}
h2{font-family:'Playfair Display',serif;font-size:1.35rem;font-weight:700;margin:2.2rem 0 1rem;display:flex;align-items:center;gap:.5rem}
p{margin-bottom:1rem;font-size:.95rem}

/* ÉQUIPEMENTS */
.equips{display:flex;flex-direction:column;gap:1rem;margin:1.5rem 0}
.equip{background:var(--w);border:1px solid var(--b);border-radius:var(--r);padding:1.3rem 1.5rem;display:grid;grid-template-columns:auto 1fr auto;gap:1rem;align-items:start;transition:box-shadow .2s}
.equip:hover{box-shadow:0 4px 18px rgba(5,150,105,.1)}
.equip.top{border:2px solid var(--g)}
.top-badge{display:inline-block;background:var(--g);color:white;font-size:.65rem;font-weight:700;padding:.1rem .5rem;border-radius:50px;margin-bottom:.3rem}
.eq-icon{font-size:2rem;flex-shrink:0;margin-top:.1rem}
.eq-body h3{font-size:.95rem;font-weight:700;margin-bottom:.2rem}
.eq-body p{font-size:.83rem;color:var(--m);font-weight:300;margin:0 0 .45rem}
.eq-tags{display:flex;flex-wrap:wrap;gap:.3rem}
.etag{font-size:.68rem;font-weight:600;padding:.1rem .45rem;border-radius:50px;background:var(--emerald-l);color:#065f46}
.etag.prix{background:var(--al);color:var(--ad)}
.eq-right{text-align:right;flex-shrink:0}
.eq-conso{font-family:'Playfair Display',serif;font-size:1.1rem;font-weight:700;color:var(--emerald);display:block;white-space:nowrap}
.eq-sub{font-size:.7rem;color:var(--m)}

/* TABLEAU COMPARATIF */
.tw{overflow-x:auto;margin:1.3rem 0;border-radius:var(--r);border:1px solid var(--b)}
table{width:100%;border-collapse:collapse;font-size:.86rem}
thead tr{background:linear-gradient(135deg,#065f46,#059669);color:white}
thead th{padding:.85rem 1rem;text-align:left;font-weight:600;font-size:.8rem}
tbody tr{border-bottom:1px solid var(--b)}
tbody tr:last-child{border-bottom:none}
tbody tr:nth-child(even){background:#fafafa}
tbody td{padding:.8rem 1rem;vertical-align:middle}
.g{color:#16a34a;font-weight:600}
.o{color:var(--ad);font-weight:500}
.r{color:#dc2626;font-weight:500}

/* ENCADRÉS */
.tip{background:var(--gl);border-left:4px solid var(--g);border-radius:var(--r);padding:1.1rem 1.4rem;margin:1.5rem 0;font-size:.9rem;color:var(--gd)}
.tip strong{display:block;font-weight:600;margin-bottom:.25rem}
.warn{background:var(--emerald-l);border-left:4px solid var(--emerald);border-radius:var(--r);padding:1.1rem 1.4rem;margin:1.5rem 0;font-size:.9rem;color:#064e3b}
.warn strong{display:block;font-weight:600;margin-bottom:.25rem}

.cta{background:linear-gradient(135deg,#022c22,#065f46);border-radius:var(--r);padding:1.8rem;text-align:center;margin-top:2.5rem;color:white}
.cta h3{font-family:'Playfair Display',serif;font-size:1.2rem;margin-bottom:.4rem}
.cta p{color:rgba(255,255,255,.7);font-size:.86rem;margin-bottom:1rem}
.cta-form{display:flex;gap:.5rem;max-width:360px;margin:0 auto;flex-wrap:wrap;justify-content:center}
.cta-form input{flex:1;min-width:150px;padding:.65rem 1rem;border-radius:50px;border:none;font-size:.86rem;font-family:inherit}
.cta-form button{background:linear-gradient(135deg,#059669,#d97706);color:white;border:none;padding:.65rem 1.3rem;border-radius:50px;font-weight:600;cursor:pointer;font-family:inherit;font-size:.86rem}
footer{background:var(--gd);color:rgba(255,255,255,.6);text-align:center;padding:1.5rem;font-size:.8rem}
footer strong{color:white}
@media(max-width:640px){.ah{padding:2rem 1.2rem}.ab{padding:1.8rem 1.1rem 3rem}.ah::before{font-size:8rem}.equip{grid-template-columns:1fr;gap:.5rem}.eq-right{text-align:left}}

/* Menu hamburger mobile */
.hamburger{display:none;flex-direction:column;gap:5px;cursor:pointer;background:none;border:none;padding:.3rem}
.hamburger span{display:block;width:24px;height:2px;background:var(--gd,#085041);border-radius:2px;transition:all .3s}
