<!DOCTYPE html>
<html lang="fr">
<head>
  <link rel="icon" type="image/svg+xml" href="favicon.svg">
  <meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Générateur de Défi Épargne — Economya.fr</title>
<meta name="description" content="Choisissez votre objectif et obtenez un plan d'épargne personnalisé semaine par semaine. Vacances, voiture, apport immo... Gratuit sur Economya.fr">
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;700;900&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet">
<style>
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
:root{--g:#1D9E75;--gl:#E1F5EE;--gd:#085041;--a:#EF9F27;--al:#FAEEDA;--r:16px;--t:#2C2C2A;--m:#5F5E5A;--bg:#FAFAF8;--w:#fff;--b:rgba(0,0,0,0.08)}
body{font-family:'DM Sans',sans-serif;background:var(--bg);color:var(--t);min-height:100vh}
nav{display:flex;justify-content:space-between;align-items:center;padding:.9rem 1.8rem;background:var(--w);border-bottom:1px solid var(--b);position:sticky;top:0;z-index:99}
.logo{font-family:'Playfair Display',serif;font-weight:900;font-size:1.3rem;color:var(--gd);text-decoration:none}
.logo span{color:var(--a)}
.nav-back{text-decoration:none;color:var(--m);font-size:.82rem;font-weight:500}
.hero{background:linear-gradient(135deg,#1e1b4b,#4338ca,#6366f1);color:white;padding:3rem 2rem 2.5rem;text-align:center;position:relative;overflow:hidden}
.hero::before{content:'🎯';position:absolute;font-size:16rem;right:-1rem;top:-2rem;opacity:.07;pointer-events:none}
.hero h1{font-family:'Playfair Display',serif;font-size:clamp(1.8rem,4vw,2.6rem);font-weight:900;margin-bottom:.6rem}
.hero h1 em{color:#EF9F27;font-style:normal}
.hero p{font-size:.95rem;color:rgba(255,255,255,.75);max-width:500px;margin:0 auto}
.container{max-width:800px;margin:0 auto;padding:2.5rem 1.5rem}
.card{background:var(--w);border-radius:var(--r);border:1px solid var(--b);padding:2rem;margin-bottom:1.5rem;box-shadow:0 4px 20px rgba(0,0,0,.04)}
.card h2{font-family:'Playfair Display',serif;font-size:1.2rem;font-weight:700;margin-bottom:1.5rem;color:var(--gd)}
.objectifs-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(140px,1fr));gap:.8rem;margin-bottom:1.5rem}
.obj-btn{background:var(--bg);border:2px solid var(--b);border-radius:var(--r);padding:1rem;text-align:center;cursor:pointer;transition:all .2s;font-family:inherit}
.obj-btn:hover{border-color:var(--g);background:var(--gl)}
.obj-btn.active{border-color:var(--g);background:var(--gl)}
.obj-icon{font-size:2rem;display:block;margin-bottom:.4rem}
.obj-nom{font-size:.82rem;font-weight:600;color:var(--t)}
.field{margin-bottom:1.2rem}
.field label{display:block;font-size:.78rem;font-weight:600;color:var(--m);margin-bottom:.5rem;text-transform:uppercase;letter-spacing:.05em}
.field input[type=range]{width:100%;accent-color:var(--g);height:6px;margin:.5rem 0}
.field .val{font-family:'Playfair Display',serif;font-size:1.6rem;font-weight:700;color:var(--gd)}
.field .val span{font-size:.85rem;font-weight:400;color:var(--m)}
.btn-generer{background:linear-gradient(135deg,#1e1b4b,#4338ca);color:white;border:none;padding:.9rem 2.5rem;border-radius:50px;font-weight:700;cursor:pointer;font-family:inherit;font-size:1rem;width:100%;margin-top:.5rem}
.defi-result{display:none}
.defi-result.show{display:block;animation:fadeIn .4s ease}
@keyframes fadeIn{from{opacity:0;transform:translateY(10px)}to{opacity:1;transform:translateY(0)}}
.defi-header{background:linear-gradient(135deg,#1e1b4b,#4338ca);border-radius:var(--r);padding:2rem;color:white;text-align:center;margin-bottom:1.5rem}
.defi-header .emoji{font-size:3rem;display:block;margin-bottom:.5rem}
.defi-header h2{font-family:'Playfair Display',serif;font-size:1.4rem;margin-bottom:.3rem}
.defi-header .sous{font-size:.85rem;color:rgba(255,255,255,.75)}
.defi-stats{display:grid;grid-template-columns:repeat(3,1fr);gap:1rem;margin-bottom:1.5rem}
.defi-stat{background:var(--w);border:1px solid var(--b);border-radius:var(--r);padding:1.2rem;text-align:center}
.defi-stat .num{font-family:'Playfair Display',serif;font-size:1.5rem;font-weight:900;color:var(--gd);display:block}
.defi-stat .lbl{font-size:.72rem;color:var(--m)}
.plan-table{background:var(--w);border-radius:var(--r);border:1px solid var(--b);padding:1.5rem;margin-bottom:1.5rem;box-shadow:0 4px 20px rgba(0,0,0,.04)}
.plan-table h2{font-family:'Playfair Display',serif;font-size:1.1rem;font-weight:700;margin-bottom:1rem;color:var(--gd)}
.semaines{display:flex;flex-direction:column;gap:.5rem;max-height:400px;overflow-y:auto}
.semaine-item{display:flex;align-items:center;gap:.8rem;padding:.6rem .8rem;border-radius:10px;font-size:.85rem;background:var(--bg)}
.semaine-item.milestone{background:var(--gl);font-weight:600}
.sem-num{width:80px;flex-shrink:0;font-weight:600;color:var(--m);font-size:.78rem}
.sem-bar{flex:1;height:10px;background:var(--b);border-radius:50px;overflow:hidden}
.sem-fill{height:100%;background:linear-gradient(90deg,#4338ca,var(--g));border-radius:50px}
.sem-montant{width:70px;text-align:right;font-weight:700;color:var(--gd);font-size:.82rem;flex-shrink:0}
.sem-cumul{width:90px;text-align:right;color:var(--m);font-size:.75rem;flex-shrink:0}
.astuces{background:var(--gl);border-radius:var(--r);padding:1.5rem;margin-bottom:1.5rem}
.astuces h3{font-family:'Playfair Display',serif;font-size:1.1rem;font-weight:700;color:var(--gd);margin-bottom:1rem}
.astuce-list{display:flex;flex-direction:column;gap:.6rem}
.astuce-item{display:flex;align-items:flex-start;gap:.7rem;font-size:.85rem;color:var(--t)}
.cta{background:linear-gradient(135deg,var(--al),#FFF8EE);border-radius:var(--r);padding:1.8rem;text-align:center}
.cta h3{font-family:'Playfair Display',serif;font-size:1.1rem;color:#633806;margin-bottom:.4rem}
.cta p{font-size:.86rem;color:var(--m);margin-bottom:1rem}
.cta-form{display:flex;gap:.5rem;max-width:360px;margin:0 auto;flex-wrap:wrap;justify-content:center}
.cta-form input{flex:1;min-width:150px;padding:.65rem 1rem;border-radius:50px;border:1px solid var(--b);font-size:.86rem;font-family:inherit}
.cta-form button{background:var(--a);color:white;border:none;padding:.65rem 1.3rem;border-radius:50px;font-weight:600;cursor:pointer;font-family:inherit;font-size:.86rem}
footer{background:var(--gd);color:rgba(255,255,255,.6);text-align:center;padding:1.5rem;font-size:.8rem;margin-top:2rem}
footer strong{color:white}
@media(max-width:640px){.hero{padding:2rem 1.2rem}.container{padding:1.5rem 1rem}.defi-stats{grid-template-columns:1fr 1fr}.semaine-item{flex-wrap:wrap}}

/* Menu hamburger mobile */
.hamburger{display:none;flex-direction:column;gap:5px;cursor:pointer;background:none;border:none;padding:.3rem}
.hamburger span{display:block;width:24px;height:2px;background:var(--gd,#085041);border-radius:2px;transition:all .3s}
.mobile-menu{display:none;position:fixed;top:0;left:0;right:0;bottom:0;background:rgba(255,255,255,.98);z-index:999;flex-direction:column;align-items:center;justify-content:center;gap:1.5rem}
.mobile-menu.open{display:flex}
.mobile-menu a{font-family:'Playfair Display',serif;font-size:1.3rem;font-weight:700;color:#085041;text-decoration:none}
.mobile-menu .close-btn{position:absolute;top:1.2rem;right:1.5rem;background:none;border:none;font-size:1.8rem;cursor:pointer;color:#085041}
.mobile-menu .nav-cta{background:#1D9E75;color:white!important;padding:.5rem 1.4rem;border-radius:50px}
@media(max-width:768px){
  .hamburger{display:flex}
  nav .nav-links, nav > a:not(.logo), nav > div{display:none!important}
  nav li{display:none!important}
}
</style>

