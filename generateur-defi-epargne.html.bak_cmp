<button class="hamburger" onclick="toggleMenu()" aria-label="Menu"><span></span><span></span><span></span></button></nav><div class="mobile-menu" id="mobileMenu"><button class="close-btn" onclick="toggleMenu()">X</button><a href="index.html">Accueil</a><a href="jeux.html">Jeux</a><a href="outils-gratuits.html">Outils gratuits</a><a href="comparateurs.html">Comparateurs</a><a href="a-propos.html">A propos</a><a href="recherche.html">Rechercher</a></div>
<div class="hero">
  <h1>Générateur de <em>Défi Épargne</em></h1>
  <p>Choisissez votre objectif et obtenez un plan d'épargne semaine par semaine. Simple, motivant, efficace.</p>
</div>
<div class="container">
  <div class="card">
    <h2>🎯 Choisissez votre objectif</h2>
    <div class="objectifs-grid" id="objectifs-grid">
      <button class="obj-btn active" data-obj="vacances" data-montant="1500" onclick="selectObj(this)"><span class="obj-icon">✈️</span><span class="obj-nom">Vacances</span></button>
      <button class="obj-btn" data-obj="voiture" data-montant="5000" onclick="selectObj(this)"><span class="obj-icon">🚗</span><span class="obj-nom">Voiture</span></button>
      <button class="obj-btn" data-obj="apport" data-montant="20000" onclick="selectObj(this)"><span class="obj-icon">🏠</span><span class="obj-nom">Apport immo</span></button>
      <button class="obj-btn" data-obj="mariage" data-montant="8000" onclick="selectObj(this)"><span class="obj-icon">💍</span><span class="obj-nom">Mariage</span></button>
      <button class="obj-btn" data-obj="urgence" data-montant="3000" onclick="selectObj(this)"><span class="obj-icon">🛡️</span><span class="obj-nom">Fonds urgence</span></button>
      <button class="obj-btn" data-obj="formation" data-montant="2000" onclick="selectObj(this)"><span class="obj-icon">🎓</span><span class="obj-nom">Formation</span></button>
      <button class="obj-btn" data-obj="bebe" data-montant="3000" onclick="selectObj(this)"><span class="obj-icon">👶</span><span class="obj-nom">Bébé</span></button>
      <button class="obj-btn" data-obj="retraite" data-montant="50000" onclick="selectObj(this)"><span class="obj-icon">🌅</span><span class="obj-nom">Retraite</span></button>
      <button class="obj-btn" data-obj="custom" data-montant="0" onclick="selectObj(this)"><span class="obj-icon">✏️</span><span class="obj-nom">Mon objectif</span></button>
    </div>

    <div class="field">
      <label>Montant à atteindre</label>
      <div class="val" id="v-montant">1 500 <span>€</span></div>
      <input type="range" id="montant" min="100" max="100000" step="100" value="1500">
    </div>

    <div class="field">
      <label>Épargne mensuelle possible</label>
      <div class="val" id="v-epargne">200 <span>€/mois</span></div>
      <input type="range" id="epargne" min="10" max="3000" step="10" value="200">
    </div>

    <button class="btn-generer" onclick="generer()">🎯 Générer mon défi épargne</button>
  </div>

  <div class="defi-result" id="defi-result">

    <div class="defi-header" id="defi-header">
      <span class="emoji" id="defi-emoji">✈️</span>
      <h2 id="defi-titre">Mon défi vacances</h2>
      <div class="sous" id="defi-sous">Chargement...</div>
    </div>

    <div class="defi-stats">
      <div class="defi-stat"><span class="num" id="ds-objectif">—</span><div class="lbl">Objectif</div></div>
      <div class="defi-stat"><span class="num" id="ds-duree">—</span><div class="lbl">Durée</div></div>
      <div class="defi-stat"><span class="num" id="ds-semaine">—</span><div class="lbl">Par semaine</div></div>
    </div>

    <div class="plan-table">
      <h2>📅 Votre plan semaine par semaine</h2>
      <div class="semaines" id="semaines-list"></div>
    </div>

    <div class="astuces" id="astuces-block">
      <h3>💡 Astuces pour réussir votre défi</h3>
      <div class="astuce-list" id="astuces-list"></div>
    </div>

    <div class="cta">
      <h3>📬 Recevez votre suivi défi chaque semaine</h3>
      <p>Rappels, encouragements et astuces pour tenir votre défi épargne jusqu'au bout.</p>
      <div class="cta-form">
        <input type="email" placeholder="votre@email.fr">
        <button>Je participe !</button>
      </div>
    </div>
  </div>
</div>


<!-- Boutons partage -->
<div style="background:#fff;border-radius:16px;border:1px solid rgba(0,0,0,0.08);padding:1.2rem 1.5rem;margin:2rem auto;max-width:680px;text-align:center">
  <p style="font-size:.82rem;font-weight:600;color:#5F5E5A;margin-bottom:.8rem;text-transform:uppercase;letter-spacing:.05em">Partager cet article</p>
