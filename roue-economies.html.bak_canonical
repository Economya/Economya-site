.container{max-width:700px;margin:0 auto;padding:1.5rem}

/* TOTAL SAVED */
.total-banner{background:linear-gradient(135deg,var(--gd),var(--g));color:white;border-radius:16px;padding:1.2rem;text-align:center;margin-bottom:1.5rem}
.total-label{font-size:.78rem;text-transform:uppercase;letter-spacing:.06em;color:rgba(255,255,255,.7);margin-bottom:.2rem}
.total-val{font-family:'Playfair Display',serif;font-size:2.5rem;font-weight:900;color:var(--a);display:block}
.total-sub{font-size:.78rem;color:rgba(255,255,255,.6);margin-top:.2rem}

/* WHEEL WRAP */
.wheel-wrap{position:relative;width:320px;margin:0 auto 1.5rem;user-select:none}
.wheel-pointer{position:absolute;top:-18px;left:50%;transform:translateX(-50%);font-size:2rem;z-index:10;filter:drop-shadow(0 2px 4px rgba(0,0,0,.3))}
canvas#wheel{display:block;border-radius:50%;box-shadow:0 8px 32px rgba(0,0,0,.15);cursor:pointer}
.wheel-center{position:absolute;top:50%;left:50%;transform:translate(-50%,-50%);width:52px;height:52px;background:white;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:1.4rem;box-shadow:0 2px 8px rgba(0,0,0,.2);cursor:pointer;z-index:5}

/* SPIN BTN */
.spin-btn{display:block;width:100%;background:linear-gradient(135deg,#5a4a00,#a07800);color:white;border:none;padding:.9rem;border-radius:50px;font-weight:700;font-size:1rem;cursor:pointer;font-family:inherit;margin-bottom:1.2rem;transition:transform .1s,opacity .2s}
.spin-btn:hover{transform:scale(1.02)}
.spin-btn:disabled{opacity:.5;cursor:not-allowed;transform:none}

/* RESULT CARD */
.result-card{background:var(--w);border-radius:16px;border:2px solid var(--b);padding:1.5rem;margin-bottom:1.2rem;display:none;animation:popIn .4s ease}
@keyframes popIn{from{opacity:0;transform:scale(.9)}to{opacity:1;transform:scale(1)}}
.result-emoji{font-size:3rem;display:block;text-align:center;margin-bottom:.5rem}
.result-cat{font-size:.72rem;font-weight:700;text-transform:uppercase;letter-spacing:.06em;text-align:center;margin-bottom:.3rem}
.result-title{font-family:'Playfair Display',serif;font-size:1.3rem;font-weight:700;color:var(--gd);text-align:center;margin-bottom:.5rem}
.result-saving{text-align:center;margin-bottom:.8rem}
.saving-val{font-family:'Playfair Display',serif;font-size:2rem;font-weight:900;color:var(--g);display:block}
.saving-lbl{font-size:.75rem;color:var(--m)}
.result-tip{background:#f0fdf4;border-left:4px solid var(--g);border-radius:0 12px 12px 0;padding:.8rem 1rem;font-size:.85rem;color:var(--t);line-height:1.6;margin-bottom:.8rem}
.result-actions{display:flex;gap:.5rem;flex-wrap:wrap}
.btn-apply{background:var(--g);color:white;border:none;padding:.6rem 1.2rem;border-radius:50px;font-weight:700;cursor:pointer;font-family:inherit;font-size:.82rem;flex:1}
.btn-share{background:transparent;border:2px solid var(--g);color:var(--gd);padding:.6rem 1.2rem;border-radius:50px;font-weight:700;cursor:pointer;font-family:inherit;font-size:.82rem;flex:1}

/* HISTORY */
.history{background:var(--w);border-radius:16px;border:1px solid var(--b);padding:1.2rem;margin-bottom:1.2rem}
.history h3{font-size:.82rem;font-weight:700;color:var(--m);text-transform:uppercase;letter-spacing:.05em;margin-bottom:.8rem}
.history-item{display:flex;justify-content:space-between;align-items:center;padding:.5rem 0;border-bottom:1px solid var(--b);font-size:.85rem}
.history-item:last-child{border-bottom:none}
