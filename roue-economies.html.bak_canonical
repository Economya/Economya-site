<script>
const ASTUCES = [
  {emoji:'📱', cat:'Téléphonie', color:'#7c3aed', title:'Changer de forfait mobile', saving:300, tip:'Passez à un forfait low-cost (RED, Prixtel, Free) au lieu des opérateurs historiques. Même réseau, 3x moins cher. Économie moyenne : 25€/mois.', article:'article-113.html'},
  {emoji:'☕', cat:'Quotidien', color:'#92400e', title:'Café maison vs café au bar', saving:600, tip:'1 café à 2€ par jour = 720€/an. Une cafetière à 30€ + café moulu = 60€/an. Économie nette : 660€ pour un seul geste.', article:'article-35.html'},
  {emoji:'🏦', cat:'Banque', color:'#1e40af', title:'Banque en ligne gratuite', saving:150, tip:'Les banques traditionnelles coûtent en moyenne 150€/an en frais divers. Boursobank, Hello Bank, Fortuneo sont 100% gratuites.', article:'article-182.html'},
  {emoji:'📺', cat:'Streaming', color:'#be185d', title:'Partager ses abonnements', saving:250, tip:'Netflix + Spotify + Disney+ en solo = 40€/mois. Partagez via Sharesub avec 3 amis = 12€/mois. Économie : 28€/mois, 336€/an.', article:'article-13.html'},
  {emoji:'🛒', cat:'Courses', color:'#065f46', title:'Switcher vers Lidl ou Aldi', saving:400, tip:'Un panier identique coûte 22% moins cher chez Lidl vs Carrefour. Sur 400€/mois de courses : 88€ économisés par mois, soit 1 056€/an.', article:'article-3.html'},
  {emoji:'💊', cat:'Santé', color:'#7f1d1d', title:'Génériques au lieu des marques', saving:120, tip:'Le Doliprane à 3,20€ vs paracétamol générique à 1,10€. Multipliez par tous vos médicaments courants : 120€/an d\'économies facilement.', article:'article-18.html'},
  {emoji:'⚡', cat:'Énergie', color:'#713f12', title:'Éteindre les veilles', saving:150, tip:'Les appareils en veille représentent 10% de votre facture électricité. Une multiprise à interrupteur (8€) éteint tout d\'un geste. Économie : 150€/an.', article:'article-110.html'},
  {emoji:'🚗', cat:'Transport', color:'#1e3a5f', title:'Comparer son assurance auto', saving:350, tip:'80% des automobilistes n\'ont pas comparé leur assurance depuis 2 ans. En moyenne, comparer économise 30€/mois. Soit 350€/an.', article:'article-61.html'},
  {emoji:'🏠', cat:'Logement', color:'#14532d', title:'Renégocier son assurance habitation', saving:156, tip:'Les assurances habitation augmentent automatiquement chaque année. Comparer et changer prend 15 min et économise 13€/mois en moyenne.', article:'article-9.html'},
  {emoji:'🍕', cat:'Alimentation', color:'#7c2d12', title:'Batch cooking le dimanche', saving:2400, tip:'2h de cuisine le dimanche = 5 déjeuners préparés. Au lieu de 12€/repas au resto : 3€/repas maison. Économie : 45€/semaine, 2 340€/an.', article:'article-84.html'},
  {emoji:'💡', cat:'Éclairage', color:'#713f12', title:'Passer aux ampoules LED', saving:80, tip:'Une LED consomme 8x moins qu\'une halogène. Équiper tout un logement coûte 80€ et économise 80€/an en électricité. Amorti en 1 an.', article:'article-54.html'},
  {emoji:'📚', cat:'Culture', color:'#1e3a8a', title:'Bibliothèque municipale', saving:300, tip:'Un livre moyen coûte 18€. Lire 1 livre par mois via la médiathèque = 216€ économisés. Accès gratuit ou quasi-gratuit dans toutes les communes.', article:'article-22.html'},
  {emoji:'🧴', cat:'Beauté', color:'#831843', title:'Cosmétiques marques distributeur', saving:200, tip:'Les crèmes Lidl ou Aldi sont souvent formulées par les mêmes labos que les grandes marques. Économie : 15 à 20€/mois, 200€/an.', article:'article-36.html'},
  {emoji:'🎬', cat:'Loisirs', color:'#4a1d96', title:'UGC ou CGR au lieu des multiplexes', saving:120, tip:'Le cinéma UGC Illimité (23€/mois) = illimité. Vs 13€ la séance : à partir de 2 séances/mois vous êtes gagnant. 120€/an économisés.', article:'article-143.html'},
  {emoji:'🐕', cat:'Animaux', color:'#78350f', title:'Mutuelle animaux vs soins directs', saving:400, tip:'Une mutuelle chien à 20€/mois couvre les soins à 80%. Une seule opération (800€+) et la mutuelle est rentabilisée pour 3 ans.', article:'article-79.html'},
  {emoji:'🧹', cat:'Maison', color:'#166534', title:'Produits ménagers maison', saving:180, tip:'Vinaigre blanc + bicarbonate + savon noir = 3 produits qui remplacent 15 produits du supermarché. Économie : 15€/mois, 180€/an.', article:'article-186.html'},
];

const COLORS = ['#1D9E75','#EF9F27','#7c3aed','#1e40af','#be185d','#065f46','#7f1d1d','#713f12','#1e3a5f','#14532d','#7c2d12','#1e3a8a','#831843','#4a1d96','#78350f','#166534'];

let spinning = false, totalSavings = 0, spinCount = 0, maxSpins = 10;
let history = [], currentResult = null;
let angle = 0;

const canvas = document.getElementById('wheel');
const ctx = canvas.getContext('2d');
const N = ASTUCES.length;
const arc = (2 * Math.PI) / N;

function drawWheel(rotation) {
  ctx.clearRect(0, 0, canvas.width, canvas.height);
  const cx = canvas.width / 2, cy = canvas.height / 2, r = cx - 4;

  for(let i = 0; i < N; i++) {
    const start = rotation + i * arc - Math.PI / 2;
    const end = start + arc;
    ctx.beginPath();
    ctx.moveTo(cx, cy);
    ctx.arc(cx, cy, r, start, end);
    ctx.closePath();
    ctx.fillStyle = COLORS[i % COLORS.length];
    ctx.fill();
    ctx.strokeStyle = 'rgba(255,255,255,.3)';
    ctx.lineWidth = 1.5;
    ctx.stroke();

    ctx.save();
    ctx.translate(cx, cy);
    ctx.rotate(start + arc / 2);
    ctx.textAlign = 'right';
    ctx.fillStyle = 'white';
    ctx.font = 'bold 11px DM Sans';
    ctx.fillText(ASTUCES[i].emoji + ' ' + ASTUCES[i].title.split(' ').slice(0,2).join(' '), r - 10, 4);
    ctx.restore();
  }

  // Center circle
  ctx.beginPath();
  ctx.arc(cx, cy, 26, 0, 2 * Math.PI);
  ctx.fillStyle = 'white';
  ctx.fill();
  ctx.strokeStyle = 'rgba(0,0,0,.1)';
  ctx.lineWidth = 2;
  ctx.stroke();
}

function spinWheel() {
  if(spinning || spinCount >= maxSpins) return;
  spinning = true;
  document.getElementById('spin-btn').disabled = true;
  document.getElementById('result-card').style.display = 'none';

  const extraSpins = (Math.floor(Math.random() * 5) + 5) * 2 * Math.PI;
  const targetAngle = angle + extraSpins + Math.random() * 2 * Math.PI;
  const duration = 3000 + Math.random() * 1000;
  const start = performance.now();
  const startAngle = angle;

  function animate(now) {
    const elapsed = now - start;
    const progress = Math.min(elapsed / duration, 1);
    const ease = 1 - Math.pow(1 - progress, 4);
    angle = startAngle + (targetAngle - startAngle) * ease;
    drawWheel(angle);

    if(progress < 1) {
      requestAnimationFrame(animate);
    } else {
      angle = targetAngle % (2 * Math.PI);
      drawWheel(angle);
      spinning = false;
      spinCount++;
      showResult(getResult());
      document.getElementById('spin-btn').disabled = spinCount >= maxSpins;
      document.getElementById('spin-count').textContent = spinCount;
      document.getElementById('spins-left').textContent = Math.max(0, maxSpins - spinCount);
    }
  }
  requestAnimationFrame(animate);
}

function getResult() {
  const normalized = ((2 * Math.PI - (angle % (2 * Math.PI))) + Math.PI / 2) % (2 * Math.PI);
  const idx = Math.floor(normalized / arc) % N;
  return ASTUCES[idx];
}

function showResult(astuce) {
  currentResult = astuce;
  totalSavings += astuce.saving;

  document.getElementById('res-emoji').textContent = astuce.emoji;
  document.getElementById('res-cat').textContent = astuce.cat;
  document.getElementById('res-cat').style.color = astuce.color;
  document.getElementById('res-title').textContent = astuce.title;
  document.getElementById('res-saving').textContent = astuce.saving.toLocaleString('fr-FR') + '€';
  document.getElementById('res-tip').textContent = astuce.tip;

  document.getElementById('total-val').textContent = totalSavings.toLocaleString('fr-FR') + '€';
  document.getElementById('total-sub').textContent = `En appliquant ${spinCount} astuce${spinCount > 1 ? 's' : ''} — économies annuelles potentielles`;

  document.getElementById('result-card').style.display = 'block';
  document.getElementById('result-card').style.borderColor = astuce.color;

  addToHistory(astuce);
  document.getElementById('result-card').scrollIntoView({behavior:'smooth', block:'center'});
}

function addToHistory(astuce) {
  history.unshift(astuce);
  const list = document.getElementById('history-list');
  list.innerHTML = history.map(a => `
    <div class="history-item">
      <span class="history-emoji">${a.emoji}</span>
      <span class="history-title">${a.title}</span>
      <span class="history-saving">${a.saving.toLocaleString('fr-FR')}€/an</span>
    </div>
  `).join('');
}

function applyTip() {
  if(currentResult) {
    window.open(currentResult.article, '_blank');
  }
}

function shareTip() {
  if(currentResult) {
    const text = `🎡 J'ai découvert que "${currentResult.title}" peut m'économiser ${currentResult.saving.toLocaleString('fr-FR')}€/an ! Testez la Roue des Économies sur economya.fr`;
    if(navigator.share) {
      navigator.share({title:'Economya.fr', text, url:'https://economya.fr/roue-economies.html'});
    } else {
      navigator.clipboard.writeText(text).then(() => alert('Copié !'));
    }
  }
}

drawWheel(0);
</script>
