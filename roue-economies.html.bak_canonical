.empty-history{color:var(--m);font-size:.85rem;font-style:italic;text-align:center;padding:.5rem 0}

/* COUNTER */
.spin-counter{text-align:center;font-size:.82rem;color:var(--m);margin-bottom:1rem}
.spin-counter span{font-weight:700;color:var(--gd)}

