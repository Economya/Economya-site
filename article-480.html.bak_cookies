.cta{background:linear-gradient(135deg,#1c1000,#92400e);border-radius:var(--r);padding:1.8rem;text-align:center;margin-top:2.5rem;color:white}
.cta h3{font-family:'Playfair Display',serif;font-size:1.2rem;margin-bottom:.4rem}
