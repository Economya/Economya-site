/* PLATEFORMES */
.plates{display:flex;flex-direction:column;gap:.9rem;margin:1.5rem 0}
.plate{background:var(--w);border:1px solid var(--b);border-radius:var(--r);padding:1.1rem 1.5rem;display:grid;grid-template-columns:auto 1fr auto;gap:1rem;align-items:start;transition:box-shadow .2s}
