p{margin-bottom:1rem;font-size:.95rem}

/* OUI / NON */
.ouinon{display:grid;grid-template-columns:1fr 1fr;gap:1.2rem;margin:1.5rem 0}
@media(max-width:520px){.ouinon{grid-template-columns:1fr}}
.oui{background:#f0fdf4;border:2px solid #86efac;border-radius:var(--r);padding:1.2rem}
.non{background:#fef2f2;border:2px solid #fecaca;border-radius:var(--r);padding:1.2rem}
.on-title{font-weight:700;font-size:.92rem;margin-bottom:.6rem}
.oui .on-title{color:#166534}
.non .on-title{color:#dc2626}
.on-list{list-style:none;display:flex;flex-direction:column;gap:.35rem}
.on-list li{font-size:.82rem;font-weight:300;padding-left:.8rem;position:relative}
.on-list li::before{position:absolute;left:0;font-weight:700}
.oui .on-list li{color:#166534}
.oui .on-list li::before{content:'✓';color:#16a34a}
.non .on-list li{color:#7f1d1d}
.non .on-list li::before{content:'✗';color:#dc2626}

/* ÉTAPES */
.steps{display:flex;flex-direction:column;gap:.85rem;margin:1.2rem 0}
.step{display:grid;grid-template-columns:38px 1fr;gap:.9rem;align-items:start;background:var(--w);border:1px solid var(--b);border-radius:var(--r);padding:1rem 1.2rem;transition:box-shadow .2s}
.step:hover{box-shadow:0 4px 16px rgba(67,56,202,.1)}
.sn{width:38px;height:38px;border-radius:50%;background:linear-gradient(135deg,#1e1b5e,#4338ca);color:white;font-family:'Playfair Display',serif;font-weight:700;font-size:1rem;display:flex;align-items:center;justify-content:center;flex-shrink:0}
.sc h3{font-size:.92rem;font-weight:600;margin-bottom:.2rem}
.sc p{font-size:.84rem;color:var(--m);font-weight:300;margin:0}
.sc .stag{display:inline-block;margin-top:.35rem;background:var(--gl);color:var(--gd);font-size:.7rem;font-weight:600;padding:.12rem .55rem;border-radius:50px}

/* PROBLÈMES */
.problemes{display:flex;flex-direction:column;gap:.75rem;margin:1.2rem 0}
.prob{background:var(--w);border:1px solid var(--b);border-radius:var(--r);padding:.9rem 1.1rem;display:flex;gap:.9rem;align-items:flex-start}
.prob .pico{font-size:1.2rem;flex-shrink:0;margin-top:.05rem}
.prob strong{display:block;font-size:.9rem;margin-bottom:.1rem;color:var(--indigo)}
.prob span{font-size:.84rem;color:var(--m);font-weight:300}

/* ENCADRÉS */
.tip{background:var(--gl);border-left:4px solid var(--g);border-radius:var(--r);padding:1.1rem 1.4rem;margin:1.5rem 0;font-size:.9rem;color:var(--gd)}
.tip strong{display:block;font-weight:600;margin-bottom:.25rem}
.warn{background:var(--indigo-l);border-left:4px solid var(--indigo);border-radius:var(--r);padding:1.1rem 1.4rem;margin:1.5rem 0;font-size:.9rem;color:#1e1b5e}
.warn strong{display:block;font-weight:600;margin-bottom:.25rem}

.cta{background:linear-gradient(135deg,#0f0c29,#1e1b5e);border-radius:var(--r);padding:1.8rem;text-align:center;margin-top:2.5rem;color:white}
.cta h3{font-family:'Playfair Display',serif;font-size:1.2rem;margin-bottom:.4rem}
.cta p{color:rgba(255,255,255,.7);font-size:.86rem;margin-bottom:1rem}
.cta-form{display:flex;gap:.5rem;max-width:360px;margin:0 auto;flex-wrap:wrap;justify-content:center}
.cta-form input{flex:1;min-width:150px;padding:.65rem 1rem;border-radius:50px;border:none;font-size:.86rem;font-family:inherit}
.cta-form button{background:linear-gradient(135deg,#4338ca,#059669);color:white;border:none;padding:.65rem 1.3rem;border-radius:50px;font-weight:600;cursor:pointer;font-family:inherit;font-size:.86rem}
footer{background:var(--gd);color:rgba(255,255,255,.6);text-align:center;padding:1.5rem;font-size:.8rem}
footer strong{color:white}
@media(max-width:640px){.ah{padding:2rem 1.2rem}.ab{padding:1.8rem 1.1rem 3rem}.ah::before{font-size:8rem}}

/* Menu hamburger mobile */
