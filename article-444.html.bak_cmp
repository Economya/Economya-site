p{margin-bottom:1rem;font-size:.95rem}

/* DURÉES */
.durees{display:grid;grid-template-columns:repeat(auto-fit,minmax(155px,1fr));gap:1rem;margin:1.5rem 0}
.duree{background:var(--w);border:1px solid var(--b);border-radius:var(--r);padding:1.1rem;text-align:center;transition:transform .2s}
.duree:hover{transform:translateY(-2px)}
.duree.top{border:2px solid var(--g)}
.d-icon{font-size:1.6rem;margin-bottom:.35rem}
.d-type{font-weight:700;font-size:.88rem;margin-bottom:.2rem}
.d-duree{font-family:'Playfair Display',serif;font-size:1.1rem;font-weight:700;color:var(--indigo);margin:.15rem 0}
.d-note{font-size:.74rem;color:var(--m);font-weight:300;line-height:1.3}

/* ÉTAPES */
.steps{display:flex;flex-direction:column;gap:.85rem;margin:1.5rem 0}
.step{display:grid;grid-template-columns:38px 1fr;gap:.9rem;align-items:start;background:var(--w);border:1px solid var(--b);border-radius:var(--r);padding:1rem 1.2rem;transition:box-shadow .2s}
.step:hover{box-shadow:0 4px 14px rgba(67,56,202,.08)}
.step.top{border:2px solid var(--g)}
.sn{width:38px;height:38px;border-radius:50%;background:linear-gradient(135deg,#1e1b5e,#4338ca);color:white;font-family:'Playfair Display',serif;font-weight:700;font-size:1rem;display:flex;align-items:center;justify-content:center;flex-shrink:0}
.sc h3{font-size:.92rem;font-weight:600;margin-bottom:.2rem}
