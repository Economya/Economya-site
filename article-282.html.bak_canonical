    <div class="mois basse"><div class="mois-name">Avril</div><div class="mois-label">Épaule</div><div class="mois-eco">−25 %</div></div>
    <div class="mois basse"><div class="mois-name">Mai</div><div class="mois-label">Pré-saison</div><div class="mois-eco">−30 %</div></div>
